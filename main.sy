import (
    { cliProgramArgv } from @driver/cli_argv
    { runStandaloneCli, standaloneCliShouldTryExec } from @driver/main_standalone
    { cliOutputIsExecPath } from @driver/cli_exec
    { cliOsExec } from ./cli_main_exec
)

fn main() {
    val argv = cliProgramArgv()
    val output = runStandaloneCli(argv)
    if standaloneCliShouldTryExec(argv) && cliOutputIsExecPath(output) {
        print(cliOsExec(output))
        return
    }
    print(output)
}

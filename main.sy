import (
    { cliProgramArgv } from @driver/cli_argv
    { runStandaloneCli, standaloneCliBootstrapShellCommand } from @driver/main_standalone
    { cliOsExecShell } from ./cli_main_exec
)

fn main() {
    val argv = cliProgramArgv()
    val bootstrap = standaloneCliBootstrapShellCommand(argv)
    if bootstrap.len() > 0 {
        print(cliOsExecShell(bootstrap))
        return
    }
    print(runStandaloneCli(argv))
}

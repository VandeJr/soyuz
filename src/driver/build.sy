pub fn defaultDriverFullBuildCheckScript() -> String = "tools/driver-full-build-check.sh"

pub fn defaultDriverHelloIrLinkCheckScript() -> String = "tools/driver-hello-ir-link-check.sh"

pub fn defaultExportDriverHelloIrScript() -> String = "tools/export-driver-hello-ir.sh"

pub fn defaultDriverExportCodegenIrCheckScript() -> String = "tools/driver-export-codegen-ir-check.sh"

pub fn defaultDriverAppliedManifestLinkCheckScript() -> String = "tools/driver-applied-manifest-link-check.sh"

pub fn defaultDriverRunPlanLinkCheckScript() -> String = "tools/driver-run-plan-link-check.sh"

pub fn defaultExportHelloRunManifestScript() -> String = "tools/export-hello-run-manifest.sh"

pub fn defaultDriverRunManifestRoundTripCheckScript() -> String = "tools/driver-run-manifest-round-trip-check.sh"

pub fn defaultDriverRunPlanMaterializeCheckScript() -> String = "tools/driver-run-plan-materialize-check.sh"

pub fn defaultDriverBootstrapHelloRunCheckScript() -> String = "tools/driver-bootstrap-hello-run-check.sh"

pub fn defaultDriverCliRunDispatchCheckScript() -> String = "tools/driver-cli-run-dispatch-check.sh"

pub fn defaultDriverCliRunPipelineCheckScript() -> String = "tools/driver-cli-run-pipeline-check.sh"

pub fn defaultDriverCliEntryCheckScript() -> String = "tools/driver-cli-entry-check.sh"

pub fn defaultDriverCliNewCheckScript() -> String = "tools/driver-cli-new-check.sh"

pub fn defaultDriverCliBuildCheckScript() -> String = "tools/driver-cli-build-check.sh"


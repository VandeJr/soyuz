import (
    { runtimeAssetNames } from @runtime/embed
    { emptyPathIndex, joinPathFile } from @module/paths
    { newResolverWithStdlib } from @module/resolver
    { buildConfigForEntry, defaultRuntimeSrcDir } from @driver/build
    { planFullBuild, fullBuildReady } from @driver/pipeline
    { manifestContainsPath } from @runtime/manifest
    { defaultLlFilePath } from @runtime/link
    { assertMsg } from @soyuz/testing
)

test fn testPlanFullBuildHello() {
    val entry = "/tmp/hello.sy"
    val stdlibDir = "/tmp/stdlib"
    val goRoot = "/ref/soyuz-go"
    val runtimeSrc = defaultRuntimeSrcDir(goRoot)
    val tmpDir = "/tmp/soyuz-abc"
    var index = emptyPathIndex()
    index.fileContents.set(joinPathFile(stdlibDir, "prelude.sy"), "pub fn print(x: String) {}")
    index.fileContents.set(entry, "fn main() {\n    print(\"hello\")\n}\n")
    var sourceIndex = emptyPathIndex()
    for name in runtimeAssetNames() {
        sourceIndex.fileContents.set(joinPathFile(runtimeSrc, name), "// $(name)\n")
    }
    val cfg = buildConfigForEntry(entry, "$(tmpDir)/app", false, tmpDir, runtimeSrc)
    val r = newResolverWithStdlib(entry, stdlibDir)
    val plan = planFullBuild(entry, cfg, r, index, sourceIndex)
    assertMsg(fullBuildReady(plan), "full build plan ready")
    assertMsg(plan.error.len() == 0, "no build error")
    assertMsg(plan.codegen.funcCount >= 1, "codegen produced main")
    assertMsg(manifestContainsPath(plan.artifacts.manifest, defaultLlFilePath(tmpDir)), "manifest includes ll")
}

test fn testPlanFullBuildMissingRuntime() {
    val entry = "/tmp/hello.sy"
    val stdlibDir = "/tmp/stdlib"
    val runtimeSrc = defaultRuntimeSrcDir("/ref/soyuz-go")
    var index = emptyPathIndex()
    index.fileContents.set(joinPathFile(stdlibDir, "prelude.sy"), "pub fn print(x: String) {}")
    index.fileContents.set(entry, "fn main() {}\n")
    val cfg = buildConfigForEntry(entry, "/tmp/out/app", false, "/tmp/build", runtimeSrc)
    val r = newResolverWithStdlib(entry, stdlibDir)
    val plan = planFullBuild(entry, cfg, r, index, emptyPathIndex())
    assertMsg(!fullBuildReady(plan), "missing runtime blocks link plan")
    assertMsg(plan.error.len() > 0, "error explains failure")
}

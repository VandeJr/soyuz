import (
    { cliActionUsage, cliActionRun, cliActionBuild, cliDispatchAction, cliDispatchNeedsUsage, cliDispatchUsageOutput, cliRunActionReady, cliHelloMinimalRunActionReady, cliRunActionPipelineReady, cliHelloMinimalRunActionPipelineReady, cliRunActionOrderedCommands, cliRunActionOrderedCommandsReady, cliHelloMinimalRunActionOrderedCommandsReady, cliRunActionExecCommand, cliHelloMinimalRunActionExecReady } from @driver/dispatch
    { cliCommandRun, cliCommandBuild, cliUsageHeader, defaultHelloMinimalFixturePath, cliHelloMinimalBinaryPath } from @driver/cli
    { runPlanOrderedMaterializeCommandCount } from @driver/run
    { assertMsg } from @soyuz/testing
)

test fn testCliDispatchAction() {
    var argv = List[String]{}
    argv.append("soyuz")
    assertMsg(cliDispatchAction(argv) == cliActionUsage(), "argv too short maps to usage")

    argv.append(cliCommandBuild())
    assertMsg(cliDispatchAction(argv) == cliActionBuild(), "build command routed")

    var runArgv = List[String]{}
    runArgv.append("soyuz")
    runArgv.append(cliCommandRun())
    runArgv.append(defaultHelloMinimalFixturePath())
    assertMsg(cliDispatchAction(runArgv) == cliActionRun(), "run command routed")
    assertMsg(cliRunActionReady(runArgv), "run action ready for hello fixture")
    assertMsg(cliHelloMinimalRunActionReady(), "hello minimal run action ready")
    assertMsg(cliRunActionPipelineReady(runArgv), "run action pipeline ready")
    assertMsg(cliHelloMinimalRunActionPipelineReady(), "hello minimal run action pipeline ready")
}

test fn testCliDispatchUsageAndOrderedCommands() {
    var argv = List[String]{}
    argv.append("soyuz")
    assertMsg(cliDispatchNeedsUsage(argv), "short argv needs usage")
    assertMsg(cliDispatchUsageOutput(argv).contains(cliUsageHeader()), "usage output has header")

    var runArgv = List[String]{}
    runArgv.append("soyuz")
    runArgv.append(cliCommandRun())
    runArgv.append(defaultHelloMinimalFixturePath())
    assertMsg(!cliDispatchNeedsUsage(runArgv), "run argv does not need usage")
    assertMsg(cliDispatchUsageOutput(runArgv).len() == 0, "run argv has no usage output")
    val cmds = cliRunActionOrderedCommands(runArgv)
    assertMsg(cmds.size() == runPlanOrderedMaterializeCommandCount(), "run action ordered commands")
    assertMsg(cliRunActionOrderedCommandsReady(runArgv), "run action ordered commands ready")
    assertMsg(cliHelloMinimalRunActionOrderedCommandsReady(), "hello minimal ordered commands ready")
    assertMsg(cliRunActionExecCommand(runArgv) == cliHelloMinimalBinaryPath(), "run action exec command")
    assertMsg(cliHelloMinimalRunActionExecReady(), "hello minimal run action exec ready")
}

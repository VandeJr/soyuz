import (
    { cliBuildReleaseFlag, cliBuildOutputFlag, cliBuildReleaseFromArgs, cliBuildOutputFromArgs, cliBuildLegacyEntryFromArgs, cliBuildLegacyHasEntry, cliBuildProjectModeFromArgs, buildCliLibraryVerifyStubMessage, buildCliLegacyDefaultOutput, buildCliLegacyPlanFromArgs, buildCliLegacyPlanReady, buildCliLegacySuccessMessage, defaultHelloMinimalBuildArgv, defaultSoyuzLibraryBuildArgv } from @driver/build_cli
    { helloMinimalFixturePath } from @driver/export
    { assertMsg } from @soyuz/testing
)

test fn testCliBuildArgsParse() {
    var args = List[String]{}
    args.append(helloMinimalFixturePath())
    assertMsg(cliBuildLegacyEntryFromArgs(args) == helloMinimalFixturePath(), "entry from positional")
    assertMsg(!cliBuildReleaseFromArgs(args), "no release by default")
    assertMsg(cliBuildOutputFromArgs(args).len() == 0, "no output flag")

    var withFlags = List[String]{}
    withFlags.append(cliBuildReleaseFlag())
    withFlags.append(cliBuildOutputFlag())
    withFlags.append("/tmp/out")
    withFlags.append(helloMinimalFixturePath())
    assertMsg(cliBuildReleaseFromArgs(withFlags), "release flag")
    assertMsg(cliBuildOutputFromArgs(withFlags) == "/tmp/out", "output flag value")
    assertMsg(cliBuildLegacyEntryFromArgs(withFlags) == helloMinimalFixturePath(), "entry after flags")
    assertMsg(cliBuildLegacyHasEntry(withFlags), "legacy has entry")
}

test fn testBuildCliLegacyPlanFromArgs() {
    var args = List[String]{}
    args.append(helloMinimalFixturePath())
    val plan = buildCliLegacyPlanFromArgs(args)
    assertMsg(buildCliLegacyPlanReady(plan), "legacy plan ready")
    assertMsg(plan.outputFile == buildCliLegacyDefaultOutput(), "default output")
    assertMsg(!plan.release, "default not release")

    var customOut = List[String]{}
    customOut.append(cliBuildOutputFlag())
    customOut.append("mybin")
    customOut.append(helloMinimalFixturePath())
    val customPlan = buildCliLegacyPlanFromArgs(customOut)
    assertMsg(customPlan.outputFile == "mybin", "custom output")
    assertMsg(buildCliLegacySuccessMessage(customPlan).contains("mybin"), "success message")
}

test fn testDefaultHelloMinimalBuildArgv() {
    val argv = defaultHelloMinimalBuildArgv()
    assertMsg(argv.size() == 3, "hello minimal build argv shape")
    assertMsg(argv.get(1) == "build", "build command")
}

test fn testBuildCliProjectMode() {
    assertMsg(cliBuildProjectModeFromArgs(List[String]{}), "empty args is project mode")
    var args = List[String]{}
    args.append(helloMinimalFixturePath())
    assertMsg(!cliBuildProjectModeFromArgs(args), "entry arg is legacy mode")
    assertMsg(buildCliLibraryVerifyStubMessage().contains("verificada com sucesso"), "library stub message")
    val libraryArgv = defaultSoyuzLibraryBuildArgv()
    assertMsg(libraryArgv.size() == 2, "library build argv shape")
}

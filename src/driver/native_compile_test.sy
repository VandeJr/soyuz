import (
    { nativeCompileLibraryBuildArgv, nativeCompileLibraryBuildReady, nativeCompileLibraryBuildOutput, argvIsNativeLibraryBuild, standaloneCliNativeLibraryBuildEnabled, nativeCompileHelloMinimalBuildArgv, argvIsNativeLegacyBuild, nativeCompileLegacyBuildOutputFromArgv, nativeCompileLegacyBootstrapEntry, standaloneCliNativeNewEnabled, nativeCompileDemoNewArgv, nativeCompileDemoNewProjectName, argvIsNativeNew, nativeCompileNewOutputFromArgv, standaloneCliNativeTestEnabled, nativeCompileTestRunnerArgv, argvIsNativeTest, nativeCompileTestOutputFromArgv, nativeCompileTestSuccessMarker, standaloneCliNativeRunEnabled, nativeCompileHelloMinimalRunArgv, argvIsNativeRun, nativeCompileRunOutputFromArgv, nativeCompileRunSuccessMarker, nativeCompileMainRebuildArgv, argvIsBootstrapOnlyBuild, nativeCompileBootstrapFakePathMarker } from @driver/native_compile
    { bootstrapVerifyLibraryMarker } from @driver/bootstrap_verify
    { testCliNativeSuccessStubMessage } from @driver/test_cli
    { runCliNativeHelloStubMessage } from @driver/run_cli
    { buildCliLibraryVerifyMessage, buildCliProjectConfigFromRoot, soyuzLibraryProjectIndex, soyuzLibraryProjectRoot, soyuzLibraryProjectVerifyReady } from @driver/project_cli
    { defaultSoyuzLibraryBuildArgv } from @driver/build_cli
    { assertMsg } from @soyuz/testing
)

test fn testNativeCompileLibraryBuild() {
    assertMsg(standaloneCliNativeLibraryBuildEnabled(), "native library build enabled")
    assertMsg(nativeCompileLibraryBuildReady(), "native library build ready")
    val out = nativeCompileLibraryBuildOutput()
    assertMsg(out.contains(bootstrapVerifyLibraryMarker()), "native library verify marker")
    assertMsg(nativeCompileLibraryBuildArgv() == defaultSoyuzLibraryBuildArgv(), "library argv")
    assertMsg(argvIsNativeLibraryBuild(defaultSoyuzLibraryBuildArgv()), "argv detects library build")
    val cfg = buildCliProjectConfigFromRoot(soyuzLibraryProjectRoot(), soyuzLibraryProjectIndex())
    assertMsg(out == buildCliLibraryVerifyMessage(cfg), "native output matches project verify message")
    assertMsg(soyuzLibraryProjectVerifyReady(), "frontend verify ready in test")
}

test fn testNativeCompileLegacyBuild() {
    val helloArgv = nativeCompileHelloMinimalBuildArgv()
    assertMsg(argvIsNativeLegacyBuild(helloArgv), "argv detects hello legacy build")
    val out = nativeCompileLegacyBuildOutputFromArgv(helloArgv)
    assertMsg(out.contains("Build concluído"), "hello legacy success message")
    assertMsg(!argvIsNativeLegacyBuild(defaultSoyuzLibraryBuildArgv()), "library not legacy")

    var mainArgv = List[String]{}
    mainArgv.append("soyuz")
    mainArgv.append("build")
    mainArgv.append(nativeCompileLegacyBootstrapEntry())
    assertMsg(!argvIsNativeLegacyBuild(mainArgv), "main.sy still delegates")
    assertMsg(nativeCompileLegacyBuildOutputFromArgv(mainArgv) == "", "main.sy no native output")
}

test fn testNativeCompileNew() {
    assertMsg(standaloneCliNativeNewEnabled(), "native new enabled")
    val argv = nativeCompileDemoNewArgv()
    assertMsg(argvIsNativeNew(argv), "argv detects new")
    val out = nativeCompileNewOutputFromArgv(argv)
    assertMsg(out.contains(nativeCompileDemoNewProjectName()), "new project name")
    assertMsg(out.contains("criado"), "new success marker")
}

test fn testNativeCompileTest() {
    assertMsg(!standaloneCliNativeTestEnabled(), "native test disabled until it executes tests")
    val argv = nativeCompileTestRunnerArgv()
    assertMsg(argvIsNativeTest(argv), "argv detects test")
    val out = nativeCompileTestOutputFromArgv(argv)
    assertMsg(out == "", "native test must not emit a false success")
}

test fn testNativeCompileRun() {
    assertMsg(standaloneCliNativeRunEnabled(), "native run enabled")
    val argv = nativeCompileHelloMinimalRunArgv()
    assertMsg(argvIsNativeRun(argv), "argv detects run")
    val out = nativeCompileRunOutputFromArgv(argv)
    assertMsg(out == runCliNativeHelloStubMessage(), "native run stub message")
    assertMsg(out.contains(nativeCompileRunSuccessMarker()), "native run success marker")
}

test fn testNativeCompileBootstrapOnlyBuild() {
    val mainArgv = nativeCompileMainRebuildArgv()
    assertMsg(argvIsBootstrapOnlyBuild(mainArgv), "main.sy is bootstrap-only build")
    assertMsg(!argvIsNativeLegacyBuild(mainArgv), "main.sy not native legacy")
    assertMsg(!argvIsNativeLibraryBuild(mainArgv), "main.sy not library build")
    assertMsg(nativeCompileBootstrapFakePathMarker().len() > 0, "fake path marker")
}

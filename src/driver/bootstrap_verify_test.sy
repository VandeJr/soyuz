import (
    { bootstrapVerifyLibraryMarker, bootstrapVerifyLibraryStepName, bootstrapVerifyTestMarker, bootstrapVerifyTestStepName, bootstrapVerifyHelloFixturePath, bootstrapVerifyHelloOutput, bootstrapVerifyHelloStepName, bootstrapVerifyHelloIrCStringMarker, bootstrapVerifyHelloIrPrintfMarker, bootstrapVerifyHelloIrMainMarker, bootstrapVerifyHelloIrRetMarker, bootstrapVerifyHelloIrStepName, bootstrapVerifyHelloIrDebugPath, bootstrapVerifyHelloLinkStepName, bootstrapVerifySelfRebuildEntry, bootstrapVerifySelfRebuildUsageMarker, bootstrapVerifySelfRebuildSuccessMarker, bootstrapVerifySelfRebuildStepName, bootstrapVerifyVn1StepName, bootstrapVerifyVn2StepName, bootstrapVerifyVn2FixedPointStepName, bootstrapVerifyGenerationCount, bootstrapVerifyBinarySizeStepName, bootstrapVerifyElfTextSection, bootstrapVerifyElfRodataSection, bootstrapVerifyElfDataSection, bootstrapVerifyElfBssSection, bootstrapVerifyElfSectionStepName, bootstrapVerifyMainSymbol, bootstrapVerifySymbolStepName, bootstrapVerifyDataSectionStepName, bootstrapVerifyMainEntryPath, bootstrapVerifyCliExecSymbol, bootstrapVerifyBootstrapDelegateMarker, bootstrapVerifyBootstrapDelegateStepName, bootstrapVerifyBootstrapBuildCommandMarker, bootstrapVerifyBootstrapTestCommandMarker, bootstrapVerifyBootstrapRunCommandMarker, bootstrapVerifyBootstrapCommandStepName, bootstrapVerifyNativeCompileStepName, defaultBootstrapVerifyScript, bootstrapVerifyLibraryStepReady, bootstrapVerifyTestStepReady, bootstrapVerifyHelloStepReady, bootstrapVerifyHelloIrStepReady, bootstrapVerifyHelloLinkStepReady, bootstrapVerifySelfRebuildStepReady, bootstrapVerifyVn1StepReady, bootstrapVerifyVn2StepReady, bootstrapVerifyVn2FixedPointStepReady, bootstrapVerifyBinarySizeStepReady, bootstrapVerifyElfSectionStepReady, bootstrapVerifySymbolStepReady, bootstrapVerifyDataSectionStepReady, bootstrapVerifyBootstrapDelegateStepReady, bootstrapVerifyBootstrapCommandStepReady, bootstrapVerifyNativeCompileStepReady } from @driver/bootstrap_verify
    { buildCliLibraryVerifyStubMessage, buildCliLegacySuccessMessage, buildCliLegacyPlanFromArgs, buildCliProjectBootstrapCommand, defaultSoyuzLibraryBuildArgv } from @driver/build_cli
    { cliUsageHeader } from @driver/cli_usage
    { testRunnerBootstrapSuccessMarker, defaultTestRunnerBootstrapCommand } from @driver/test_runner_gate
    { defaultBootstrapHelloRunCommand } from @driver/cli
    { helloMinimalFixturePath, helloCodegenIrContent } from @driver/export
    { defaultDriverBootstrapVerifyScript, defaultExportDriverHelloIrScript, defaultDriverExportCodegenIrCheckScript } from @driver/build
    { defaultRunLinkScript } from @runtime/link
    { assertMsg } from @soyuz/testing
)

test fn testBootstrapVerifyMetadata() {
    assertMsg(bootstrapVerifyLibraryStepReady(), "library step metadata ready")
    assertMsg(buildCliLibraryVerifyStubMessage().contains(bootstrapVerifyLibraryMarker()), "stub matches marker")
    assertMsg(defaultBootstrapVerifyScript() == defaultDriverBootstrapVerifyScript(), "script path")
    assertMsg(bootstrapVerifyLibraryStepName().contains("fixed-point"), "library step name")
    assertMsg(bootstrapVerifyTestStepReady(), "test step metadata ready")
    assertMsg(testRunnerBootstrapSuccessMarker() == bootstrapVerifyTestMarker(), "test marker matches gate")
    assertMsg(defaultTestRunnerBootstrapCommand().contains("test_runner.sy"), "bootstrap test command")
    assertMsg(bootstrapVerifyTestStepName().contains("fixed-point"), "test step name")
    assertMsg(bootstrapVerifyHelloStepReady(), "hello step metadata ready")
    assertMsg(bootstrapVerifyHelloFixturePath() == helloMinimalFixturePath(), "hello fixture path")
    assertMsg(defaultBootstrapHelloRunCommand().contains(bootstrapVerifyHelloFixturePath()), "bootstrap run command")
    assertMsg(bootstrapVerifyHelloStepName().contains("fixed-point"), "hello step name")
    assertMsg(bootstrapVerifyHelloOutput() == "hello", "hello output marker")
    assertMsg(bootstrapVerifyHelloIrStepReady(), "hello ir step metadata ready")
    assertMsg(defaultExportDriverHelloIrScript().contains("export-driver-hello-ir"), "export hello ir script")
    assertMsg(bootstrapVerifyHelloIrStepName().contains("IR"), "hello ir step name")
    val ir = helloCodegenIrContent()
    assertMsg(ir.contains(bootstrapVerifyHelloIrCStringMarker()), "soyuz codegen ir cstring marker")
    assertMsg(ir.contains(bootstrapVerifyHelloIrPrintfMarker()), "soyuz codegen ir printf marker")
    assertMsg(ir.contains(bootstrapVerifyHelloIrMainMarker()), "soyuz codegen ir main marker")
    assertMsg(ir.contains(bootstrapVerifyHelloIrRetMarker()), "soyuz codegen ir ret marker")
    assertMsg(bootstrapVerifyHelloIrDebugPath().contains("soyuz_debug"), "bootstrap ir debug path")
    assertMsg(bootstrapVerifyHelloLinkStepReady(), "hello link step metadata ready")
    assertMsg(bootstrapVerifyHelloLinkStepName().contains("link"), "hello link step name")
    assertMsg(defaultRunLinkScript().contains("runtime-run-link"), "run link script")
    assertMsg(defaultDriverExportCodegenIrCheckScript().contains("export-codegen-ir"), "export codegen ir gate script")
    assertMsg(bootstrapVerifySelfRebuildStepReady(), "self rebuild step metadata ready")
    assertMsg(bootstrapVerifySelfRebuildStepName().contains("vN"), "self rebuild step name")
    assertMsg(cliUsageHeader().contains(bootstrapVerifySelfRebuildUsageMarker()), "usage marker")
    var mainArgs = List[String]{}
    mainArgs.append(bootstrapVerifySelfRebuildEntry())
    val mainPlan = buildCliLegacyPlanFromArgs(mainArgs)
    assertMsg(buildCliLegacySuccessMessage(mainPlan).contains(bootstrapVerifySelfRebuildSuccessMarker()), "rebuild success marker")
    assertMsg(bootstrapVerifyLibraryMarker().len() > 0, "library marker for vN+1 check")
    assertMsg(bootstrapVerifyVn1StepReady(), "vN+1 step metadata ready")
    assertMsg(bootstrapVerifyVn1StepName().contains("vN+1"), "vN+1 step name")
    assertMsg(bootstrapVerifyTestMarker().len() > 0, "test marker for vN+1 check")
    assertMsg(bootstrapVerifyHelloOutput().len() > 0, "hello marker for vN+1 check")
    assertMsg(bootstrapVerifyVn2StepReady(), "vN+2 step metadata ready")
    assertMsg(bootstrapVerifyVn2StepName().contains("vN+2"), "vN+2 step name")
    assertMsg(bootstrapVerifyVn2FixedPointStepReady(), "vN+2 fixed-point step metadata ready")
    assertMsg(bootstrapVerifyVn2FixedPointStepName().contains("fixed-point"), "vN+2 fixed-point step name")
    assertMsg(bootstrapVerifyBinarySizeStepReady(), "binary size step metadata ready")
    assertMsg(bootstrapVerifyBinarySizeStepName().contains("binary"), "binary size step name")
    assertMsg(bootstrapVerifyGenerationCount() == 3, "generation chain depth")
    assertMsg(bootstrapVerifyElfSectionStepReady(), "elf section step metadata ready")
    assertMsg(bootstrapVerifyElfSectionStepName().contains("ELF"), "elf section step name")
    assertMsg(bootstrapVerifyElfTextSection() == ".text", "elf text section")
    assertMsg(bootstrapVerifyElfRodataSection() == ".rodata", "elf rodata section")
    assertMsg(bootstrapVerifySymbolStepReady(), "symbol step metadata ready")
    assertMsg(bootstrapVerifySymbolStepName().contains("symbol"), "symbol step name")
    assertMsg(bootstrapVerifyMainSymbol() == "main", "main symbol marker")
    assertMsg(bootstrapVerifyDataSectionStepReady(), "data section step metadata ready")
    assertMsg(bootstrapVerifyDataSectionStepName().contains(".data"), "data section step name")
    assertMsg(bootstrapVerifyBootstrapDelegateStepReady(), "bootstrap delegate step metadata ready")
    assertMsg(bootstrapVerifyBootstrapDelegateStepName().contains("delegation"), "bootstrap delegate step name")
    assertMsg(bootstrapVerifyMainEntryPath() == "main.sy", "main entry path")
    assertMsg(bootstrapVerifyCliExecSymbol() == "soyuz_os_exec", "cli exec symbol")
    assertMsg(bootstrapVerifyBootstrapDelegateMarker() == "cliOsExecShell", "bootstrap delegate marker")
    assertMsg(bootstrapVerifyBootstrapCommandStepReady(), "bootstrap command step metadata ready")
    assertMsg(bootstrapVerifyBootstrapCommandStepName().contains("command"), "bootstrap command step name")
    assertMsg(buildCliProjectBootstrapCommand(defaultSoyuzLibraryBuildArgv()) == bootstrapVerifyBootstrapBuildCommandMarker(), "library bootstrap marker")
    assertMsg(defaultTestRunnerBootstrapCommand().contains(bootstrapVerifyBootstrapTestCommandMarker()), "test bootstrap marker")
    assertMsg(defaultBootstrapHelloRunCommand().contains(bootstrapVerifyBootstrapRunCommandMarker()), "run bootstrap marker")
    assertMsg(!bootstrapVerifyNativeCompileStepReady(), "native compile not ready yet")
    assertMsg(bootstrapVerifyNativeCompileStepName().contains("native"), "native compile step name")
}

import (
    { bootstrapVerifyLibraryMarker, bootstrapVerifyLibraryStepName, bootstrapVerifyTestMarker, bootstrapVerifyTestStepName, bootstrapVerifyHelloFixturePath, bootstrapVerifyHelloOutput, bootstrapVerifyHelloStepName, bootstrapVerifyHelloIrCStringMarker, bootstrapVerifyHelloIrPrintfMarker, bootstrapVerifyHelloIrMainMarker, bootstrapVerifyHelloIrRetMarker, bootstrapVerifyHelloIrStepName, bootstrapVerifyHelloIrDebugPath, bootstrapVerifyHelloLinkStepName, bootstrapVerifySelfRebuildEntry, bootstrapVerifySelfRebuildUsageMarker, bootstrapVerifySelfRebuildSuccessMarker, bootstrapVerifySelfRebuildStepName, bootstrapVerifyVn1StepName, bootstrapVerifyVn2StepName, bootstrapVerifyVn2FixedPointStepName, bootstrapVerifyGenerationCount, bootstrapVerifyBinarySizeStepName, bootstrapVerifyElfTextSection, bootstrapVerifyElfRodataSection, bootstrapVerifyElfDataSection, bootstrapVerifyElfBssSection, bootstrapVerifyElfSectionStepName, bootstrapVerifyMainSymbol, bootstrapVerifySymbolStepName, bootstrapVerifyDataSectionStepName, bootstrapVerifyMainEntryPath, bootstrapVerifyCliExecSymbol, bootstrapVerifyBootstrapDelegateMarker, bootstrapVerifyBootstrapDelegateStepName, bootstrapVerifyBootstrapBuildCommandMarker, bootstrapVerifyBootstrapTestCommandMarker, bootstrapVerifyBootstrapRunCommandMarker, bootstrapVerifyBootstrapCommandStepName, bootstrapVerifyNativeCompileStepName, bootstrapVerifyNativeLibraryBuildStepName, defaultBootstrapVerifyScript, bootstrapVerifyLibraryStepReady, bootstrapVerifyTestStepReady, bootstrapVerifyHelloStepReady, bootstrapVerifyHelloIrStepReady, bootstrapVerifyHelloLinkStepReady, bootstrapVerifySelfRebuildStepReady, bootstrapVerifyVn1StepReady, bootstrapVerifyVn2StepReady, bootstrapVerifyVn2FixedPointStepReady, bootstrapVerifyBinarySizeStepReady, bootstrapVerifyElfSectionStepReady, bootstrapVerifySymbolStepReady, bootstrapVerifyDataSectionStepReady, bootstrapVerifyBootstrapDelegateStepReady, bootstrapVerifyBootstrapCommandStepReady, bootstrapVerifyNativeCompileStepReady, bootstrapVerifyNativeLibraryBuildStepReady, bootstrapVerifyNativeLegacyBuildStepName, bootstrapVerifyNativeLegacyBuildStepReady, bootstrapVerifyNativeLegacyBuildSuccessMarker, bootstrapVerifyNativeNewStepName, bootstrapVerifyNativeNewStepReady, bootstrapVerifyNativeNewSuccessMarker, bootstrapVerifyNativeTestStepName, bootstrapVerifyNativeTestStepReady, bootstrapVerifyNativeRunStepName, bootstrapVerifyNativeRunStepReady, bootstrapVerifyBootstrapOnlyBuildStepName, bootstrapVerifyBootstrapOnlyBuildStepReady, bootstrapVerifyBootstrapFakePathMarker, bootstrapVerifyNativeMainBuildPlanStepName, bootstrapVerifyNativeMainBuildPlanStepReady, bootstrapVerifyNativeMainThinGraphStepName, bootstrapVerifyNativeMainThinGraphStepReady, bootstrapVerifyNativeMainCliArgvStepName, bootstrapVerifyNativeMainCliArgvStepReady, bootstrapVerifyNativeMainCliMainExecStepName, bootstrapVerifyNativeMainCliMainExecStepReady, bootstrapVerifyNativeMainCliUsageStepName, bootstrapVerifyNativeMainCliUsageStepReady, bootstrapVerifyNativeMainBuildCliStepName, bootstrapVerifyNativeMainBuildCliStepReady, bootstrapVerifyNativeMainStandaloneLegacyBuildStepName, bootstrapVerifyNativeMainStandaloneLegacyBuildStepReady } from @driver/bootstrap_verify
    { buildCliLibraryVerifyStubMessage, buildCliLegacySuccessMessage, buildCliLegacyPlanFromArgs, buildCliProjectBootstrapCommand, defaultSoyuzLibraryBuildArgv } from @driver/build_cli
    { cliUsageHeader } from @driver/cli_usage
    { testRunnerBootstrapSuccessMarker, defaultTestRunnerBootstrapCommand } from @driver/test_runner_gate
    { nativeCompileLibraryBuildOutput, nativeCompileLibraryBuildReady, argvIsNativeLegacyBuild, nativeCompileLegacyBuildOutputFromArgv, nativeCompileHelloMinimalBuildArgv, argvIsNativeNew, nativeCompileNewOutputFromArgv, nativeCompileDemoNewArgv, argvIsNativeTest, nativeCompileTestOutputFromArgv, nativeCompileTestRunnerArgv, argvIsNativeRun, nativeCompileRunOutputFromArgv, nativeCompileHelloMinimalRunArgv, argvIsBootstrapOnlyBuild, nativeCompileMainRebuildArgv, nativeCompileBootstrapFakePathMarker, nativeCompileMainBuildReady, standaloneCliNativeMainBuildEnabled } from @driver/native_compile
    { mainStandaloneFullBuildPlanReady, mainStandaloneThinGraphPlanReady, mainStandaloneThinGraphIrReady, mainStandaloneThinCliArgvPlanReady, mainStandaloneThinCliArgvIsRealSource, mainStandaloneThinCliMainExecPlanReady, mainStandaloneThinCliMainExecIsRealSource, mainStandaloneThinCliUsagePlanReady, mainStandaloneThinCliUsageIsRealSource, mainStandaloneThinBuildCliPlanReady, mainStandaloneThinBuildCliIsRealSource, mainStandaloneThinMainStandaloneLibraryBuildReady, mainStandaloneThinMainStandaloneLegacyBuildReady } from @driver/main_build
    { defaultBootstrapHelloRunCommand } from @driver/cli
    { helloMinimalFixturePath, helloCodegenIrContent } from @driver/export
    { defaultDriverBootstrapVerifyScript, defaultExportDriverHelloIrScript, defaultDriverExportCodegenIrCheckScript } from @driver/build
    { defaultRunLinkScript } from @runtime/link
    { assertMsg } from @soyuz/testing
)

test fn testBootstrapVerifyMetadata() {
    assertMsg(bootstrapVerifyLibraryStepReady(), "library step metadata ready")
    assertMsg(buildCliLibraryVerifyStubMessage().contains(bootstrapVerifyLibraryMarker()), "stub matches marker")
    assertMsg(defaultBootstrapVerifyScript() == defaultDriverBootstrapVerifyScript(), "script path")
    assertMsg(bootstrapVerifyLibraryStepName().contains("fixed-point"), "library step name")
    assertMsg(bootstrapVerifyTestStepReady(), "test step metadata ready")
    assertMsg(testRunnerBootstrapSuccessMarker() == bootstrapVerifyTestMarker(), "test marker matches gate")
    assertMsg(defaultTestRunnerBootstrapCommand().contains("test_runner.sy"), "bootstrap test command")
    assertMsg(bootstrapVerifyTestStepName().contains("fixed-point"), "test step name")
    assertMsg(bootstrapVerifyHelloStepReady(), "hello step metadata ready")
    assertMsg(bootstrapVerifyHelloFixturePath() == helloMinimalFixturePath(), "hello fixture path")
    assertMsg(defaultBootstrapHelloRunCommand().contains(bootstrapVerifyHelloFixturePath()), "bootstrap run command")
    assertMsg(bootstrapVerifyHelloStepName().contains("fixed-point"), "hello step name")
    assertMsg(bootstrapVerifyHelloOutput() == "hello", "hello output marker")
    assertMsg(bootstrapVerifyHelloIrStepReady(), "hello ir step metadata ready")
    assertMsg(defaultExportDriverHelloIrScript().contains("export-driver-hello-ir"), "export hello ir script")
    assertMsg(bootstrapVerifyHelloIrStepName().contains("IR"), "hello ir step name")
    val ir = helloCodegenIrContent()
    assertMsg(ir.contains(bootstrapVerifyHelloIrCStringMarker()), "soyuz codegen ir cstring marker")
    assertMsg(ir.contains(bootstrapVerifyHelloIrPrintfMarker()), "soyuz codegen ir printf marker")
    assertMsg(ir.contains(bootstrapVerifyHelloIrMainMarker()), "soyuz codegen ir main marker")
    assertMsg(ir.contains(bootstrapVerifyHelloIrRetMarker()), "soyuz codegen ir ret marker")
    assertMsg(bootstrapVerifyHelloIrDebugPath().contains("soyuz_debug"), "bootstrap ir debug path")
    assertMsg(bootstrapVerifyHelloLinkStepReady(), "hello link step metadata ready")
    assertMsg(bootstrapVerifyHelloLinkStepName().contains("link"), "hello link step name")
    assertMsg(defaultRunLinkScript().contains("runtime-run-link"), "run link script")
    assertMsg(defaultDriverExportCodegenIrCheckScript().contains("export-codegen-ir"), "export codegen ir gate script")
    assertMsg(bootstrapVerifySelfRebuildStepReady(), "self rebuild step metadata ready")
    assertMsg(bootstrapVerifySelfRebuildStepName().contains("vN"), "self rebuild step name")
    assertMsg(cliUsageHeader().contains(bootstrapVerifySelfRebuildUsageMarker()), "usage marker")
    var mainArgs = List[String]{}
    mainArgs.append(bootstrapVerifySelfRebuildEntry())
    val mainPlan = buildCliLegacyPlanFromArgs(mainArgs)
    assertMsg(buildCliLegacySuccessMessage(mainPlan).contains(bootstrapVerifySelfRebuildSuccessMarker()), "rebuild success marker")
    assertMsg(bootstrapVerifyLibraryMarker().len() > 0, "library marker for vN+1 check")
    assertMsg(bootstrapVerifyVn1StepReady(), "vN+1 step metadata ready")
    assertMsg(bootstrapVerifyVn1StepName().contains("vN+1"), "vN+1 step name")
    assertMsg(bootstrapVerifyTestMarker().len() > 0, "test marker for vN+1 check")
    assertMsg(bootstrapVerifyHelloOutput().len() > 0, "hello marker for vN+1 check")
    assertMsg(bootstrapVerifyVn2StepReady(), "vN+2 step metadata ready")
    assertMsg(bootstrapVerifyVn2StepName().contains("vN+2"), "vN+2 step name")
    assertMsg(bootstrapVerifyVn2FixedPointStepReady(), "vN+2 fixed-point step metadata ready")
    assertMsg(bootstrapVerifyVn2FixedPointStepName().contains("fixed-point"), "vN+2 fixed-point step name")
    assertMsg(bootstrapVerifyBinarySizeStepReady(), "binary size step metadata ready")
    assertMsg(bootstrapVerifyBinarySizeStepName().contains("binary"), "binary size step name")
    assertMsg(bootstrapVerifyGenerationCount() == 3, "generation chain depth")
    assertMsg(bootstrapVerifyElfSectionStepReady(), "elf section step metadata ready")
    assertMsg(bootstrapVerifyElfSectionStepName().contains("ELF"), "elf section step name")
    assertMsg(bootstrapVerifyElfTextSection() == ".text", "elf text section")
    assertMsg(bootstrapVerifyElfRodataSection() == ".rodata", "elf rodata section")
    assertMsg(bootstrapVerifySymbolStepReady(), "symbol step metadata ready")
    assertMsg(bootstrapVerifySymbolStepName().contains("symbol"), "symbol step name")
    assertMsg(bootstrapVerifyMainSymbol() == "main", "main symbol marker")
    assertMsg(bootstrapVerifyDataSectionStepReady(), "data section step metadata ready")
    assertMsg(bootstrapVerifyDataSectionStepName().contains(".data"), "data section step name")
    assertMsg(bootstrapVerifyBootstrapDelegateStepReady(), "bootstrap delegate step metadata ready")
    assertMsg(bootstrapVerifyBootstrapDelegateStepName().contains("delegation"), "bootstrap delegate step name")
    assertMsg(bootstrapVerifyMainEntryPath() == "main.sy", "main entry path")
    assertMsg(bootstrapVerifyCliExecSymbol() == "soyuz_os_exec", "cli exec symbol")
    assertMsg(bootstrapVerifyBootstrapDelegateMarker() == "cliOsExecShell", "bootstrap delegate marker")
    assertMsg(bootstrapVerifyBootstrapCommandStepReady(), "bootstrap command step metadata ready")
    assertMsg(bootstrapVerifyBootstrapCommandStepName().contains("command"), "bootstrap command step name")
    assertMsg(buildCliProjectBootstrapCommand(defaultSoyuzLibraryBuildArgv()) == bootstrapVerifyBootstrapBuildCommandMarker(), "library bootstrap marker")
    assertMsg(defaultTestRunnerBootstrapCommand().contains(bootstrapVerifyBootstrapTestCommandMarker()), "test bootstrap marker")
    assertMsg(defaultBootstrapHelloRunCommand().contains(bootstrapVerifyBootstrapRunCommandMarker()), "run bootstrap marker")
    assertMsg(!bootstrapVerifyNativeCompileStepReady(), "native compile not ready yet")
    assertMsg(bootstrapVerifyNativeCompileStepName().contains("native"), "native compile step name")
    assertMsg(bootstrapVerifyNativeLibraryBuildStepReady(), "native library build step metadata ready")
    assertMsg(bootstrapVerifyNativeLibraryBuildStepName().contains("library"), "native library build step name")
    assertMsg(nativeCompileLibraryBuildReady(), "native library verify ready")
    assertMsg(nativeCompileLibraryBuildOutput().contains(bootstrapVerifyLibraryMarker()), "native library output marker")
    assertMsg(bootstrapVerifyNativeLegacyBuildStepReady(), "native legacy build step metadata ready")
    assertMsg(bootstrapVerifyNativeLegacyBuildStepName().contains("legacy"), "native legacy build step name")
    assertMsg(argvIsNativeLegacyBuild(nativeCompileHelloMinimalBuildArgv()), "hello fixture native legacy")
    assertMsg(nativeCompileLegacyBuildOutputFromArgv(nativeCompileHelloMinimalBuildArgv()).contains(bootstrapVerifyNativeLegacyBuildSuccessMarker()), "hello native legacy marker")
    assertMsg(bootstrapVerifyNativeNewStepReady(), "native new step metadata ready")
    assertMsg(bootstrapVerifyNativeNewStepName().contains("new"), "native new step name")
    assertMsg(argvIsNativeNew(nativeCompileDemoNewArgv()), "demo new argv native")
    assertMsg(nativeCompileNewOutputFromArgv(nativeCompileDemoNewArgv()).contains(bootstrapVerifyNativeNewSuccessMarker()), "demo new marker")
    assertMsg(bootstrapVerifyNativeTestStepReady(), "native test step metadata ready")
    assertMsg(bootstrapVerifyNativeTestStepName().contains("test"), "native test step name")
    assertMsg(argvIsNativeTest(nativeCompileTestRunnerArgv()), "test runner argv native")
    assertMsg(nativeCompileTestOutputFromArgv(nativeCompileTestRunnerArgv()).contains(bootstrapVerifyTestMarker()), "test runner native marker")
    assertMsg(bootstrapVerifyNativeRunStepReady(), "native run step metadata ready")
    assertMsg(bootstrapVerifyNativeRunStepName().contains("run"), "native run step name")
    assertMsg(argvIsNativeRun(nativeCompileHelloMinimalRunArgv()), "hello run argv native")
    assertMsg(nativeCompileRunOutputFromArgv(nativeCompileHelloMinimalRunArgv()).contains(bootstrapVerifyHelloOutput()), "hello run native marker")
    assertMsg(bootstrapVerifyBootstrapOnlyBuildStepReady(), "bootstrap-only build step metadata ready")
    assertMsg(bootstrapVerifyBootstrapOnlyBuildStepName().contains("main.sy"), "bootstrap-only build step name")
    assertMsg(argvIsBootstrapOnlyBuild(nativeCompileMainRebuildArgv()), "main rebuild bootstrap-only")
    assertMsg(bootstrapVerifyBootstrapFakePathMarker() == nativeCompileBootstrapFakePathMarker(), "fake path marker")
    assertMsg(bootstrapVerifyNativeMainBuildPlanStepReady(), "native main build plan step metadata ready")
    assertMsg(bootstrapVerifyNativeMainBuildPlanStepName().contains("plan"), "native main build plan step name")
    assertMsg(mainStandaloneFullBuildPlanReady(), "main standalone full build plan ready")
    assertMsg(!standaloneCliNativeMainBuildEnabled(), "native main build cli disabled")
    assertMsg(!nativeCompileMainBuildReady(), "native main build not ready")
    assertMsg(bootstrapVerifyNativeMainThinGraphStepReady(), "native thin graph step metadata ready")
    assertMsg(bootstrapVerifyNativeMainThinGraphStepName().contains("thin"), "native thin graph step name")
    assertMsg(mainStandaloneThinGraphPlanReady(), "main thin graph plan ready")
    assertMsg(mainStandaloneThinGraphIrReady(), "main thin graph IR exec symbol")
    assertMsg(bootstrapVerifyNativeMainCliArgvStepReady(), "native cli_argv step metadata ready")
    assertMsg(bootstrapVerifyNativeMainCliArgvStepName().contains("cli_argv"), "native cli_argv step name")
    assertMsg(mainStandaloneThinCliArgvIsRealSource(), "real cli_argv source in plan")
    assertMsg(mainStandaloneThinCliArgvPlanReady(), "real cli_argv plan ready")
    assertMsg(bootstrapVerifyNativeMainCliMainExecStepReady(), "native cli_main_exec step metadata ready")
    assertMsg(bootstrapVerifyNativeMainCliMainExecStepName().contains("cli_main_exec"), "native cli_main_exec step name")
    assertMsg(mainStandaloneThinCliMainExecIsRealSource(), "real cli_main_exec source in plan")
    assertMsg(mainStandaloneThinCliMainExecPlanReady(), "real cli_main_exec plan ready")
    assertMsg(bootstrapVerifyNativeMainCliUsageStepReady(), "native cli_usage step metadata ready")
    assertMsg(bootstrapVerifyNativeMainCliUsageStepName().contains("cli_usage"), "native cli_usage step name")
    assertMsg(mainStandaloneThinCliUsageIsRealSource(), "real cli_usage source in plan")
    assertMsg(mainStandaloneThinCliUsagePlanReady(), "real cli_usage plan ready")
    assertMsg(bootstrapVerifyNativeMainBuildCliStepReady(), "native build_cli step metadata ready")
    assertMsg(bootstrapVerifyNativeMainBuildCliStepName().contains("build_cli"), "native build_cli step name")
    assertMsg(mainStandaloneThinBuildCliIsRealSource(), "real build_cli source in plan")
    assertMsg(mainStandaloneThinBuildCliPlanReady(), "real build_cli plan ready")
    assertMsg(mainStandaloneThinMainStandaloneLibraryBuildReady(), "main_standalone library build path")
    assertMsg(bootstrapVerifyNativeMainStandaloneLegacyBuildStepReady(), "native main_standalone legacy build step metadata ready")
    assertMsg(bootstrapVerifyNativeMainStandaloneLegacyBuildStepName().contains("legacy"), "native main_standalone legacy build step name")
    assertMsg(mainStandaloneThinMainStandaloneLegacyBuildReady(), "main_standalone legacy build path in plan")
}

import (
    { bootstrapVerifyLibraryMarker, bootstrapVerifyLibraryStepName, bootstrapVerifyTestMarker, bootstrapVerifyTestStepName, bootstrapVerifyHelloFixturePath, bootstrapVerifyHelloOutput, bootstrapVerifyHelloStepName, defaultBootstrapVerifyScript, bootstrapVerifyLibraryStepReady, bootstrapVerifyTestStepReady, bootstrapVerifyHelloStepReady } from @driver/bootstrap_verify
    { buildCliLibraryVerifyStubMessage } from @driver/build_cli
    { testRunnerBootstrapSuccessMarker, defaultTestRunnerBootstrapCommand } from @driver/test_runner_gate
    { defaultBootstrapHelloRunCommand } from @driver/cli
    { helloMinimalFixturePath } from @driver/export
    { defaultDriverBootstrapVerifyScript } from @driver/build
    { assertMsg } from @soyuz/testing
)

test fn testBootstrapVerifyMetadata() {
    assertMsg(bootstrapVerifyLibraryStepReady(), "library step metadata ready")
    assertMsg(buildCliLibraryVerifyStubMessage().contains(bootstrapVerifyLibraryMarker()), "stub matches marker")
    assertMsg(defaultBootstrapVerifyScript() == defaultDriverBootstrapVerifyScript(), "script path")
    assertMsg(bootstrapVerifyLibraryStepName().contains("fixed-point"), "library step name")
    assertMsg(bootstrapVerifyTestStepReady(), "test step metadata ready")
    assertMsg(testRunnerBootstrapSuccessMarker() == bootstrapVerifyTestMarker(), "test marker matches gate")
    assertMsg(defaultTestRunnerBootstrapCommand().contains("test_runner.sy"), "bootstrap test command")
    assertMsg(bootstrapVerifyTestStepName().contains("fixed-point"), "test step name")
    assertMsg(bootstrapVerifyHelloStepReady(), "hello step metadata ready")
    assertMsg(bootstrapVerifyHelloFixturePath() == helloMinimalFixturePath(), "hello fixture path")
    assertMsg(defaultBootstrapHelloRunCommand().contains(bootstrapVerifyHelloFixturePath()), "bootstrap run command")
    assertMsg(bootstrapVerifyHelloStepName().contains("fixed-point"), "hello step name")
    assertMsg(bootstrapVerifyHelloOutput() == "hello", "hello output marker")
}

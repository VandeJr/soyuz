import (
    { runStandaloneCli, standaloneCliShouldTryExec, standaloneCliUsageReady, standaloneCliNewReady, standaloneCliBuildReady, standaloneCliTestReady, standaloneCliRunReady, standaloneCliLibraryBuildReady } from @driver/main_standalone
    { cliTryExecOutput, cliOutputIsError } from @driver/cli_exec
    { cliProgramArgv, defaultCliProgramArgv } from @driver/cli_argv
    { cliUsageHeader } from @driver/cli_usage
    { testCliDefaultTmpBinPath } from @driver/test_cli
    { assertMsg } from @soyuz/testing
)

fn testStandaloneCliUsage() {
    assertMsg(standaloneCliUsageReady(), "standalone usage ready")
    assertMsg(runStandaloneCli(defaultCliProgramArgv()).contains(cliUsageHeader()), "default argv prints usage")
}

fn testStandaloneCliNew() {
    assertMsg(standaloneCliNewReady(), "standalone new plan message")
}

fn testStandaloneCliBuild() {
    assertMsg(standaloneCliBuildReady(), "standalone build legacy message")
}

fn testStandaloneCliTest() {
    assertMsg(standaloneCliTestReady(), "standalone test exec path")
}

fn testStandaloneCliRun() {
    assertMsg(standaloneCliRunReady(), "standalone run exec path")
}

fn testStandaloneCliLibraryBuild() {
    assertMsg(standaloneCliLibraryBuildReady(), "standalone library build message")
}

fn testStandaloneCliExecStub() {
    val out = cliTryExecOutput(testCliDefaultTmpBinPath())
    assertMsg(cliOutputIsError(out), "library exec stub returns error")
    assertMsg(out.contains(testCliDefaultTmpBinPath()), "stub mentions path")
}

fn testStandaloneCliShouldTryExec() {
    var testArgv = List[String]{}
    testArgv.append("soyuz")
    testArgv.append("test")
    assertMsg(standaloneCliShouldTryExec(testArgv), "test should try exec")
    var buildArgv = List[String]{}
    buildArgv.append("soyuz")
    buildArgv.append("build")
    assertMsg(!standaloneCliShouldTryExec(buildArgv), "build should not try exec")
}

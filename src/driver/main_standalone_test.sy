import (
    { runStandaloneCli, standaloneCliBootstrapShellCommand, standaloneCliBootstrapBuildCommand, standaloneCliBootstrapTestCommand, standaloneCliBootstrapRunCommand, standaloneCliShouldDelegateBuild, standaloneCliUsageReady, standaloneCliNewReady, standaloneCliBuildReady, standaloneCliTestReady, standaloneCliRunReady, standaloneCliLibraryBuildReady } from @driver/main_standalone
    { cliTryExecOutput, cliOutputIsError } from @driver/cli_exec
    { cliProgramArgv, defaultCliProgramArgv } from @driver/cli_argv
    { cliUsageHeader } from @driver/cli_usage
    { testCliDefaultTmpBinPath } from @driver/test_cli
    { defaultSoyuzLibraryBuildArgv } from @driver/build_cli
    { assertMsg } from @soyuz/testing
)

fn testStandaloneCliUsage() {
    assertMsg(standaloneCliUsageReady(), "standalone usage ready")
    assertMsg(runStandaloneCli(defaultCliProgramArgv()).contains(cliUsageHeader()), "default argv prints usage")
}

fn testStandaloneCliNew() {
    assertMsg(standaloneCliNewReady(), "standalone new plan message")
}

fn testStandaloneCliBuild() {
    assertMsg(standaloneCliBuildReady(), "standalone build legacy message")
}

fn testStandaloneCliTest() {
    assertMsg(standaloneCliTestReady(), "standalone test exec path")
}

fn testStandaloneCliRun() {
    assertMsg(standaloneCliRunReady(), "standalone run exec path")
}

fn testStandaloneCliLibraryBuild() {
    assertMsg(standaloneCliLibraryBuildReady(), "standalone library build message")
}

fn testStandaloneCliExecStub() {
    val out = cliTryExecOutput(testCliDefaultTmpBinPath())
    assertMsg(cliOutputIsError(out), "library exec stub returns error")
    assertMsg(out.contains(testCliDefaultTmpBinPath()), "stub mentions path")
}

fn testStandaloneCliBootstrapShellCommand() {
    var testArgv = List[String]{}
    testArgv.append("soyuz")
    testArgv.append("test")
    testArgv.append("test_runner.sy")
    val testCmd = standaloneCliBootstrapTestCommand(testArgv)
    assertMsg(testCmd.contains("soyuz test"), "bootstrap test command")
    assertMsg(standaloneCliBootstrapShellCommand(testArgv) == testCmd, "shell picks test")

    var runArgv = List[String]{}
    runArgv.append("soyuz")
    runArgv.append("run")
    runArgv.append("tools/fixtures/hello_minimal.sy")
    val runCmd = standaloneCliBootstrapRunCommand(runArgv)
    assertMsg(runCmd.contains("soyuz run"), "bootstrap run command")
    assertMsg(standaloneCliBootstrapShellCommand(runArgv) == runCmd, "shell picks run")
}

fn testStandaloneCliBootstrapBuildDelegate() {
    var argv = List[String]{}
    argv.append("soyuz")
    argv.append("build")
    argv.append("tools/fixtures/hello_minimal.sy")
    assertMsg(standaloneCliShouldDelegateBuild(argv), "legacy build delegates")
    val cmd = standaloneCliBootstrapBuildCommand(argv)
    assertMsg(cmd.contains("soyuz build"), "bootstrap command")
    assertMsg(cmd.contains("hello_minimal"), "bootstrap entry")
    assertMsg(standaloneCliShouldDelegateBuild(defaultSoyuzLibraryBuildArgv()), "library build delegates")
    assertMsg(standaloneCliBootstrapBuildCommand(defaultSoyuzLibraryBuildArgv()) == "soyuz build", "library bootstrap command")
}

import (
    { runStandaloneCli, standaloneCliUsageReady, standaloneCliNewReady } from @driver/main_standalone
    { cliProgramArgv, defaultCliProgramArgv } from @driver/cli_argv
    { cliUsageHeader } from @driver/cli_usage
    { assertMsg } from @soyuz/testing
)

fn testStandaloneCliUsage() {
    assertMsg(standaloneCliUsageReady(), "standalone usage ready")
    assertMsg(runStandaloneCli(defaultCliProgramArgv()).contains(cliUsageHeader()), "default argv prints usage")
}

fn testStandaloneCliNew() {
    assertMsg(standaloneCliNewReady(), "standalone new plan message")
}

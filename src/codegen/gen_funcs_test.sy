import (
    { Node, Pattern, FuncDeclData, FuncParam, LiteralPatternValue, IntLiteralData, ReturnStmtData } from @ast/ast
    { Span } from @lexer/tokens
    { CheckResult, FuncType, Type, IntType, StringType, UnitType } from @checker/types
    { newGenerator } from @codegen/generator
    { mangleSpecializedFuncName, isCatchallPatternForDispatch, funcVariantDispatchPriority, isWhenGuardVariant, sortFuncVariantsForDispatch, variantGuardBlockName, variantBodyBlockName, variantNextBlockName, variantParamPatternOkBlockName, buildFuncVariantPlan, buildFuncVariantPlans, funcVariantsForName, generateFuncVariantsBody, generateFuncDeclNode, generateProgramBody, shouldSkipFuncVariants } from @codegen/gen_funcs
    { llvmI64, llvmTypesEqual } from @codegen/llvm_types
    { assertMsg } from @soyuz/testing
)

fn funcTestCheckResult() -> CheckResult = CheckResult {
    errors: [],
    warnings: [],
    nodeTypes: [],
    specializations: Map[Int, FuncType]{},
    funcVariants: Map[String, List[FuncDeclData]]{},
    testFuncs: [],
    captures: Map[Int, List[String]]{},
    synthCallArgs: Map[Int, List[Node]]{},
    curriedCalls: Map[Int, Node]{},
    typeExtensions: Map[String, Map[String, List[FuncType]]]{}
}

fn funcCheckerWithNodeType(id: Int, t: Type) -> CheckResult {
    var cr = funcTestCheckResult()
    var i = 0
    loop {
        if i > id { break }
        if i == id {
            cr.nodeTypes.append(Some(t))
        } else {
            cr.nodeTypes.append(None)
        }
        i = i + 1
    }
    return cr
}

test fn testMangleSpecializedFuncName() {
    assertMsg(mangleSpecializedFuncName("identity", [IntType]) == "identity__Int", "identity Int")
    assertMsg(mangleSpecializedFuncName("pair", [IntType, StringType]) == "pair__Int__String", "pair Int String")
}

test fn testIsCatchallPatternForDispatch() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 1 }
    assertMsg(isCatchallPatternForDispatch(Pattern.Wildcard(0, span)), "wildcard catchall")
    assertMsg(isCatchallPatternForDispatch(Pattern.Binding(0, span, "x")), "binding catchall")
    assertMsg(!isCatchallPatternForDispatch(Pattern.Literal(0, span, LiteralPatternValue.Int("42"))), "literal not catchall")
}

test fn testFuncVariantDispatchPriority() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 1 }
    val catchall = FuncDeclData {
        namePos: span,
        isPub: false,
        name: "f",
        generics: [],
        params: [FuncParam { span: span, pattern: Pattern.Binding(0, span, "x"), typeExpr: None, defaultExpr: None }],
        whenGuard: None,
        returnType: None,
        body: None,
        isExprBody: false,
        isTest: false,
        isIgnore: false
    }
    assertMsg(funcVariantDispatchPriority(catchall) == 2, "catchall priority 2")
    assertMsg(!isWhenGuardVariant(catchall), "no when guard")
}

test fn testFuncVariantLiteralPatternPriority() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 1 }
    val specific = FuncDeclData {
        namePos: span,
        isPub: false,
        name: "f",
        generics: [],
        params: [FuncParam { span: span, pattern: Pattern.Literal(0, span, LiteralPatternValue.Int("42")), typeExpr: None, defaultExpr: None }],
        whenGuard: None,
        returnType: None,
        body: None,
        isExprBody: false,
        isTest: false,
        isIgnore: false
    }
    assertMsg(funcVariantDispatchPriority(specific) == 1, "literal pattern priority 1")
}

test fn testFuncVariantWhenGuardPriority() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 1 }
    val guardCond = Node.IntLiteral(10, span, IntLiteralData { value: "1" })
    val guarded = FuncDeclData {
        namePos: span,
        isPub: false,
        name: "f",
        generics: [],
        params: [FuncParam { span: span, pattern: Pattern.Binding(0, span, "x"), typeExpr: None, defaultExpr: None }],
        whenGuard: Some(guardCond),
        returnType: None,
        body: None,
        isExprBody: false,
        isTest: false,
        isIgnore: false
    }
    assertMsg(funcVariantDispatchPriority(guarded) == 0, "when guard priority 0")
    assertMsg(isWhenGuardVariant(guarded), "has when guard")
}

fn makePickVariant(span: Span, whenGuard: Option[Node]) -> FuncDeclData {
    return FuncDeclData {
        namePos: span,
        isPub: false,
        name: "pick",
        generics: [],
        params: [FuncParam { span: span, pattern: Pattern.Binding(0, span, "x"), typeExpr: None, defaultExpr: None }],
        whenGuard: whenGuard,
        returnType: None,
        body: None,
        isExprBody: false,
        isTest: false,
        isIgnore: false
    }
}

test fn testSortFuncVariantsWhenGuardBeforeCatchall() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 1 }
    val guardCond = Node.IntLiteral(10, span, IntLiteralData { value: "1" })
    val catchall = makePickVariant(span, None)
    val guarded = makePickVariant(span, Some(guardCond))
    val sorted = sortFuncVariantsForDispatch([catchall, guarded])
    assertMsg(sorted.size() == 2, "two variants")
    assertMsg(isWhenGuardVariant(sorted.get(0)), "when-guarded variant runs first (P-13)")
    assertMsg(!isWhenGuardVariant(sorted.get(1)), "catch-all variant runs last")
}

test fn testSortFuncVariantsStableAmongSamePriority() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 1 }
    val first = FuncDeclData {
        namePos: span,
        isPub: false,
        name: "first",
        generics: [],
        params: [FuncParam { span: span, pattern: Pattern.Literal(0, span, LiteralPatternValue.Int("1")), typeExpr: None, defaultExpr: None }],
        whenGuard: None,
        returnType: None,
        body: None,
        isExprBody: false,
        isTest: false,
        isIgnore: false
    }
    val second = FuncDeclData {
        namePos: span,
        isPub: false,
        name: "second",
        generics: [],
        params: [FuncParam { span: span, pattern: Pattern.Literal(1, span, LiteralPatternValue.Int("2")), typeExpr: None, defaultExpr: None }],
        whenGuard: None,
        returnType: None,
        body: None,
        isExprBody: false,
        isTest: false,
        isIgnore: false
    }
    val sorted = sortFuncVariantsForDispatch([first, second])
    assertMsg(sorted.get(0).name == "first", "stable sort preserves order among equal priority")
    assertMsg(sorted.get(1).name == "second", "stable sort preserves order among equal priority")
}

test fn testVariantBlockNames() {
    assertMsg(variantGuardBlockName(0) == "v0_guard_ok", "guard block name")
    assertMsg(variantBodyBlockName(1) == "variant_1_body", "body block name")
    assertMsg(variantNextBlockName(2) == "variant_2_next", "next block name")
    assertMsg(variantParamPatternOkBlockName(0, 1) == "v0_p1_ok", "param pattern ok block")
}

test fn testBuildFuncVariantPlanWhenGuard() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 1 }
    val guardCond = Node.IntLiteral(10, span, IntLiteralData { value: "1" })
    val guarded = makePickVariant(span, Some(guardCond))
    val plan = buildFuncVariantPlan(guarded, 0)
    assertMsg(plan.bodyBlockName == "variant_0_body", "plan body block")
    assertMsg(plan.nextBlockName == "variant_0_next", "plan next block")
    match plan.guardBlockName {
        None => assertMsg(false, "plan guard block")
        Some(name) => assertMsg(name == "v0_guard_ok", "plan guard block name")
    }
    assertMsg(plan.paramPatternOkBlockNames.size() == 1, "one param pattern block")
    assertMsg(plan.paramPatternOkBlockNames.get(0) == "v0_p0_ok", "param pattern block name")
}

test fn testBuildFuncVariantPlansFromCheckResult() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 1 }
    val guardCond = Node.IntLiteral(10, span, IntLiteralData { value: "1" })
    val catchall = makePickVariant(span, None)
    val guarded = makePickVariant(span, Some(guardCond))
    var cr = funcTestCheckResult()
    cr.funcVariants.set("pick", [catchall, guarded])
    val g = newGenerator(cr)
    val plans = buildFuncVariantPlans(g, "pick")
    assertMsg(plans.size() == 2, "two variant plans")
    assertMsg(isWhenGuardVariant(plans.get(0).variant), "guarded plan first")
    match plans.get(0).guardBlockName {
        None => assertMsg(false, "first plan has guard block")
        Some(name) => assertMsg(name == "v0_guard_ok", "first plan guard block")
    }
    match plans.get(1).guardBlockName {
        None => assertMsg(true, "catchall has no guard block")
        Some(_) => assertMsg(false, "catchall has no guard block")
    }
}

test fn testFuncVariantsForNameMissing() {
    val g = newGenerator(funcTestCheckResult())
    assertMsg(funcVariantsForName(g, "missing").size() == 0, "missing name returns empty")
}

test fn testGenerateFuncVariantsBodyWhenGuard() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val guardCond = Node.IntLiteral(10, span, IntLiteralData { value: "1" })
    val ret = Node.ReturnStmt(11, span, ReturnStmtData { value: Some(Node.IntLiteral(12, span, IntLiteralData { value: "42" })) })
    val catchall = makePickVariant(span, None)
    val guarded = makePickVariant(span, Some(guardCond))
    var catchallBody = catchall
    catchallBody.body = Some(ret)
    var guardedBody = guarded
    guardedBody.body = Some(ret)
    var cr = funcTestCheckResult()
    cr.funcVariants.set("pick", [catchallBody, guardedBody])
    cr.nodeTypes.append(Some(IntType))
    cr.nodeTypes.append(Some(IntType))
    val g = newGenerator(cr)
    assertMsg(generateFuncVariantsBody(g, "pick"), "when-guard variant bodies codegen")
}

test fn testGenerateFuncVariantsBodyLiteralParam() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val ret = Node.ReturnStmt(11, span, ReturnStmtData { value: Some(Node.IntLiteral(12, span, IntLiteralData { value: "1" })) })
    val literalVariant = FuncDeclData {
        namePos: span,
        isPub: false,
        name: "pick",
        generics: [],
        params: [FuncParam { span: span, pattern: Pattern.Literal(0, span, LiteralPatternValue.Int("1")), typeExpr: None, defaultExpr: None }],
        whenGuard: None,
        returnType: None,
        body: Some(ret),
        isExprBody: false,
        isTest: false,
        isIgnore: false
    }
    var cr = funcTestCheckResult()
    cr.funcVariants.set("pick", [literalVariant])
    cr.nodeTypes.append(Some(IntType))
    cr.nodeTypes.append(Some(IntType))
    val g = newGenerator(cr)
    assertMsg(generateFuncVariantsBody(g, "pick"), "literal param pattern variant body codegen")
}

test fn testShouldSkipFuncVariantsTestInNormalBuild() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 1 }
    var testVariant = makePickVariant(span, None)
    testVariant.isTest = true
    val g = newGenerator(funcTestCheckResult())
    assertMsg(shouldSkipFuncVariants(g, "test_pick", [testVariant]), "skip test func in normal build")
}

test fn testGenerateProgramBodyMultiVariant() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val ret = Node.ReturnStmt(11, span, ReturnStmtData { value: Some(Node.IntLiteral(12, span, IntLiteralData { value: "42" })) })
    val catchall = makePickVariant(span, None)
    val guarded = makePickVariant(span, Some(Node.IntLiteral(10, span, IntLiteralData { value: "1" })))
    var catchallBody = catchall
    catchallBody.body = Some(ret)
    var guardedBody = guarded
    guardedBody.body = Some(ret)
    val catchallNode = Node.FuncDecl(1, span, catchallBody)
    val guardedNode = Node.FuncDecl(2, span, guardedBody)
    var cr = funcTestCheckResult()
    cr.funcVariants.set("pick", [catchallBody, guardedBody])
    cr.nodeTypes.append(Some(IntType))
    cr.nodeTypes.append(Some(IntType))
    cr.nodeTypes.append(Some(IntType))
    val g = newGenerator(cr)
    match generateProgramBody(g, [catchallNode, guardedNode]) {
        None => assertMsg(false, "expected program result for multi-variant pick")
        Some(r) => assertMsg(r.funcCount == 1, "multi-variant name counted once")
    }
}

test fn testGenerateFuncDeclNode() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val ret = Node.ReturnStmt(2, span, ReturnStmtData { value: Some(Node.IntLiteral(3, span, IntLiteralData { value: "42" })) })
    val ft = FuncType { params: [], returnType: IntType, generics: [], defaults: [], isOptional: [] }
    val fd = FuncDeclData {
        namePos: span,
        isPub: false,
        name: "main",
        generics: [],
        params: [],
        whenGuard: None,
        returnType: None,
        body: Some(ret),
        isExprBody: false,
        isTest: false,
        isIgnore: false
    }
    val node = Node.FuncDecl(1, span, fd)
    var cr = funcCheckerWithNodeType(1, Type.Func(ft))
    cr.nodeTypes.append(Some(IntType))
    cr.nodeTypes.append(Some(UnitType))
    val g = newGenerator(cr)
    match generateFuncDeclNode(g, node, fd) {
        None => assertMsg(false, "expected func result")
        Some(r) => {
            assertMsg(r.name == "main", "func name")
            assertMsg(r.paramCount == 0, "no params")
            assertMsg(r.hasBody, "has body")
            assertMsg(llvmTypesEqual(r.returnLlvm, llvmI64()), "returns i64")
        }
    }
}

test fn testGenerateProgramBody() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val ret = Node.ReturnStmt(4, span, ReturnStmtData { value: None })
    val ft = FuncType { params: [], returnType: UnitType, generics: [], defaults: [], isOptional: [] }
    val fd = FuncDeclData {
        namePos: span,
        isPub: false,
        name: "main",
        generics: [],
        params: [],
        whenGuard: None,
        returnType: None,
        body: Some(ret),
        isExprBody: false,
        isTest: false,
        isIgnore: false
    }
    val funcNode = Node.FuncDecl(1, span, fd)
    var cr = funcCheckerWithNodeType(1, Type.Func(ft))
    cr.nodeTypes.append(Some(UnitType))
    val g = newGenerator(cr)
    match generateProgramBody(g, [funcNode]) {
        None => assertMsg(false, "expected program result")
        Some(r) => assertMsg(r.funcCount == 1, "one func generated")
    }
}

}

test fn testGeneratePendingClassMethodBody() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val emptyBody = Node.BlockStmt(20, span, BlockStmtData { statements: [] })
    var params: List[FuncParam] = []
    params.append(FuncParam { span: span, pattern: Pattern.Binding(100, span, "self"), typeExpr: None, defaultExpr: None })
    val fd = FuncDeclData {
        namePos: span,
        isPub: true,
        name: "incrementar",
        generics: [],
        params: params,
        whenGuard: None,
        returnType: None,
        body: Some(emptyBody),
        isExprBody: false,
        isTest: false,
        isIgnore: false
    }
    val methodNode = Node.FuncDecl(10, span, fd)
    var classBody: List[Node] = []
    classBody.append(methodNode)
    val classDecl = ClassDeclData { isPub: true, name: "Contador", generics: [], interfaces: [], body: classBody }
    val g = newGenerator(funcTestCheckResult())
    assertMsg(generateClassDecl(g, classDecl), "class decl ok")
    assertMsg(g.pendingClassBodies.size() == 1, "pending class body")
    assertMsg(generatePendingClassBodies(g), "generate class method bodies")
    assertMsg(g.pendingClassBodies.size() == 0, "pending cleared")
    assertMsg(g.classMethodBodiesGenerated == 1, "one body generated")
    assertMsg(blockNameRegistered(g, "entry"), "entry block from method body")
}

test fn testGeneratePendingExtendMethodBody() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val emptyBody = Node.BlockStmt(20, span, BlockStmtData { statements: [] })
    var params: List[FuncParam] = []
    params.append(FuncParam { span: span, pattern: Pattern.Binding(100, span, "self"), typeExpr: None, defaultExpr: None })
    val fd = FuncDeclData {
        namePos: span,
        isPub: true,
        name: "double",
        generics: [],
        params: params,
        whenGuard: None,
        returnType: None,
        body: Some(emptyBody),
        isExprBody: false,
        isTest: false,
        isIgnore: false
    }
    var methods: List[Node] = []
    methods.append(Node.FuncDecl(10, span, fd))
    val extendDecl = ExtendDeclData { typeName: "Int", methods: methods }
    val g = newGenerator(funcTestCheckResult())
    assertMsg(generateExtendDecl(g, extendDecl), "extend decl ok")
    assertMsg(g.pendingExtendBodies.size() == 1, "pending extend body")
    assertMsg(generatePendingExtendBodies(g), "generate extend method bodies")
    assertMsg(g.pendingExtendBodies.size() == 0, "pending extend cleared")
    assertMsg(g.extendMethodBodiesGenerated == 1, "one extend body generated")
    assertMsg(extendHasMethodSymbol(g, "Int", extendMethodSymbolName("Int", "double")), "Int_double symbol")
}

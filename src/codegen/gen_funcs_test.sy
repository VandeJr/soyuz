}

test fn testFuncVariantWhenGuardPriority() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 1 }
    val guardCond = Node.IntLiteral(10, span, IntLiteralData { value: "1" })
    val guarded = FuncDeclData {
        namePos: span,
        isPub: false,
        name: "f",
        generics: [],
        params: [FuncParam { span: span, pattern: Pattern.Binding(0, span, "x"), typeExpr: None, defaultExpr: None }],
        whenGuard: Some(guardCond),
        returnType: None,
        body: None,
        isExprBody: false,
        isTest: false,
        isIgnore: false
    }
    assertMsg(funcVariantDispatchPriority(guarded) == 0, "when guard priority 0")
    assertMsg(isWhenGuardVariant(guarded), "has when guard")
}

fn makePickVariant(span: Span, whenGuard: Option[Node]) -> FuncDeclData {
    return FuncDeclData {
        namePos: span,
        isPub: false,
        name: "pick",
        generics: [],
        params: [FuncParam { span: span, pattern: Pattern.Binding(0, span, "x"), typeExpr: None, defaultExpr: None }],
        whenGuard: whenGuard,
        returnType: None,
        body: None,
        isExprBody: false,
        isTest: false,
        isIgnore: false
    }
}

fn makeAbsVariant(span: Span, whenGuard: Option[Node]) -> FuncDeclData {
    return FuncDeclData {
        namePos: span,
        isPub: false,
        name: "abs",
        generics: [],
        params: [FuncParam { span: span, pattern: Pattern.Binding(0, span, "x"), typeExpr: None, defaultExpr: None }],
        whenGuard: whenGuard,
        returnType: None,
        body: None,
        isExprBody: false,
        isTest: false,
        isIgnore: false
    }
}

fn makeAbsGuardCond(span: Span) -> Node {
    val xId = Node.Identifier(10, span, IdentifierData { name: "x" })
    val zero = Node.IntLiteral(11, span, IntLiteralData { value: "0" })
    return Node.BinaryExpr(12, span, BinaryExprData { operator: "<", left: [xId], right: [zero] })
}

fn makeAbsReturnNegX(span: Span) -> Node {
    val xId = Node.Identifier(30, span, IdentifierData { name: "x" })
    val negX = Node.UnaryExpr(31, span, UnaryExprData { operator: "-", operand: [xId] })
    return Node.ReturnStmt(32, span, ReturnStmtData { value: Some(negX) })
}

fn makeAbsReturnX(span: Span) -> Node {
    val xId = Node.Identifier(40, span, IdentifierData { name: "x" })
    return Node.ReturnStmt(41, span, ReturnStmtData { value: Some(xId) })
}

test fn testSortFuncVariantsWhenGuardBeforeCatchall() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 1 }
    val guardCond = Node.IntLiteral(10, span, IntLiteralData { value: "1" })
    val catchall = makePickVariant(span, None)
    val guarded = makePickVariant(span, Some(guardCond))
    val sorted = sortFuncVariantsForDispatch([catchall, guarded])
    assertMsg(sorted.size() == 2, "two variants")
    assertMsg(isWhenGuardVariant(sorted.get(0)), "when-guarded variant runs first (P-13)")
    assertMsg(!isWhenGuardVariant(sorted.get(1)), "catch-all variant runs last")
}

fn makePickReturnBody(span: Span, value: String) -> Node {
    val lit = Node.StringLiteral(20, span, StringLiteralData { value: value })
    return Node.ReturnStmt(21, span, ReturnStmtData { value: Some(lit) })
}

// Port of soyuz-go/internal/codegen/when_dispatch_test.go TestWhenVariantBeforeCatchall (P-13).
test fn testWhenVariantBeforeCatchall() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 40 }
    val guardCond = Node.IntLiteral(10, span, IntLiteralData { value: "1" })
    var catchall = makePickVariant(span, None)
    catchall.body = Some(makePickReturnBody(span, "default"))
    var guarded = makePickVariant(span, Some(guardCond))
    guarded.body = Some(makePickReturnBody(span, "positive"))
    var cr = funcTestCheckResult()
    cr.funcVariants.set("pick", [catchall, guarded])
    cr.nodeTypes.append(Some(StringType))
    cr.nodeTypes.append(Some(StringType))
    val g = newGenerator(cr)
    val plans = buildFuncVariantPlans(g, "pick")
    assertMsg(plans.size() == 2, "two variant plans")
    val firstPlan = plans.get(0)
    assertMsg(isWhenGuardVariant(firstPlan.variant), "when-guarded variant at index 0 after sort")
    match firstPlan.variant.body {
        None => assertMsg(false, "guarded variant body")
        Some(bodyNode) => match bodyNode {
            ReturnStmt(_, _, data) => match data.value {
                None => assertMsg(false, "guarded return value")
                Some(valNode) => match valNode {
                    StringLiteral(_, _, lit) => assertMsg(lit.value == "positive", "guarded body is positive")
                    _ => assertMsg(false, "guarded string return")
                }
            }
            _ => assertMsg(false, "guarded return stmt")
        }
    }
    match firstPlan.guardBlockName {
        None => assertMsg(false, "guarded plan has guard block")
        Some(name) => assertMsg(name == "v0_guard_ok", "guard block at sorted index 0")
    }
    assertMsg(generateFuncVariantsBody(g, "pick"), "when-guarded pick codegen")
    assertMsg(blockNameRegistered(g, "v0_guard_ok"), "v0_guard_ok block registered")
    assertMsg(blockNameRegistered(g, "variant_0_body"), "guarded variant body block at index 0")
    assertMsg(blockNameRegistered(g, "variant_1_body"), "catchall variant body block at index 1")
    match g.funcVariantGuardCondValue {
        None => assertMsg(false, "func variant guard condition stub")
        Some(v) => assertMsg(v.handle > 0, "guard cond br uses generated condition stub")
    }
}

test fn testSortFuncVariantsStableAmongSamePriority() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 1 }
    val first = FuncDeclData {
        namePos: span,
        isPub: false,
        name: "first",
        generics: [],
        params: [FuncParam { span: span, pattern: Pattern.Literal(0, span, LiteralPatternValue.Int("1")), typeExpr: None, defaultExpr: None }],
        whenGuard: None,
        returnType: None,
        body: None,
        isExprBody: false,
        isTest: false,
        isIgnore: false
    }
    val second = FuncDeclData {
        namePos: span,
        isPub: false,
        name: "second",
        generics: [],
        params: [FuncParam { span: span, pattern: Pattern.Literal(1, span, LiteralPatternValue.Int("2")), typeExpr: None, defaultExpr: None }],
        whenGuard: None,
        returnType: None,
        body: None,
        isExprBody: false,
        isTest: false,
        isIgnore: false
    }
    val sorted = sortFuncVariantsForDispatch([first, second])
    val sortedFirst = sorted.get(0)
    val sortedSecond = sorted.get(1)
    assertMsg(sortedFirst.name == "first", "stable sort preserves order among equal priority")
    assertMsg(sortedSecond.name == "second", "stable sort preserves order among equal priority")
}

test fn testVariantBlockNames() {
    assertMsg(variantGuardBlockName(0) == "v0_guard_ok", "guard block name")
    assertMsg(variantBodyBlockName(1) == "variant_1_body", "body block name")
    assertMsg(variantNextBlockName(2) == "variant_2_next", "next block name")
    assertMsg(variantParamPatternOkBlockName(0, 1) == "v0_p1_ok", "param pattern ok block")
    assertMsg(funcVariantArgName(0) == "arg0", "first arg slot name")
}

test fn testSeedFuncVariantParams() {
    val g = newGenerator(funcTestCheckResult())
    assertMsg(seedFuncVariantParams(g, 2), "seed two arg slots")
    var hasArg0 = false
    var hasArg1 = false
    for k in g.vars.keys() {
        if k == "arg0" { hasArg0 = true }
        if k == "arg1" { hasArg1 = true }
    }
    assertMsg(hasArg0, "arg0 seeded")
    assertMsg(hasArg1, "arg1 seeded")
}

test fn testGenerateFuncVariantsBodyBindingParamAliasesArg() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val ret = Node.ReturnStmt(11, span, ReturnStmtData { value: Some(Node.IntLiteral(12, span, IntLiteralData { value: "42" })) })
    val bindingVariant = FuncDeclData {
        namePos: span,
        isPub: false,
        name: "pick",
        generics: [],
        params: [FuncParam { span: span, pattern: Pattern.Binding(0, span, "x"), typeExpr: None, defaultExpr: None }],
        whenGuard: None,
        returnType: None,
        body: Some(ret),
        isExprBody: false,
        isTest: false,
        isIgnore: false
    }
    var cr = funcTestCheckResult()
    cr.funcVariants.set("pick", [bindingVariant])
    cr.nodeTypes.append(Some(IntType))
    cr.nodeTypes.append(Some(IntType))
    val g = newGenerator(cr)
    assertMsg(generateFuncVariantsBody(g, "pick"), "binding param variant body codegen")
    var argHandle = 0
    var xHandle = 0
    var hasArg = false
    var hasX = false
    for k in g.vars.keys() {
        if k == "arg0" {
            hasArg = true
            val argValue = g.vars.get("arg0")
            argHandle = argValue.handle
        }
        if k == "x" {
            hasX = true
            val xValue = g.vars.get("x")
            xHandle = xValue.handle
        }
    }
    assertMsg(hasArg, "arg0 present after variant dispatch")
    assertMsg(hasX, "binding x present after variant dispatch")
    assertMsg(argHandle == xHandle, "x aliases arg0 alloca")
}

test fn testBuildFuncVariantPlanWhenGuard() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 1 }
    val guardCond = Node.IntLiteral(10, span, IntLiteralData { value: "1" })
    val guarded = makePickVariant(span, Some(guardCond))
    val plan = buildFuncVariantPlan(guarded, 0)
    assertMsg(plan.bodyBlockName == "variant_0_body", "plan body block")
    assertMsg(plan.nextBlockName == "variant_0_next", "plan next block")
    match plan.guardBlockName {
        None => assertMsg(false, "plan guard block")
        Some(name) => assertMsg(name == "v0_guard_ok", "plan guard block name")
    }
    assertMsg(plan.paramPatternOkBlockNames.size() == 1, "one param pattern block")
    assertMsg(plan.paramPatternOkBlockNames.get(0) == "v0_p0_ok", "param pattern block name")
}

test fn testBuildFuncVariantPlansFromCheckResult() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 1 }
    val guardCond = Node.IntLiteral(10, span, IntLiteralData { value: "1" })
    val catchall = makePickVariant(span, None)
    val guarded = makePickVariant(span, Some(guardCond))
    var cr = funcTestCheckResult()
    cr.funcVariants.set("pick", [catchall, guarded])
    val g = newGenerator(cr)
    val plans = buildFuncVariantPlans(g, "pick")
    assertMsg(plans.size() == 2, "two variant plans")
    val firstPlan = plans.get(0)
    val secondPlan = plans.get(1)
    assertMsg(isWhenGuardVariant(firstPlan.variant), "guarded plan first")
    match firstPlan.guardBlockName {
        None => assertMsg(false, "first plan has guard block")
        Some(name) => assertMsg(name == "v0_guard_ok", "first plan guard block")
    }
    match secondPlan.guardBlockName {
        None => assertMsg(true, "catchall has no guard block")
        Some(_) => assertMsg(false, "catchall has no guard block")
    }
}


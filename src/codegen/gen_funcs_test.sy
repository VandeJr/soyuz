test fn testGenerateFuncVariantsBodyWhenGuardCreatesBlocks() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val guardCond = Node.IntLiteral(10, span, IntLiteralData { value: "1" })
    val ret = Node.ReturnStmt(11, span, ReturnStmtData { value: Some(Node.IntLiteral(12, span, IntLiteralData { value: "42" })) })
    val catchall = makePickVariant(span, None)
    val guarded = makePickVariant(span, Some(guardCond))
    var catchallBody = catchall
    catchallBody.body = Some(ret)
    var guardedBody = guarded
    guardedBody.body = Some(ret)
    var cr = funcTestCheckResult()
    cr.funcVariants.set("pick", [catchallBody, guardedBody])
    cr.nodeTypes.append(Some(IntType))
    cr.nodeTypes.append(Some(IntType))
    val g = newGenerator(cr)
    assertMsg(generateFuncVariantsBody(g, "pick"), "when-guard blocks codegen")
    assertMsg(blockNameRegistered(g, "v0_guard_ok"), "guard ok block registered")
    assertMsg(blockNameRegistered(g, "variant_0_next"), "guard fail block registered")
    assertMsg(blockNameRegistered(g, "variant_0_body"), "guarded variant body block")
    assertMsg(blockNameRegistered(g, "variant_1_body"), "catchall variant body block")
    match currentBlockHandle(g) {
        None => assertMsg(false, "current block after variant loop")
        Some(handle) => assertMsg(handle > 0, "current block set after variants")
    }
}

// Port of soyuz-go/internal/codegen/when_guard_test.go TestWhenGuardCodegen (abs when x < 0).
test fn testWhenGuardCodegen() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 40 }
    var guarded = makeAbsVariant(span, Some(makeAbsGuardCond(span)))
    guarded.body = Some(makeAbsReturnNegX(span))
    var catchall = makeAbsVariant(span, None)
    catchall.body = Some(makeAbsReturnX(span))
    var cr = funcTestCheckResult()
    cr.funcVariants.set("abs", [guarded, catchall])
    cr.nodeTypes.append(Some(IntType))
    cr.nodeTypes.append(Some(IntType))
    val g = newGenerator(cr)
    assertMsg(generateFuncVariantsBody(g, "abs"), "abs when-guard variant codegen")
    assertMsg(blockNameRegistered(g, "v0_guard_ok"), "v0_guard_ok block")
    assertMsg(blockNameRegistered(g, "variant_0_body"), "variant_0_body block")
    assertMsg(blockNameRegistered(g, "variant_1_body"), "variant_1_body block")
    match g.funcVariantGuardCondValue {
        None => assertMsg(false, "func variant guard condition stub")
        Some(v) => assertMsg(v.handle > 0, "conditional branch guard value stub")
    }
}


    val fanMember = Node.MemberExpr(2, span, MemberExprData { object: taskId, property: "fan" })
    assertMsg(isTaskStaticFan("Task", "fan"), "Task.fan static")
    assertMsg(isTaskFanCall(fanMember), "Task.fan call")
    assertMsg(!isTaskFanCall(Node.MemberExpr(3, span, MemberExprData { object: taskId, property: "all" })), "Task.all not fan")
}

test fn testTaskFanFnArgsValid() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val input = Node.IntLiteral(1, span, IntLiteralData { value: "5" })
    val f1 = Node.Identifier(2, span, IdentifierData { name: "double" })
    val f2 = Node.Identifier(3, span, IdentifierData { name: "triple" })
    var args: List[Node] = []
    args.append(input)
    args.append(f1)
    args.append(f2)
    assertMsg(taskFanFnArgsValid(args), "input plus two fn ids")
    var badArgs: List[Node] = []
    badArgs.append(input)
    badArgs.append(input)
    assertMsg(!taskFanFnArgsValid(badArgs), "second arg must be fn id")
}


test fn testEmitTaskDrops() {
    val g = newGenerator(taskEmptyCheckResult())
    var names: List[String] = []
    names.append("t")
    assertMsg(emitTaskDrops(g, []), "empty drop list ok")
    assertMsg(emitTaskDrops(g, names), "emit task drops")
    assertMsg(g.taskDropStub != None, "drop stub stored")
    assertMsg(taskRuntimeSymbolRegistered(g, taskDropHandleRuntime()), "srt_drop_task_handle registered")
}

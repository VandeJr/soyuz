test fn testOwnTaskVarAndPopScope() {
    val g = newGenerator(taskEmptyCheckResult())
    pushTaskScope(g)
    ownTaskVar(g, "t")
    val owned = popTaskScope(g)
    assertMsg(owned.size() == 1, "one task var owned")
    assertMsg(isTaskInstanceType(Type.Specialized(Type.Class(taskEmptyClass("Task")), [IntType])), "task instance type")
}

test fn testNullifyTaskVarAfterConsume() {
    val g = newGenerator(taskEmptyCheckResult())
    g.vars.set("t", newAlloca(g, llvmI8Ptr()))
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val tId = Node.Identifier(1, span, IdentifierData { name: "t" })
    assertMsg(nullifyTaskVarAfterConsume(g, tId), "null store on task var alloca")
    assertMsg(taskNullStoreRecorded(g, "t"), "null store recorded for t")
    assertMsg(nullifyTaskVarAfterConsume(g, Node.IntLiteral(2, span, IntLiteralData { value: "0" })), "non-identifier is no-op")
}

test fn testNullifyAfterTapStub() {
    val g = newGenerator(taskEmptyCheckResult())
    g.vars.set("t", newAlloca(g, llvmI8Ptr()))
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }

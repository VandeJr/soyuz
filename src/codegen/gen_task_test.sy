    var cr = taskEmptyCheckResult()
    cr.nodeTypes.append(Some(taskInt))
    cr.nodeTypes.append(Some(taskInt))
    val g = newGenerator(cr)
    assertMsg(isTaskTapMethodCall(tapMember, g), "t.tap on Task[Int]")

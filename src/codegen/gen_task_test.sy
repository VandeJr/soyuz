}

test fn testGenerateTaskTapStub() {
    val g = newGenerator(taskEmptyCheckResult())
    match generateTaskTapStub(g) {
        None => assertMsg(false, "task tap stub")
        Some(_) => {
            assertMsg(g.taskTapStub != None, "tap stub stored")
            assertMsg(g.taskTapWrapperName != None, "tap wrapper name stored")
        }
    }
    assertMsg(taskRuntimeSymbolRegistered(g, taskRuntimeEnqueue()), "srt_enqueue registered")
    assertMsg(taskRuntimeSymbolRegistered(g, taskRuntimeAwait()), "srt_await registered")
    assertMsg(taskRuntimeSymbolRegistered(g, taskRuntimeSetResult()), "srt_set_task_result registered")
    assertMsg(taskRuntimeSymbolRegistered(g, taskMallocBuiltin()), "malloc registered")
    match g.taskTapWrapperName {
        None => assertMsg(false, "tap wrapper name")
        Some(name) => assertMsg(name == "__tap_wrapper_1", "tap wrapper counter used")
    }
}


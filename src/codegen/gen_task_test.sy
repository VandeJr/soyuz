test fn testIsSelectTaskAwaitCall() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val tId = Node.Identifier(1, span, IdentifierData { name: "t" })
    val awaitMember = Node.MemberExpr(2, span, MemberExprData { object: tId, property: "await" })
    var args: List[Node] = []
    val awaitCall = Node.CallExpr(3, span, CallExprData { callee: awaitMember, args: args })
    assertMsg(isSelectTaskAwaitCall(awaitCall), "t.await() is select task arm")
    val recvMember = Node.MemberExpr(4, span, MemberExprData { object: tId, property: "recv" })
    val recvCall = Node.CallExpr(5, span, CallExprData { callee: recvMember, args: args })
    assertMsg(!isSelectTaskAwaitCall(recvCall), "ch.recv() not select task arm")
}


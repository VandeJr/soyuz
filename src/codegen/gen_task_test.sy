import (
    { Node, FuncDeclData, IdentifierData, MemberExprData, CallExprData, TaskExprData, IntLiteralData, PipeExprData } from @ast/ast
    { Span } from @lexer/tokens
    { CheckResult, Type, FuncType, ClassType, IntType } from @checker/types
    { newGenerator } from @codegen/generator
    { isTaskInstanceType, taskRuntimeEnqueue, taskRuntimeAwait } from @codegen/gen_gather
    { isTaskCallInner, isTaskPipeInner, isTaskAllCombinatorCall, isTaskStaticAll, isTaskStaticFan, isTaskFanCall, isTaskStaticPipeline, isTaskPipelineCall, isTaskFanFnArg, taskFanFnArgsValid, isTaskAwaitMethodCall, isTaskDetachMethodCall, isTaskTapMethodCall, isTaskAlwaysMethodCall, isSelectTaskAwaitCall, taskRuntimeDetach, taskRuntimeSetResult, taskMallocBuiltin, taskDropHandleRuntime, taskTupleAllocBuiltin, generateTaskEnqueueStub, generateTaskPipeEnqueueStub, generateTaskDetachStub, generateTaskAwaitStub, generateTaskTapStub, generateTaskAlwaysStub, generateSelectListenerStub, generateSelectTaskBridgeStub, generateTaskDropStub, generateTaskAllStub, generateTaskFanStub, generateTaskPipelineStub, taskPipelineBlockNamesRegistered, nullifyTaskVarAfterConsume, taskNullStoreRecorded, emitTaskDrops, taskRuntimeSymbolRegistered, ownTaskVar, pushTaskScope, popTaskScope } from @codegen/gen_task
    { newAlloca } from @codegen/gen_ir
    { llvmI8Ptr } from @codegen/llvm_types
    { channelRuntimeNew, channelRuntimeSend, channelRuntimeRecv, channelRuntimeClose } from @codegen/gen_channel
    { assertMsg } from @soyuz/testing
)

fn taskEmptyCheckResult() -> CheckResult = CheckResult {
    errors: [],
    warnings: [],
    nodeTypes: [],
    specializations: Map[Int, FuncType]{},
    funcVariants: Map[String, List[FuncDeclData]]{},
    testFuncs: [],
    captures: Map[Int, List[String]]{},
    synthCallArgs: Map[Int, List[Node]]{},
    curriedCalls: Map[Int, Node]{},
    typeExtensions: Map[String, Map[String, List[FuncType]]]{}
}

fn taskEmptyClass(name: String) -> ClassType = ClassType {
    name: name,
    fields: Map[String, Type]{},
    fieldPub: Map[String, Bool]{},
    fieldInit: Map[String, Node]{},
    methods: Map[String, List[FuncType]]{},
    methodPub: Map[String, Bool]{},
    implements: [],
    generics: ["T"]
}

test fn testIsTaskCallInner() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val callee = Node.Identifier(1, span, IdentifierData { name: "double" })
    val arg = Node.IntLiteral(2, span, IntLiteralData { value: "5" })
    var args: List[Node] = []
    args.append(arg)
    val call = Node.CallExpr(3, span, CallExprData { callee: callee, args: args })
    assertMsg(isTaskCallInner(call), "CallExpr is task call inner")
    val taskInner = Node.TaskExpr(4, span, TaskExprData { inner: call })
    assertMsg(!isTaskCallInner(taskInner), "TaskExpr not direct call inner")
}

test fn testIsTaskPipeInner() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val nId = Node.Identifier(1, span, IdentifierData { name: "n" })
    val fnId = Node.Identifier(2, span, IdentifierData { name: "double" })
    val pipe = Node.PipeExpr(3, span, PipeExprData { left: nId, right: fnId })
    assertMsg(isTaskPipeInner(pipe), "PipeExpr is task pipe inner")
    val callee = Node.Identifier(4, span, IdentifierData { name: "double" })
    var args: List[Node] = []
    args.append(nId)
    val call = Node.CallExpr(5, span, CallExprData { callee: callee, args: args })
    assertMsg(!isTaskPipeInner(call), "CallExpr not pipe inner")
}

test fn testGenerateTaskPipeEnqueueStub() {
    val g = newGenerator(taskEmptyCheckResult())
    match generateTaskPipeEnqueueStub(g) {
        None => assertMsg(false, "task pipe enqueue stub")
        Some(_) => {
            assertMsg(g.taskPipeMode, "pipe mode flag set")
            assertMsg(g.taskEnqueueStub != None, "enqueue stub stored")
            assertMsg(g.taskPipeInnerStub != None, "pipe inner stub stored")
            assertMsg(g.taskPipeCaptureStub != None, "pipe capture stub stored")
        }
    }
    assertMsg(taskRuntimeSymbolRegistered(g, taskRuntimeEnqueue()), "srt_enqueue registered")
    assertMsg(taskRuntimeSymbolRegistered(g, taskMallocBuiltin()), "malloc registered")
}

test fn testIsTaskAwaitCall() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val taskClass = taskEmptyClass("Task")
    val taskInt = Type.Specialized(Type.Class(taskClass), [IntType])
    val tId = Node.Identifier(1, span, IdentifierData { name: "t" })
    val awaitMember = Node.MemberExpr(2, span, MemberExprData { object: tId, property: "await" })
    var cr = taskEmptyCheckResult()
    cr.nodeTypes.append(Some(taskInt))
    cr.nodeTypes.append(Some(taskInt))
    val g = newGenerator(cr)
    assertMsg(isTaskAwaitMethodCall(awaitMember, g), "t.await on Task[Int]")
    val detachMember = Node.MemberExpr(3, span, MemberExprData { object: tId, property: "detach" })
    assertMsg(!isTaskAwaitMethodCall(detachMember, g), "t.detach not await")
}


test fn testIsTaskAllCombinatorCall() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val taskId = Node.Identifier(1, span, IdentifierData { name: "Task" })
    val allMember = Node.MemberExpr(2, span, MemberExprData { object: taskId, property: "all" })
    val settledMember = Node.MemberExpr(3, span, MemberExprData { object: taskId, property: "allSettled" })
    val gatherMember = Node.MemberExpr(4, span, MemberExprData { object: taskId, property: "gather" })
    assertMsg(isTaskStaticAll("Task", "all"), "Task.all static")
    assertMsg(isTaskStaticAll("Task", "allSettled"), "Task.allSettled static")
    assertMsg(isTaskAllCombinatorCall(allMember), "Task.all call")
    assertMsg(isTaskAllCombinatorCall(settledMember), "Task.allSettled call")
    assertMsg(!isTaskAllCombinatorCall(gatherMember), "Task.gather not all combinator")
}


    val g = newGenerator(controlCheckerWithNodeTypes(types))
    val handlesBefore = g.valueHandleCounter
    match generateStmtNode(g, loopNode) {
        None => assertMsg(false, "expected value loop with break")
        Some(_) => assertMsg(g.valueHandleCounter > handlesBefore + 1, "break value store stub allocates value handle")
    }
}

test fn testGenerateUnitLoopNoResultLoad() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val body = Node.BlockStmt(3, span, BlockStmtData { statements: [] })
    val loopNode = Node.LoopStmt(2, span, LoopStmtData { body: body })
    var types: Map[Int, Type] = Map[Int, Type]{}
    types.set(2, UnitType)
    types.set(3, UnitType)
    val g = newGenerator(controlCheckerWithNodeTypes(types))
    val handlesBefore = g.valueHandleCounter
    match generateStmtNode(g, loopNode) {
        None => assertMsg(false, "expected unit loop stmt")
        Some(_) => {
            assertMsg(g.valueHandleCounter == handlesBefore, "unit loop has no result alloca")
            assertMsg(g.loopResultLoad == None, "unit loop has no result load")
            assertMsg(g.loopResultDefaultStore == None, "unit loop has no default store")
        }
    }
}

test fn testBreakBranchesToLoopAfter() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 5 }
    val brk = Node.BreakStmt(1, span, BreakStmtData { value: None })
    var types: Map[Int, Type] = Map[Int, Type]{}
    types.set(1, UnitType)
    val g = newGenerator(controlCheckerWithNodeTypes(types))
    val after = LlvmBasicBlock { handle: 99 }
    val cond = LlvmBasicBlock { handle: 88 }
    pushLoop(g, LoopCtx { cond: cond, after: after, resultAlloca: noneLlvmValueOption(), resultLlvm: llvmVoid() })
    match generateStmtNode(g, brk) {
        None => assertMsg(false, "expected break stmt")
        Some(r) => {
            assertMsg(hasTerminator(r), "break terminates")
            match g.current {
                None => assertMsg(false, "expected current block after break")
                Some(block) => assertMsg(block.handle == 99, "break branches to loop after")
            }
        }
    }
    popLoop(g)
}

test fn testContinueBranchesToLoopCond() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 5 }
    val cont = Node.ContinueStmt(1, span)
    var types: Map[Int, Type] = Map[Int, Type]{}
    types.set(1, UnitType)
    val g = newGenerator(controlCheckerWithNodeTypes(types))
    val after = LlvmBasicBlock { handle: 99 }
    val cond = LlvmBasicBlock { handle: 88 }
    pushLoop(g, LoopCtx { cond: cond, after: after, resultAlloca: noneLlvmValueOption(), resultLlvm: llvmVoid() })
    match generateStmtNode(g, cont) {
        None => assertMsg(false, "expected continue stmt")
        Some(r) => {
            assertMsg(hasTerminator(r), "continue terminates")
            match g.current {
                None => assertMsg(false, "expected current block after continue")
                Some(block) => assertMsg(block.handle == 88, "continue branches to loop cond")
            }
        }
    }
    popLoop(g)
}

test fn testGenerateLoopEndsOnAfterBlock() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val body = Node.BlockStmt(3, span, BlockStmtData { statements: [] })
    val loopNode = Node.LoopStmt(2, span, LoopStmtData { body: body })
    var types: Map[Int, Type] = Map[Int, Type]{}
    types.set(2, UnitType)
    types.set(3, UnitType)
    val g = newGenerator(controlCheckerWithNodeTypes(types))
    match generateStmtNode(g, loopNode) {
        None => assertMsg(false, "expected loop stmt")
        Some(_) => match currentBlockHandle(g) {
            None => assertMsg(false, "expected current block after loop")
            Some(handle) => assertMsg(handle > 0, "loop finishes on after block")
        }
    }
}

fn controlTaskClass(name: String) -> ClassType = ClassType {
    name: name,
    fields: Map[String, Type]{},
    fieldPub: Map[String, Bool]{},
    fieldInit: Map[String, Node]{},
    methods: Map[String, List[FuncType]]{},
    methodPub: Map[String, Bool]{},
    implements: [],
    generics: ["T"]
}

// Port of m_task_test.go TestTaskDropOnScopeExit — block scope emits srt_drop_task_handle stub.
test fn testBlockEmitsTaskDropOnScopeExit() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val taskClass = controlTaskClass("Task")
    val taskInt = Type.Specialized(Type.Class(taskClass), [IntType])
    val callee = Node.Identifier(1, span, IdentifierData { name: "work" })
    val call = Node.CallExpr(2, span, CallExprData { callee: callee, args: [] })
    val taskExpr = Node.TaskExpr(3, span, TaskExprData { inner: call })
    val varDecl = Node.VarDecl(4, span, VarDeclData {
        namePos: span,
        isPub: false,
        kind: VarKind.Val,
        name: "t",
        pattern: None,
        typeExpr: None,
        init: Some(taskExpr)
    })
    var stmts: List[Node] = []
    stmts.append(varDecl)
    val block = Node.BlockStmt(5, span, BlockStmtData { statements: stmts })
    var types: Map[Int, Type] = Map[Int, Type]{}
    types.set(1, Type.Basic("Unit"))
    types.set(2, IntType)
    types.set(3, taskInt)
    types.set(4, taskInt)
    types.set(5, UnitType)
    val g = newGenerator(controlCheckerWithNodeTypes(types))
    match generateStmtNode(g, block) {
        None => assertMsg(false, "expected block with task var codegen")
        Some(_) => {
            assertMsg(g.taskDropStub != None, "task drop stub stored at block exit")
            assertMsg(taskRuntimeSymbolRegistered(g, taskDropHandleRuntime()), "srt_drop_task_handle registered")
        }
    }
}

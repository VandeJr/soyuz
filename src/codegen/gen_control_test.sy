test fn testGenerateValueLoopBlocksAndResultLoad() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val body = Node.BlockStmt(3, span, BlockStmtData { statements: [] })
    val loopNode = Node.LoopStmt(2, span, LoopStmtData { body: body })
    var types: Map[Int, Type] = Map[Int, Type]{}
    types.set(2, IntType)
    types.set(3, UnitType)
    val g = newGenerator(controlCheckerWithNodeTypes(types))
    val handlesBeforeGen = g.valueHandleCounter
    match generateStmtNode(g, loopNode) {
        None => assertMsg(false, "expected value loop stmt")
        Some(_) => {
            assertMsg(blockNameRegistered(g, "loop_body"), "loop body block registered")
            assertMsg(blockNameRegistered(g, "loop_after"), "loop after block registered")
            assertMsg(g.valueHandleCounter > handlesBeforeGen, "value loop allocates result slot")
            assertMsg(g.loopResultLoad != None, "value loop records result load stub")
            assertMsg(g.loopResultDefaultStore != None, "value loop stores default into result alloca")
        }
    }
}


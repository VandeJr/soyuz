test fn testGenerateForRangeStmtExclusive() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 30 }
    val from = Node.IntLiteral(1, span, IntLiteralData { value: "0" })
    val to = Node.IntLiteral(4, span, IntLiteralData { value: "10" })
    val range = Node.RangeExpr(5, span, RangeExprData { from: from, to: to, inclusive: false })
    val body = Node.BlockStmt(2, span, BlockStmtData { statements: [] })
    val forNode = Node.ForStmt(3, span, ForStmtData { binding: "i", iterable: range, body: body })
    var types: Map[Int, Type] = Map[Int, Type]{}
    types.set(1, IntType)
    types.set(2, UnitType)
    types.set(3, UnitType)
    types.set(4, IntType)
    types.set(5, IntType)
    val g = newGenerator(controlCheckerWithNodeTypes(types))
    assertMsg(match generateStmtNode(g, forNode) {
        None => false
        Some(_) => true
    }, "exclusive for-range dispatch")
    assertMsg(g.forRangeCondLoad != None, "exclusive for_cond loads counter")
    assertMsg(!g.forRangeCondInclusive, "exclusive range records SLT cmp path")
}

test fn testLoopCtxHasResult() {
    val cond = LlvmBasicBlock { handle: 1 }
    val after = LlvmBasicBlock { handle: 2 }
    assertMsg(!loopCtxHasResult(LoopCtx { cond: cond, after: after, resultAlloca: noneLlvmValueOption(), resultLlvm: llvmVoid() }), "unit loop no result")
    assertMsg(loopCtxHasResult(LoopCtx { cond: cond, after: after, resultAlloca: noneLlvmValueOption(), resultLlvm: llvmI64() }), "int loop has result")
}

test fn testGenerateLoopBreakWithValue() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 30 }
    val breakVal = Node.IntLiteral(5, span, IntLiteralData { value: "50" })
    val brk = Node.BreakStmt(4, span, BreakStmtData { value: Some(breakVal) })
    val body = Node.BlockStmt(3, span, BlockStmtData { statements: [brk] })
    val loopNode = Node.LoopStmt(2, span, LoopStmtData { body: body })
    var types: Map[Int, Type] = Map[Int, Type]{}
    types.set(2, IntType)
    types.set(3, UnitType)
    types.set(4, UnitType)
    types.set(5, IntType)
    val g = newGenerator(controlCheckerWithNodeTypes(types))
    match generateStmtNode(g, loopNode) {
        None => assertMsg(false, "expected value loop with break")
        Some(r) => assertMsg(!hasTerminator(r), "loop stmt itself does not terminate")
    }
}

test fn testGenerateBreakValueRequiredInValueLoop() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 10 }
    val brk = Node.BreakStmt(4, span, BreakStmtData { value: None })
    val body = Node.BlockStmt(3, span, BlockStmtData { statements: [brk] })
    val loopNode = Node.LoopStmt(2, span, LoopStmtData { body: body })
    var types: Map[Int, Type] = Map[Int, Type]{}
    types.set(2, IntType)
    types.set(3, UnitType)
    types.set(4, UnitType)
    val g = newGenerator(controlCheckerWithNodeTypes(types))
    assertMsg(generateStmtNode(g, loopNode) == None, "break without value in value loop fails")
}

test fn testGenerateBlockStopsOnReturn() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val ret = Node.ReturnStmt(2, span, ReturnStmtData { value: None })
    val dead = Node.IntLiteral(3, span, IntLiteralData { value: "99" })
    val block = Node.BlockStmt(1, span, BlockStmtData { statements: [ret, dead] })
    var types: Map[Int, Type] = Map[Int, Type]{}
    types.set(1, UnitType)
    types.set(2, UnitType)
    types.set(3, IntType)
    val g = newGenerator(controlCheckerWithNodeTypes(types))
    match generateStmtNode(g, block) {
        None => assertMsg(false, "expected block with return")
        Some(r) => assertMsg(hasTerminator(r), "block stops at return")
    }
}

test fn testGenerateWhileStmt() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val cond = Node.IntLiteral(1, span, IntLiteralData { value: "1" })
    val body = Node.BlockStmt(2, span, BlockStmtData { statements: [] })
    val whileNode = Node.WhileStmt(3, span, WhileStmtData { condition: cond, body: body })
    var types: Map[Int, Type] = Map[Int, Type]{}
    types.set(1, BoolType)
    types.set(2, UnitType)
    types.set(3, UnitType)
    val g = newGenerator(controlCheckerWithNodeTypes(types))
    val handlesBefore = g.valueHandleCounter
    match generateStmtNode(g, whileNode) {
        None => assertMsg(false, "expected while stmt result")
        Some(r) => {
            assertMsg(!hasTerminator(r), "while completes without terminator")
            assertMsg(blockNameRegistered(g, "while_cond"), "while cond block registered")
            assertMsg(blockNameRegistered(g, "while_body"), "while body block registered")
            assertMsg(blockNameRegistered(g, "while_after"), "while after block registered")
            assertMsg(g.whileCondValue != None, "while_cond records condition value stub")
            assertMsg(g.valueHandleCounter > handlesBefore, "while condition stub allocates value handle")
        }
    }
}


import (
    { Node, LoopStmtData, BlockStmtData, IfStmtData, WhileStmtData, ForStmtData, ReturnStmtData, BreakStmtData, IntLiteralData, BinaryExprData, FuncDeclData, RangeExprData, IdentifierData, VarDeclData, CallExprData, TaskExprData, VarKind } from @ast/ast
    { Span } from @lexer/tokens
    { CheckResult, FuncType, Type, IntType, UnitType, BoolType, ClassType, StringType } from @checker/types
    { newGenerator } from @codegen/generator
    { LoopCtx } from @codegen/types
    { pushLoop, popLoop, currentLoop, loopDepth, loopNeedsResultAlloca, loopCtxHasResult, loopCtxResultAlloca, isControlFlowStmt, isLoopStmt, isBreakOrContinue, newLoopCtx, noneLlvmValueOption, generateStmtNode, hasTerminator } from @codegen/gen_control
    { blockNameRegistered, emitBrToBlockStub, currentBlockHandle } from @codegen/gen_ir
    { taskDropHandleRuntime, taskRuntimeSymbolRegistered } from @codegen/gen_task
    { LlvmBasicBlock, llvmI64, llvmVoid, llvmI1 } from @codegen/llvm_types
    { assertMsg } from @soyuz/testing
)

fn controlTestCheckResult() -> CheckResult = CheckResult {
    errors: [],
    warnings: [],
    nodeTypes: [],
    specializations: Map[Int, FuncType]{},
    funcVariants: Map[String, List[FuncDeclData]]{},
    testFuncs: [],
    captures: Map[Int, List[String]]{},
    synthCallArgs: Map[Int, List[Node]]{},
    curriedCalls: Map[Int, Node]{},
    typeExtensions: Map[String, Map[String, List[FuncType]]]{}
}

test fn testLoopNeedsResultAlloca() {
    assertMsg(loopNeedsResultAlloca(IntType), "Int loop needs result")
    assertMsg(!loopNeedsResultAlloca(UnitType), "Unit loop does not")
}

test fn testLoopStack() {
    val g = newGenerator(controlTestCheckResult())
    val cond = LlvmBasicBlock { handle: 1 }
    val after = LlvmBasicBlock { handle: 2 }
    assertMsg(loopDepth(g) == 0, "empty depth")
    pushLoop(g, LoopCtx { cond: cond, after: after, resultAlloca: noneLlvmValueOption(), resultLlvm: llvmI64() })
    assertMsg(loopDepth(g) == 1, "depth after push")
    match currentLoop(g) {
        None => assertMsg(false, "expected current loop")
        Some(ctx) => assertMsg(ctx.cond.handle == 1, "cond block")
    }
    popLoop(g)
    assertMsg(loopDepth(g) == 0, "depth after pop")
    assertMsg(currentLoop(g) == None, "no current loop")
}

test fn testIsControlFlowStmt() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 1 }
    val loopNode = Node.LoopStmt(1, span, LoopStmtData { body: Node.BlockStmt(2, span, BlockStmtData { statements: [] }) })
    assertMsg(isLoopStmt(loopNode), "loop stmt")
    assertMsg(isControlFlowStmt(loopNode), "loop is control flow")
    assertMsg(!isBreakOrContinue(loopNode), "loop is not break")
}

fn controlMapHasIntType(m: Map[Int, Type], key: Int) -> Bool {
    for k in m.keys() { if k == key { return true } }
    return false
}

fn controlCheckerWithNodeTypes(types: Map[Int, Type]) -> CheckResult {
    var maxId = 0
    for id in types.keys() {
        if id > maxId { maxId = id }
    }
    var cr = controlTestCheckResult()
    var i = 0
    loop {
        if i > maxId { break }
        if controlMapHasIntType(types, i) {
            cr.nodeTypes.append(Some(types.get(i)))
        } else {
            cr.nodeTypes.append(None)
        }
        i = i + 1
    }
    return cr
}

test fn testGenerateIfStmt() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val cond = Node.IntLiteral(1, span, IntLiteralData { value: "1" })
    val thenBranch = Node.ReturnStmt(3, span, ReturnStmtData { value: None })
    val ifNode = Node.IfStmt(4, span, IfStmtData { condition: cond, consequent: thenBranch, alternate: None })
    var types: Map[Int, Type] = Map[Int, Type]{}
    types.set(1, BoolType)
    types.set(3, UnitType)
    types.set(4, UnitType)
    val g = newGenerator(controlCheckerWithNodeTypes(types))
    match generateStmtNode(g, ifNode) {
        None => assertMsg(false, "expected if stmt result")
        Some(r) => {
            assertMsg(!hasTerminator(r), "if without return in branch still NoTerminator at if level")
            assertMsg(blockNameRegistered(g, "then"), "if then block registered")
            assertMsg(blockNameRegistered(g, "else"), "if else block registered")
            assertMsg(blockNameRegistered(g, "if_merge"), "if merge block registered")
        }
    }
}

test fn testGenerateReturnStmt() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 10 }
    val ret = Node.ReturnStmt(1, span, ReturnStmtData { value: None })
    var types: Map[Int, Type] = Map[Int, Type]{}
    types.set(1, UnitType)
    val g = newGenerator(controlCheckerWithNodeTypes(types))
    match generateStmtNode(g, ret) {
        None => assertMsg(false, "expected return result")
        Some(r) => assertMsg(hasTerminator(r), "return terminates")
    }
}

test fn testGenerateBreakOutsideLoop() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 5 }
    val brk = Node.BreakStmt(1, span, BreakStmtData { value: None })
    var types: Map[Int, Type] = Map[Int, Type]{}
    types.set(1, UnitType)
    val g = newGenerator(controlCheckerWithNodeTypes(types))
    assertMsg(generateStmtNode(g, brk) == None, "break outside loop fails")
}

test fn testGenerateBreakInsideLoop() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 5 }
    val brk = Node.BreakStmt(1, span, BreakStmtData { value: None })
    var types: Map[Int, Type] = Map[Int, Type]{}
    types.set(1, UnitType)
    val g = newGenerator(controlCheckerWithNodeTypes(types))
    pushLoop(g, LoopCtx { cond: LlvmBasicBlock { handle: 1 }, after: LlvmBasicBlock { handle: 2 }, resultAlloca: noneLlvmValueOption(), resultLlvm: llvmI64() })
    match generateStmtNode(g, brk) {
        None => assertMsg(false, "expected break inside loop")
        Some(r) => assertMsg(hasTerminator(r), "break terminates")
    }
    popLoop(g)
}

test fn testGenerateForStmt() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val iterable = Node.IntLiteral(1, span, IntLiteralData { value: "0" })
    val body = Node.BlockStmt(2, span, BlockStmtData { statements: [] })
    val forNode = Node.ForStmt(3, span, ForStmtData { binding: "x", iterable: iterable, body: body })
    var types: Map[Int, Type] = Map[Int, Type]{}
    types.set(1, IntType)
    types.set(2, UnitType)
    types.set(3, UnitType)
    val g = newGenerator(controlCheckerWithNodeTypes(types))
    match generateStmtNode(g, forNode) {
        None => assertMsg(false, "expected for stmt result")
        Some(r) => {
            assertMsg(!hasTerminator(r), "for completes without terminator")
            assertMsg(blockNameRegistered(g, "for_body"), "for body block registered")
            assertMsg(blockNameRegistered(g, "for_after"), "for after block registered")
        }
    }
}

test fn testGenerateForRangeStmt() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 30 }
    val from = Node.IntLiteral(1, span, IntLiteralData { value: "0" })
    val to = Node.IntLiteral(4, span, IntLiteralData { value: "10" })
    val range = Node.RangeExpr(5, span, RangeExprData { from: from, to: to, inclusive: true })
    val body = Node.BlockStmt(2, span, BlockStmtData { statements: [] })
    val forNode = Node.ForStmt(3, span, ForStmtData { binding: "i", iterable: range, body: body })
    var types: Map[Int, Type] = Map[Int, Type]{}
    types.set(1, IntType)
    types.set(2, UnitType)
    types.set(3, UnitType)
    types.set(4, IntType)
    types.set(5, IntType)
    val g = newGenerator(controlCheckerWithNodeTypes(types))
    val handlesBefore = g.valueHandleCounter
    match generateStmtNode(g, forNode) {
        None => assertMsg(false, "expected for-range stmt result")
        Some(r) => {
            assertMsg(!hasTerminator(r), "for-range completes without terminator")
            assertMsg(blockNameRegistered(g, "for_cond"), "for-range cond block registered")
            assertMsg(blockNameRegistered(g, "for_body"), "for-range body block registered")
            assertMsg(blockNameRegistered(g, "for_incr"), "for-range incr block registered")
            assertMsg(blockNameRegistered(g, "for_after"), "for-range after block registered")
            assertMsg(g.forRangeCounterAlloca != None, "range binding alloca recorded")
            assertMsg(g.forRangeFromValue != None, "range from bound recorded")
            assertMsg(g.forRangeToValue != None, "range to bound recorded")
            assertMsg(g.forRangeCondLoad != None, "for_cond loads counter stub")
            assertMsg(g.forRangeCondInclusive, "inclusive range records SLE cmp path")
            assertMsg(g.forRangeIncrLoad != None, "for_incr loads counter stub")
            assertMsg(g.forRangeIncrStore != None, "for_incr stores next counter stub")
            assertMsg(g.valueHandleCounter > handlesBefore + 4, "range bounds plus incr load/store stubs")
            var hasI = false
            for k in g.vars.keys() {
                if k == "i" { hasI = true }
            }
            assertMsg(hasI, "range binding registered in g.vars")
        }
    }
}

test fn testGenerateForListStmt() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 30 }
    val iterable = Node.Identifier(1, span, IdentifierData { name: "nums" })
    val body = Node.BlockStmt(2, span, BlockStmtData { statements: [] })
    val forNode = Node.ForStmt(3, span, ForStmtData { binding: "n", iterable: iterable, body: body })
    val listClass = ClassType {
        name: "List",
        fields: Map[String, Type]{},
        fieldPub: Map[String, Bool]{},
        fieldInit: Map[String, Node]{},
        methods: Map[String, List[FuncType]]{},
        methodPub: Map[String, Bool]{},
        implements: [],
        generics: ["T"]
    }
    val listInt = Type.Specialized(Type.Class(listClass), [IntType])
    var types: Map[Int, Type] = Map[Int, Type]{}
    types.set(1, listInt)
    types.set(2, UnitType)
    types.set(3, UnitType)
    val g = newGenerator(controlCheckerWithNodeTypes(types))
    match generateStmtNode(g, forNode) {
        None => assertMsg(false, "expected for-in list stmt result")
        Some(r) => {
            assertMsg(!hasTerminator(r), "for-in list completes without terminator")
            assertMsg(blockNameRegistered(g, "forl_cond"), "for-list cond block registered")
            assertMsg(blockNameRegistered(g, "forl_body"), "for-list body block registered")
            assertMsg(blockNameRegistered(g, "forl_incr"), "for-list incr block registered")
            assertMsg(blockNameRegistered(g, "forl_after"), "for-list after block registered")
            assertMsg(g.forListIndexAlloca != None, "for-list index alloca recorded")
            assertMsg(g.forListBindingAlloca != None, "for-list binding alloca recorded")
            assertMsg(g.forListSizeLoad != None, "for-list size load stub")
            assertMsg(g.forListGetStub != None, "for-list get stub")
            assertMsg(g.forListCondLoad != None, "for-list cond load stub")
            assertMsg(g.forListIncrLoad != None, "for-list incr load stub")
            assertMsg(g.forListIncrStore != None, "for-list incr store stub")
            var hasN = false
            for k in g.vars.keys() {
                if k == "n" { hasN = true }
            }
            assertMsg(!hasN, "binding n not leaked after for-in list")
        }
    }
}

test fn testGenerateForMapStmt() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 30 }

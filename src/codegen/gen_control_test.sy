import (
    { Node, LoopStmtData, BlockStmtData, IfStmtData, WhileStmtData, ForStmtData, ReturnStmtData, BreakStmtData, IntLiteralData, BinaryExprData, FuncDeclData } from @ast/ast
    { Span } from @lexer/tokens
    { CheckResult, FuncType, Type, IntType, UnitType, BoolType } from @checker/types
    { newGenerator } from @codegen/generator
    { LoopCtx } from @codegen/types
    { pushLoop, popLoop, currentLoop, loopDepth, loopNeedsResultAlloca, isControlFlowStmt, isLoopStmt, isBreakOrContinue, newLoopCtx, generateStmtNode, hasTerminator } from @codegen/gen_control
    { LlvmBasicBlock, llvmI64, llvmVoid, llvmI1 } from @codegen/llvm_types
    { assertMsg } from @soyuz/testing
)

fn controlTestCheckResult() -> CheckResult = CheckResult {
    errors: [],
    warnings: [],
    nodeTypes: [],
    specializations: Map[Int, FuncType]{},
    funcVariants: Map[String, List[FuncDeclData]]{},
    testFuncs: [],
    captures: Map[Int, List[String]]{},
    synthCallArgs: Map[Int, List[Node]]{},
    curriedCalls: Map[Int, Node]{},
    typeExtensions: Map[String, Map[String, List[FuncType]]]{}
}

test fn testLoopNeedsResultAlloca() {
    assertMsg(loopNeedsResultAlloca(IntType), "Int loop needs result")
    assertMsg(!loopNeedsResultAlloca(UnitType), "Unit loop does not")
}

test fn testLoopStack() {
    val g = newGenerator(controlTestCheckResult())
    val cond = LlvmBasicBlock { handle: 1 }
    val after = LlvmBasicBlock { handle: 2 }
    assertMsg(loopDepth(g) == 0, "empty depth")
    pushLoop(g, newLoopCtx(cond, after, llvmI64()))
    assertMsg(loopDepth(g) == 1, "depth after push")
    match currentLoop(g) {
        None => assertMsg(false, "expected current loop")
        Some(ctx) => assertMsg(ctx.cond.handle == 1, "cond block")
    }
    popLoop(g)
    assertMsg(loopDepth(g) == 0, "depth after pop")
    assertMsg(currentLoop(g) == None, "no current loop")
}

test fn testIsControlFlowStmt() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 1 }
    val loopNode = Node.LoopStmt(1, span, LoopStmtData { body: Node.BlockStmt(2, span, BlockStmtData { statements: [] }) })
    assertMsg(isLoopStmt(loopNode), "loop stmt")
    assertMsg(isControlFlowStmt(loopNode), "loop is control flow")
    assertMsg(!isBreakOrContinue(loopNode), "loop is not break")
}

fn controlMapHasIntType(m: Map[Int, Type], key: Int) -> Bool {
    for k in m.keys() { if k == key { return true } }
    return false
}

fn controlCheckerWithNodeTypes(types: Map[Int, Type]) -> CheckResult {
    var maxId = 0
    for id in types.keys() {
        if id > maxId { maxId = id }
    }
    var cr = controlTestCheckResult()
    var i = 0
    loop {
        if i > maxId { break }
        if controlMapHasIntType(types, i) {
            cr.nodeTypes.append(Some(types.get(i)))
        } else {
            cr.nodeTypes.append(None)
        }
        i = i + 1
    }
    return cr
}

test fn testGenerateIfStmt() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val cond = Node.IntLiteral(1, span, IntLiteralData { value: "1" })
    val thenBranch = Node.ReturnStmt(3, span, ReturnStmtData { value: None })
    val ifNode = Node.IfStmt(4, span, IfStmtData { condition: cond, consequent: thenBranch, alternate: None })
    var types: Map[Int, Type] = Map[Int, Type]{}
    types.set(1, BoolType)
    types.set(3, UnitType)
    types.set(4, UnitType)
    val g = newGenerator(controlCheckerWithNodeTypes(types))
    match generateStmtNode(g, ifNode) {
        None => assertMsg(false, "expected if stmt result")
        Some(r) => {
            assertMsg(!hasTerminator(r), "if without return in branch still NoTerminator at if level")
        }
    }
}

test fn testGenerateReturnStmt() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 10 }
    val ret = Node.ReturnStmt(1, span, ReturnStmtData { value: None })
    var types: Map[Int, Type] = Map[Int, Type]{}
    types.set(1, UnitType)
    val g = newGenerator(controlCheckerWithNodeTypes(types))
    match generateStmtNode(g, ret) {
        None => assertMsg(false, "expected return result")
        Some(r) => assertMsg(hasTerminator(r), "return terminates")
    }
}

test fn testGenerateBreakOutsideLoop() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 5 }
    val brk = Node.BreakStmt(1, span, BreakStmtData { value: None })
    var types: Map[Int, Type] = Map[Int, Type]{}
    types.set(1, UnitType)
    val g = newGenerator(controlCheckerWithNodeTypes(types))
    assertMsg(generateStmtNode(g, brk) == None, "break outside loop fails")
}

test fn testGenerateBreakInsideLoop() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 5 }
    val brk = Node.BreakStmt(1, span, BreakStmtData { value: None })
    var types: Map[Int, Type] = Map[Int, Type]{}
    types.set(1, UnitType)
    val g = newGenerator(controlCheckerWithNodeTypes(types))
    pushLoop(g, newLoopCtx(LlvmBasicBlock { handle: 1 }, LlvmBasicBlock { handle: 2 }, llvmI64()))
    match generateStmtNode(g, brk) {
        None => assertMsg(false, "expected break inside loop")
        Some(r) => assertMsg(hasTerminator(r), "break terminates")
    }
    popLoop(g)
}

test fn testGenerateForStmt() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val iterable = Node.IntLiteral(1, span, IntLiteralData { value: "0" })
    val body = Node.BlockStmt(2, span, BlockStmtData { statements: [] })
    val forNode = Node.ForStmt(3, span, ForStmtData { binding: "x", iterable: iterable, body: body })
    var types: Map[Int, Type] = Map[Int, Type]{}
    types.set(1, IntType)
    types.set(2, UnitType)
    types.set(3, UnitType)
    val g = newGenerator(controlCheckerWithNodeTypes(types))
    match generateStmtNode(g, forNode) {
        None => assertMsg(false, "expected for stmt result")
        Some(r) => assertMsg(!hasTerminator(r), "for completes without terminator")
    }
}

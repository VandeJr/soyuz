test fn testGenerateArcNewStub() {
    val g = newGenerator(arcEmptyCheckResult())
    match generateArcNewStub(g) {
        None => assertMsg(false, "arc new stub")
        Some(_) => assertMsg(g.arcNewStub != None, "stub stored on generator")
    }
    assertMsg(arcRuntimeSymbolRegistered(g, arcRuntimeNew()), "srt_arc_new registered")
}


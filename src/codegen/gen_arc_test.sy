import (
    { Node, FuncDeclData, IdentifierData, MemberExprData } from @ast/ast
    { Span } from @lexer/tokens
    { CheckResult, Type, FuncType, ClassType, IntType } from @checker/types
    { newGenerator } from @codegen/generator
    { isArcType, arcInnerType, isArcClassType, isArcStaticNew, isArcNewCall, isArcCloneCall, isArcGetCall, isArcRefcountCall, arcRuntimeNew, arcRuntimeClone, arcRuntimeRelease, arcRuntimeGet, arcRuntimeRefcount, generateArcNewStub, generateArcCloneStub, generateArcGetStub, generateArcRefcountStub, generateArcReleaseStub, arcRuntimeSymbolRegistered, pushArcScope, ownArcVar, popArcScope, emitArcDrops } from @codegen/gen_arc
    { assertMsg } from @soyuz/testing
)

fn arcEmptyCheckResult() -> CheckResult = CheckResult {
    errors: [],
    warnings: [],
    nodeTypes: [],
    specializations: Map[Int, FuncType]{},
    funcVariants: Map[String, List[FuncDeclData]]{},
    testFuncs: [],
    captures: Map[Int, List[String]]{},
    synthCallArgs: Map[Int, List[Node]]{},
    curriedCalls: Map[Int, Node]{},
    typeExtensions: Map[String, Map[String, List[FuncType]]]{}
}

fn arcEmptyClass(name: String) -> ClassType = ClassType {
    name: name,
    fields: Map[String, Type]{},
    fieldPub: Map[String, Bool]{},
    fieldInit: Map[String, Node]{},
    methods: Map[String, List[FuncType]]{},
    methodPub: Map[String, Bool]{},
    implements: [],
    generics: ["T"]
}

test fn testIsArcType() {
    val arcClass = arcEmptyClass("Arc")
    val channelClass = arcEmptyClass("Channel")
    val arcInt = Type.Specialized(Type.Class(arcClass), [IntType])
    val channelInt = Type.Specialized(Type.Class(channelClass), [IntType])
    assertMsg(isArcType(arcInt), "Arc[Int] is arc")
    assertMsg(!isArcType(channelInt), "Channel[Int] not arc")
    assertMsg(!isArcType(IntType), "Int not arc")
}

test fn testArcInnerType() {
    val arcClass = arcEmptyClass("Arc")
    val arcInt = Type.Specialized(Type.Class(arcClass), [IntType])
    match arcInnerType(arcInt) {
        None => assertMsg(false, "Arc[Int] inner type")
        Some(t) => assertMsg(match t { Basic(name) => name == "Int", _ => false }, "inner is Int")
    }
    match arcInnerType(IntType) {
        None => assertMsg(true, "Int has no arc inner")
        Some(_) => assertMsg(false, "Int should not have inner")
    }
}

test fn testIsArcClassType() {
    val arcClass = arcEmptyClass("Arc")
    val mutexClass = arcEmptyClass("Mutex")
    assertMsg(isArcClassType(Type.Class(arcClass)), "Arc class type")
    assertMsg(!isArcClassType(Type.Class(mutexClass)), "Mutex not Arc class")
}

test fn testIsArcStaticNew() {
    assertMsg(isArcStaticNew("Arc", "new"), "Arc.new")
    assertMsg(!isArcStaticNew("Arc", "clone"), "not Arc.clone static")
    assertMsg(!isArcStaticNew("Mutex", "new"), "not Mutex.new")
}

test fn testIsArcNewCall() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val arcId = Node.Identifier(1, span, IdentifierData { name: "Arc" })
    val member = Node.MemberExpr(2, span, MemberExprData { object: arcId, property: "new" })
    assertMsg(isArcNewCall(member), "Arc.new member is arc new call")
    val channelId = Node.Identifier(3, span, IdentifierData { name: "Channel" })
    val channelMember = Node.MemberExpr(4, span, MemberExprData { object: channelId, property: "new" })
    assertMsg(!isArcNewCall(channelMember), "Channel.new not arc new")
}

test fn testIsArcCloneCall() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val arcClass = arcEmptyClass("Arc")
    val arcInt = Type.Specialized(Type.Class(arcClass), [IntType])
    val aId = Node.Identifier(1, span, IdentifierData { name: "a" })
    val cloneMember = Node.MemberExpr(2, span, MemberExprData { object: aId, property: "clone" })
    var cr = arcEmptyCheckResult()
    cr.nodeTypes.append(Some(arcInt))
    cr.nodeTypes.append(Some(arcInt))
    val g = newGenerator(cr)
    assertMsg(isArcCloneCall(cloneMember, g), "a.clone on Arc[Int]")
    val getMember = Node.MemberExpr(3, span, MemberExprData { object: aId, property: "get" })
    assertMsg(!isArcCloneCall(getMember, g), "a.get not clone")
}


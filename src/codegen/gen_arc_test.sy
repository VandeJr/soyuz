test fn testOwnArcVarAndPopScope() {
    val g = newGenerator(arcEmptyCheckResult())
    pushArcScope(g)
    ownArcVar(g, "a")
    ownArcVar(g, "b")
    val owned = popArcScope(g)
    assertMsg(owned.size() == 2, "two arc vars owned")
    assertMsg(emitArcDrops(g, owned), "emit arc drops registers release")
    assertMsg(arcRuntimeSymbolRegistered(g, arcRuntimeRelease()), "srt_arc_release registered on drop")
}

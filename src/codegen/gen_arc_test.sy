    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val arcClass = arcEmptyClass("Arc")
    val arcInt = Type.Specialized(Type.Class(arcClass), [IntType])
    val aId = Node.Identifier(1, span, IdentifierData { name: "a" })
    val getMember = Node.MemberExpr(2, span, MemberExprData { object: aId, property: "get" })
    var cr = arcEmptyCheckResult()
    cr.nodeTypes.append(Some(arcInt))
    cr.nodeTypes.append(Some(arcInt))
    val g = newGenerator(cr)
    assertMsg(isArcGetCall(getMember, g), "a.get on Arc[Int]")

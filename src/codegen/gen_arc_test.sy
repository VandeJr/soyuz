test fn testIsArcRefcountCall() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val arcClass = arcEmptyClass("Arc")
    val arcInt = Type.Specialized(Type.Class(arcClass), [IntType])
    val aId = Node.Identifier(1, span, IdentifierData { name: "a" })

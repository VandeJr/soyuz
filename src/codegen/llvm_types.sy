// Semantic LLVM type model (IR emission uses opaque handles in sibling records).

pub enum LlvmTypeKind {
    Void
    I1
    I8
    I32
    I64
    F64
    I8Ptr
    Pointer(elem: LlvmType)
    Array(elem: LlvmType, count: Int)
    Struct(name: String, fields: List[LlvmType])
}

pub record LlvmType {
    kind: LlvmTypeKind
}

pub fn llvmVoid() -> LlvmType = LlvmType { kind: LlvmTypeKind.Void }
pub fn llvmI1() -> LlvmType = LlvmType { kind: LlvmTypeKind.I1 }
pub fn llvmI8() -> LlvmType = LlvmType { kind: LlvmTypeKind.I8 }
pub fn llvmI32() -> LlvmType = LlvmType { kind: LlvmTypeKind.I32 }
pub fn llvmI64() -> LlvmType = LlvmType { kind: LlvmTypeKind.I64 }
pub fn llvmF64() -> LlvmType = LlvmType { kind: LlvmTypeKind.F64 }
pub fn llvmI8Ptr() -> LlvmType = LlvmType { kind: LlvmTypeKind.I8Ptr }

pub fn llvmPointerType(elem: LlvmType) -> LlvmType = LlvmType { kind: LlvmTypeKind.Pointer(elem) }

pub fn llvmStructType(name: String, fields: List[LlvmType]) -> LlvmType = LlvmType { kind: LlvmTypeKind.Struct(name, fields) }

pub fn llvmArrayType(elem: LlvmType, count: Int) -> LlvmType = LlvmType { kind: LlvmTypeKind.Array(elem, count) }

pub fn llvmStructFieldAt(t: LlvmType, index: Int) -> Option[LlvmType] = match t.kind {
    Struct(_, fields) => {
        if index >= fields.size() { return None }
        return Some(fields.get(index))
    }
    _ => None
}

pub fn llvmTypesEqual(a: LlvmType, b: LlvmType) -> Bool = match (a.kind, b.kind) {
    (Void, Void) => true
    (I1, I1) => true
    (I8, I8) => true
    (I32, I32) => true
    (I64, I64) => true
    (F64, F64) => true
    (I8Ptr, I8Ptr) => true
    (Pointer(ea), Pointer(eb)) => llvmTypesEqual(ea, eb)
    (Array(ea, ca), Array(eb, cb)) => ca == cb && llvmTypesEqual(ea, eb)
    (Struct(na, fa), Struct(nb, fb)) => na == nb && llvmTypeFieldListsEqual(fa, fb)
    _ => false
}

fn llvmTypeFieldListsEqual(a: List[LlvmType], b: List[LlvmType]) -> Bool {
    if a.size() != b.size() { return false }
    var i = 0
    loop {
        if i >= a.size() { break }
        if !llvmTypesEqual(a.get(i), b.get(i)) { return false }
        i = i + 1
    }
    return true
}

pub fn llvmTypeName(t: LlvmType) -> String = match t.kind {
    Void => "void"
    I1 => "i1"
    I8 => "i8"
    I32 => "i32"
    I64 => "i64"
    F64 => "f64"
    I8Ptr => "i8*"
    Pointer(elem) => "ptr_$(llvmTypeName(elem))"
    Array(elem, count) => "arr$(count)_$(llvmTypeName(elem))"
    Struct(name, _) => name
}

// LLVM IR type syntax for instruction emission (incremental; full struct defs come later).
pub fn llvmTypeIrSyntax(t: LlvmType) -> String = match t.kind {
    Void => "void"
    I1 => "i1"
    I8 => "i8"
    I32 => "i32"
    I64 => "i64"
    F64 => "double"
    I8Ptr => "i8*"
    Pointer(elem) => "$(llvmTypeIrSyntax(elem))*"
    Array(elem, count) => "[$(count) x $(llvmTypeIrSyntax(elem))]"
    Struct(name, _) => "%$(name)"
}

pub fn isHeapLlvmType(t: LlvmType) -> Bool = match t.kind {
    Pointer(elem) => match elem.kind {
        Struct(_, _) => true
        _ => false
    }
    _ => false
}

pub fn llvmTypeHasDefaultZero(t: LlvmType) -> Bool = match t.kind {
    I1 => true
    I8 => true
    I32 => true
    I64 => true
    F64 => true
    I8Ptr => true
    Pointer(_) => true
    _ => false
}

// Opaque handles for IR values (wired in later milestones).

pub record LlvmModule {
    handle: Int
}

pub record LlvmBasicBlock {
    handle: Int
}

pub record LlvmValue {
    handle: Int
}

pub record LlvmFunc {
    handle: Int
}

pub record LlvmGlobal {
    handle: Int
}

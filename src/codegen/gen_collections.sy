import (
    { Type } from @checker/types
    { Generator } from @codegen/generator
    { LlvmValue } from @codegen/llvm_types
    { legacyI64Stub } from @codegen/gen_ir
)

// collectionElemKind: 0 = Int/Char, 1 = String (for list/map to_string runtime).
pub fn collectionElemKind(t: Type) -> Int = match t {
    Basic(name) => {
        if name == "String" { return 1 }
        return 0
    }
    _ => 0
}

pub fn mapKeyIsStringKind(t: Type) -> Int = match t {
    Basic(name) => {
        if name == "String" { return 1 }
        return 0
    }
    _ => 0
}

pub fn isListOrMapType(t: Type) -> Bool = match t {
    Specialized(base, _) => match base.get(0) {
        Class(ct) => ct.name == "List" || ct.name == "Map"
        _ => false
    }
    _ => false
}

pub fn isListType(t: Type) -> Bool = match t {
    Specialized(base, params) => match base.get(0) {
        Class(ct) => ct.name == "List" && params.size() > 0
        _ => false
    }
    _ => false
}

pub fn listElemType(t: Type) -> Option[Type] = match t {
    Specialized(base, params) => match base.get(0) {
        Class(ct) => {
            if ct.name == "List" && params.size() > 0 {
                return Some(params.get(0))
            }
            return None
        }
        _ => None
    }
    _ => None
}

pub fn isMapType(t: Type) -> Bool = match t {
    Specialized(base, params) => match base.get(0) {
        Class(ct) => ct.name == "Map" && params.size() >= 2
        _ => false
    }
    _ => false
}

pub fn mapKeyType(t: Type) -> Option[Type] = match t {
    Specialized(base, params) => match base.get(0) {
        Class(ct) => {
            if ct.name == "Map" && params.size() >= 2 {
                return Some(params.get(0))
            }
            return None
        }
        _ => None
    }
    _ => None
}

pub fn mapValType(t: Type) -> Option[Type] = match t {
    Specialized(base, params) => match base.get(0) {
        Class(ct) => {
            if ct.name == "Map" && params.size() >= 2 {
                return Some(params.get(1))
            }
            return None
        }
        _ => None
    }
    _ => None
}

pub fn generateMapKeysStub(g: Generator, _mapVal: LlvmValue, mapType: Type) -> Option[LlvmValue] {
    if !isMapType(mapType) { return None }
    g.forMapKeysStub = Some(legacyI64Stub(g))
    return Some(legacyI64Stub(g))
}

pub fn generateMapValuesStub(g: Generator, _mapVal: LlvmValue, mapType: Type) -> Option[LlvmValue] {
    if !isMapType(mapType) { return None }
    g.forMapValuesStub = Some(legacyI64Stub(g))
    return Some(legacyI64Stub(g))
}

pub fn isIteratorType(t: Type) -> Bool = match t {
    Specialized(base, params) => match base.get(0) {
        Class(ct) => ct.name == "Iterator" && params.size() > 0
        _ => false
    }
    _ => false
}

pub fn iteratorElemType(t: Type) -> Option[Type] = match t {
    Specialized(base, params) => match base.get(0) {
        Class(ct) => {
            if ct.name == "Iterator" && params.size() > 0 {
                return Some(params.get(0))
            }
            return None
        }
        _ => None
    }
    _ => None
}

pub fn emitCollectionToStringStub(g: Generator, _val: LlvmValue, soyuzType: Type) -> Option[LlvmValue] {
    if !isListOrMapType(soyuzType) { return None }
    return Some(legacyI64Stub(g))
}

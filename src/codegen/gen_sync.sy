pub fn isMutexType(t: Type) -> Bool = match t {
    Specialized(base, params) => match base.get(0) {
        Class(ct) => ct.name == "Mutex" && params.size() > 0
        _ => false
    }
    _ => false
}

pub fn mutexInnerType(t: Type) -> Option[Type] = match t {
    Specialized(base, params) => match base.get(0) {
        Class(ct) => {
            if ct.name == "Mutex" && params.size() > 0 {
                return Some(params.get(0))
            }
            return None
        }
        _ => None
    }
    _ => None
}

pub fn isMutexStaticNew(typeName: String, methodName: String) -> Bool {
    return typeName == "Mutex" && methodName == "new"
}

pub fn isMutexNewCall(callee: Node) -> Bool = match callee {
    MemberExpr(_, _, memberData) => match memberData.object.get(0) {
        Identifier(_, _, idData) => isMutexStaticNew(idData.name, memberData.property)
        _ => false
    }
    _ => false
}

fn syncCheckerNodeType(g: Generator, id: Int) -> Option[Type] {
    if id >= g.check.nodeTypes.size() { return None }
    return g.check.nodeTypes.get(id)
}

pub fn isMutexInstanceMethodCall(callee: Node, g: Generator, methodName: String) -> Bool = match callee {
    MemberExpr(_, _, memberData) => {
        if memberData.property != methodName { return false }
        match syncCheckerNodeType(g, nodeId(memberData.object.get(0))) {
            None => false
            Some(t) => isMutexType(t)
        }
    }
    _ => false
}

pub fn isMutexLockCall(callee: Node, g: Generator) -> Bool {
    return isMutexInstanceMethodCall(callee, g, "lock")
}


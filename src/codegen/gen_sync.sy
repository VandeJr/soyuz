pub fn syncGuardKind(t: Type) -> Option[String] = match t {
    Specialized(base, params) => match base.get(0) {
        Class(ct) => {
            if params.size() == 0 { return None }
            match ct.name {
                "MutexGuard" => Some("mutex")
                "ReadGuard" => Some("rwlock")
                "WriteGuard" => Some("rwlock")
                _ => None
            }
        }
        _ => None
    }
    _ => None
}

pub fn syncGuardValueAccess(g: Generator, data: MemberExprData) -> Option[String] {
    if data.property != "value" { return None }
    match syncCheckerNodeType(g, nodeId(data.object.get(0))) {
        None => None
        Some(t) => syncGuardKind(t)
    }
}

pub fn syncGuardUnlockFn(t: Type) -> Option[String] = match t {
    Specialized(base, _) => match base.get(0) {
        Class(ct) => {
            if ct.name == "MutexGuard" { return Some(mutexRuntimeUnlock()) }
            if ct.name == "ReadGuard" || ct.name == "WriteGuard" { return Some(rwlockRuntimeUnlock()) }
            return None
        }
        _ => None
    }
    _ => None
}

fn syncGuardRuntimeGet(kind: String) -> String {
    if kind == "mutex" { return mutexGuardRuntimeGet() }
    return rwlockGuardRuntimeGet()
}

fn syncGuardRuntimeSet(kind: String) -> String {
    if kind == "mutex" { return mutexGuardRuntimeSet() }
    return rwlockGuardRuntimeSet()
}

fn registerSyncRuntimeSymbol(g: Generator, symbol: String) {
    var found = false
    for s in g.syncRuntimeSymbols {
        if s == symbol { found = true }
    }
    if !found {
        var syms = g.syncRuntimeSymbols
        syms.append(symbol)
        g.syncRuntimeSymbols = syms
    }
}

pub fn syncRuntimeSymbolRegistered(g: Generator, symbol: String) -> Bool {
    for s in g.syncRuntimeSymbols {
        if s == symbol { return true }
    }
    return false
}

pub fn generateMutexNewStub(g: Generator) -> Option[LlvmValue] {
    registerSyncRuntimeSymbol(g, mutexRuntimeNew())
    val stub = legacyI64Stub(g)
    g.mutexNewStub = Some(stub)
    return Some(stub)
}

pub fn generateMutexLockStub(g: Generator) -> Option[LlvmValue] {
    registerSyncRuntimeSymbol(g, mutexRuntimeLock())
    val stub = legacyI64Stub(g)
    g.mutexLockStub = Some(stub)
    return Some(stub)
}

pub fn generateSyncGuardReadStub(g: Generator, kind: String) -> Option[LlvmValue] {
    registerSyncRuntimeSymbol(g, syncGuardRuntimeGet(kind))
    val stub = legacyI64Stub(g)
    g.syncGuardReadStub = Some(stub)
    g.syncGuardLastKind = Some(kind)
    return Some(stub)
}


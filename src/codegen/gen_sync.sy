import (
    { Node, MemberExprData } from @ast/ast
    { nodeId } from @ast/ast_helpers
    { Type } from @checker/types
    { Generator } from @codegen/generator
    { SyncGuardEntry } from @codegen/types
    { LlvmValue } from @codegen/llvm_types
    { legacyI64Stub } from @codegen/gen_ir
)

pub fn mutexRuntimeNew() -> String {
    return "srt_mutex_new"
}

pub fn mutexRuntimeLock() -> String {
    return "srt_mutex_lock"
}

pub fn mutexRuntimeUnlock() -> String {
    return "srt_mutex_unlock"
}

pub fn mutexGuardRuntimeGet() -> String {
    return "srt_mutex_guard_get"
}

pub fn mutexGuardRuntimeSet() -> String {
    return "srt_mutex_guard_set"
}

pub fn rwlockGuardRuntimeGet() -> String {
    return "srt_rwlock_guard_get"
}

pub fn rwlockGuardRuntimeSet() -> String {
    return "srt_rwlock_guard_set"
}

pub fn rwlockRuntimeNew() -> String {
    return "srt_rwlock_new"
}

pub fn rwlockRuntimeRead() -> String {
    return "srt_rwlock_read"
}

pub fn rwlockRuntimeWrite() -> String {
    return "srt_rwlock_write"
}

pub fn rwlockRuntimeUnlock() -> String {
    return "srt_rwlock_unlock"
}

pub fn atomicRuntimeNew() -> String {
    return "srt_atomic_new"
}

pub fn atomicRuntimeStore() -> String {
    return "srt_atomic_store"
}

pub fn atomicRuntimeLoad() -> String {
    return "srt_atomic_load"

pub fn pushSyncGuardScope(g: Generator) {
    var stack = g.syncGuardStack
    stack.append([])
    g.syncGuardStack = stack
}

pub fn ownSyncGuard(g: Generator, name: String, unlockFn: String) {
    if g.syncGuardStack.size() == 0 { return }
    var top = g.syncGuardStack.get(g.syncGuardStack.size() - 1)
    top.append(SyncGuardEntry { name: name, unlockFn: unlockFn })
    var stack = g.syncGuardStack
    stack.set(g.syncGuardStack.size() - 1, top)
    g.syncGuardStack = stack
}

fn syncStackWithoutLast(stack: List[List[SyncGuardEntry]]) -> List[List[SyncGuardEntry]] {
    var next: List[List[SyncGuardEntry]] = []
    var index = 0
    for item in stack {
        if index + 1 < stack.size() { next.append(item) }
        index = index + 1
    }
    return next
}

pub fn popSyncGuardScope(g: Generator) -> List[SyncGuardEntry] {
    if g.syncGuardStack.size() == 0 { return [] }
    val owned = g.syncGuardStack.get(g.syncGuardStack.size() - 1)
    g.syncGuardStack = syncStackWithoutLast(g.syncGuardStack)
    return owned
}

pub fn emitSyncGuardDrops(g: Generator, guards: List[SyncGuardEntry]) -> Bool {
    if guards.size() == 0 { return true }
    for entry in guards {
        registerSyncRuntimeSymbol(g, entry.unlockFn)
    }
    val stub = legacyI64Stub(g)
    g.syncGuardUnlockStub = Some(stub)
    return true
}

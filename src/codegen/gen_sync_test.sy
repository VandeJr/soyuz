test fn testIsRwLockType() {
    val rwlockClass = syncEmptyClass("RwLock")
    val mutexClass = syncEmptyClass("Mutex")
    val rwlockInt = Type.Specialized(Type.Class(rwlockClass), [IntType])
    val mutexInt = Type.Specialized(Type.Class(mutexClass), [IntType])
    assertMsg(isRwLockType(rwlockInt), "RwLock[Int] is rwlock")
    assertMsg(!isRwLockType(mutexInt), "Mutex[Int] not rwlock")
}

test fn testIsRwLockNewCall() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val rwlockId = Node.Identifier(1, span, IdentifierData { name: "RwLock" })
    val member = Node.MemberExpr(2, span, MemberExprData { object: rwlockId, property: "new" })
    assertMsg(isRwLockNewCall(member), "RwLock.new member is rwlock new call")
    val mutexId = Node.Identifier(3, span, IdentifierData { name: "Mutex" })
    val mutexMember = Node.MemberExpr(4, span, MemberExprData { object: mutexId, property: "new" })
    assertMsg(!isRwLockNewCall(mutexMember), "Mutex.new not rwlock new")
}


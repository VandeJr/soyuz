import (
    { Node, FuncDeclData, IdentifierData, MemberExprData } from @ast/ast
    { Span } from @lexer/tokens
    { CheckResult, Type, FuncType, ClassType, IntType } from @checker/types
    { newGenerator } from @codegen/generator
    { isMutexType, mutexInnerType, isMutexStaticNew, isMutexNewCall, isMutexLockCall, isRwLockType, rwlockInnerType, isRwLockStaticNew, isRwLockNewCall, isRwLockReadCall, isRwLockWriteCall, isAtomicType, atomicInnerType, isAtomicStaticNew, isAtomicNewCall, isAtomicStoreCall, syncGuardKind, syncGuardValueAccess, syncGuardUnlockFn, mutexRuntimeNew, mutexRuntimeLock, mutexRuntimeUnlock, mutexGuardRuntimeGet, mutexGuardRuntimeSet, rwlockRuntimeNew, rwlockRuntimeRead, rwlockRuntimeWrite, rwlockRuntimeUnlock, atomicRuntimeNew, atomicRuntimeStore, generateMutexNewStub, generateMutexLockStub, generateRwLockNewStub, generateRwLockReadStub, generateRwLockWriteStub, generateAtomicNewStub, generateAtomicStoreStub, generateSyncGuardReadStub, generateSyncGuardWriteStub, pushSyncGuardScope, ownSyncGuard, popSyncGuardScope, emitSyncGuardDrops, syncRuntimeSymbolRegistered } from @codegen/gen_sync
    { assertMsg } from @soyuz/testing
)

fn syncEmptyCheckResult() -> CheckResult = CheckResult {
    errors: [],
    warnings: [],
    nodeTypes: [],
    specializations: Map[Int, FuncType]{},
    funcVariants: Map[String, List[FuncDeclData]]{},
    testFuncs: [],
    captures: Map[Int, List[String]]{},
    synthCallArgs: Map[Int, List[Node]]{},
    curriedCalls: Map[Int, Node]{},
    typeExtensions: Map[String, Map[String, List[FuncType]]]{}
}

fn syncEmptyClass(name: String) -> ClassType = ClassType {
    name: name,
    fields: Map[String, Type]{},
    fieldPub: Map[String, Bool]{},
    fieldInit: Map[String, Node]{},
    methods: Map[String, List[FuncType]]{},
    methodPub: Map[String, Bool]{},
    implements: [],
    generics: ["T"]
}

test fn testIsMutexType() {
    val mutexClass = syncEmptyClass("Mutex")
    val atomicClass = syncEmptyClass("Atomic")
    val mutexInt = Type.Specialized(Type.Class(mutexClass), [IntType])
    val atomicInt = Type.Specialized(Type.Class(atomicClass), [IntType])
    assertMsg(isMutexType(mutexInt), "Mutex[Int] is mutex")
    assertMsg(!isMutexType(atomicInt), "Atomic[Int] not mutex")
    assertMsg(!isMutexType(IntType), "Int not mutex")
}

test fn testMutexInnerType() {
    val mutexClass = syncEmptyClass("Mutex")
    val mutexInt = Type.Specialized(Type.Class(mutexClass), [IntType])
    match mutexInnerType(mutexInt) {
        None => assertMsg(false, "Mutex[Int] inner type")
        Some(t) => assertMsg(match t { Basic(name) => name == "Int", _ => false }, "inner is Int")
    }
    match mutexInnerType(IntType) {
        None => assertMsg(true, "Int has no mutex inner")
        Some(_) => assertMsg(false, "Int should not have inner")
    }
}

test fn testIsMutexStaticNew() {
    assertMsg(isMutexStaticNew("Mutex", "new"), "Mutex.new")
    assertMsg(!isMutexStaticNew("Mutex", "lock"), "not Mutex.lock static")
    assertMsg(!isMutexStaticNew("RwLock", "new"), "not RwLock.new")
}

test fn testIsMutexNewCall() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val mutexId = Node.Identifier(1, span, IdentifierData { name: "Mutex" })
    val member = Node.MemberExpr(2, span, MemberExprData { object: mutexId, property: "new" })
    assertMsg(isMutexNewCall(member), "Mutex.new member is mutex new call")
    val channelId = Node.Identifier(3, span, IdentifierData { name: "Channel" })
    val channelMember = Node.MemberExpr(4, span, MemberExprData { object: channelId, property: "new" })
    assertMsg(!isMutexNewCall(channelMember), "Channel.new not mutex new")
}

test fn testIsMutexLockCall() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val mutexClass = syncEmptyClass("Mutex")
    val mutexInt = Type.Specialized(Type.Class(mutexClass), [IntType])
    val mId = Node.Identifier(1, span, IdentifierData { name: "m" })
    val lockMember = Node.MemberExpr(2, span, MemberExprData { object: mId, property: "lock" })
    var cr = syncEmptyCheckResult()
    cr.nodeTypes.append(Some(mutexInt))
    cr.nodeTypes.append(Some(mutexInt))
    val g = newGenerator(cr)
    assertMsg(isMutexLockCall(lockMember, g), "m.lock on Mutex[Int]")
    val newMember = Node.MemberExpr(3, span, MemberExprData { object: mId, property: "new" })
    assertMsg(!isMutexLockCall(newMember, g), "m.new not lock")
}

test fn testGenerateMutexLockStub() {
    val g = newGenerator(syncEmptyCheckResult())
    match generateMutexLockStub(g) {
        None => assertMsg(false, "mutex lock stub")
        Some(_) => assertMsg(g.mutexLockStub != None, "stub stored on generator")
    }
    assertMsg(syncRuntimeSymbolRegistered(g, mutexRuntimeLock()), "srt_mutex_lock registered")
}

test fn testSyncGuardKind() {
    val guardClass = syncEmptyClass("MutexGuard")
    val guardInt = Type.Specialized(Type.Class(guardClass), [IntType])
    match syncGuardKind(guardInt) {
        None => assertMsg(false, "MutexGuard[Int] kind")
        Some(k) => assertMsg(k == "mutex", "mutex guard kind")
    }
    val readClass = syncEmptyClass("ReadGuard")
    val readInt = Type.Specialized(Type.Class(readClass), [IntType])
    match syncGuardKind(readInt) {
        None => assertMsg(false, "ReadGuard[Int] kind")
        Some(k) => assertMsg(k == "rwlock", "rwlock guard kind")
    }
}

test fn testSyncGuardValueAccess() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val guardClass = syncEmptyClass("MutexGuard")
    val guardInt = Type.Specialized(Type.Class(guardClass), [IntType])
    val guardId = Node.Identifier(1, span, IdentifierData { name: "guard" })
    val valueMember = Node.MemberExpr(2, span, MemberExprData { object: guardId, property: "value" })
    var cr = syncEmptyCheckResult()
    cr.nodeTypes.append(Some(guardInt))
    cr.nodeTypes.append(Some(guardInt))
    val g = newGenerator(cr)
    match syncGuardValueAccess(g, MemberExprData { object: guardId, property: "value" }) {
        None => assertMsg(false, "guard.value access")
        Some(k) => assertMsg(k == "mutex", "mutex guard value")
    }
    val otherMember = Node.MemberExpr(3, span, MemberExprData { object: guardId, property: "other" })
    assertMsg(syncGuardValueAccess(g, MemberExprData { object: guardId, property: "other" }) == None, "not value property")
}

test fn testGenerateSyncGuardReadStub() {
    val g = newGenerator(syncEmptyCheckResult())
    match generateSyncGuardReadStub(g, "mutex") {
        None => assertMsg(false, "sync guard read stub")
        Some(_) => assertMsg(g.syncGuardReadStub != None, "read stub stored")

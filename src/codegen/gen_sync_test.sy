test fn testIsRwLockWriteCall() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val rwlockClass = syncEmptyClass("RwLock")
    val rwlockInt = Type.Specialized(Type.Class(rwlockClass), [IntType])
    val rwId = Node.Identifier(1, span, IdentifierData { name: "rw" })
    val writeMember = Node.MemberExpr(2, span, MemberExprData { object: rwId, property: "write" })
    var cr = syncEmptyCheckResult()
    cr.nodeTypes.append(Some(rwlockInt))
    cr.nodeTypes.append(Some(rwlockInt))
    val g = newGenerator(cr)
    assertMsg(isRwLockWriteCall(writeMember, g), "rw.write on RwLock[Int]")
    assertMsg(!isRwLockWriteCall(Node.MemberExpr(3, span, MemberExprData { object: rwId, property: "read" }), g), "rw.read not write")
}


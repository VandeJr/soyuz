test fn testIsAtomicType() {
    val atomicClass = syncEmptyClass("Atomic")
    val atomicInt = Type.Specialized(Type.Class(atomicClass), [IntType])
    assertMsg(isAtomicType(atomicInt), "Atomic[Int] is atomic")
    assertMsg(!isAtomicType(IntType), "Int not atomic")
}

test fn testIsAtomicNewCall() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val atomicId = Node.Identifier(1, span, IdentifierData { name: "Atomic" })
    val member = Node.MemberExpr(2, span, MemberExprData { object: atomicId, property: "new" })
    assertMsg(isAtomicNewCall(member), "Atomic.new member is atomic new call")
    val mutexId = Node.Identifier(3, span, IdentifierData { name: "Mutex" })
    val mutexMember = Node.MemberExpr(4, span, MemberExprData { object: mutexId, property: "new" })
    assertMsg(!isAtomicNewCall(mutexMember), "Mutex.new not atomic new")
}

test fn testIsAtomicStoreCall() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val atomicClass = syncEmptyClass("Atomic")
    val atomicInt = Type.Specialized(Type.Class(atomicClass), [IntType])
    val aId = Node.Identifier(1, span, IdentifierData { name: "a" })
    val storeMember = Node.MemberExpr(2, span, MemberExprData { object: aId, property: "store" })
    var cr = syncEmptyCheckResult()
    cr.nodeTypes.append(Some(atomicInt))
    cr.nodeTypes.append(Some(atomicInt))
    val g = newGenerator(cr)
    assertMsg(isAtomicStoreCall(storeMember, g), "a.store on Atomic[Int]")
    val loadMember = Node.MemberExpr(3, span, MemberExprData { object: aId, property: "load" })
    assertMsg(!isAtomicStoreCall(loadMember, g), "a.load not store")
}


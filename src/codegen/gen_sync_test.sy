test fn testSyncGuardUnlockFn() {
    val guardClass = syncEmptyClass("MutexGuard")
    val readClass = syncEmptyClass("ReadGuard")
    val writeClass = syncEmptyClass("WriteGuard")
    val guardInt = Type.Specialized(Type.Class(guardClass), [IntType])
    val readInt = Type.Specialized(Type.Class(readClass), [IntType])
    val writeInt = Type.Specialized(Type.Class(writeClass), [IntType])
    match syncGuardUnlockFn(guardInt) {
        None => assertMsg(false, "MutexGuard unlock fn")
        Some(unlockName) => assertMsg(unlockName == mutexRuntimeUnlock(), "mutex unlock")
    }
    match syncGuardUnlockFn(readInt) {
        None => assertMsg(false, "ReadGuard unlock fn")
        Some(unlockName) => assertMsg(unlockName == rwlockRuntimeUnlock(), "rwlock unlock for read")
    }
    match syncGuardUnlockFn(writeInt) {
        None => assertMsg(false, "WriteGuard unlock fn")
        Some(unlockName) => assertMsg(unlockName == rwlockRuntimeUnlock(), "rwlock unlock for write")
    }
    assertMsg(match syncGuardUnlockFn(IntType) { None => true, Some(_) => false }, "Int has no unlock fn")
}

test fn testEmitSyncGuardDrops() {
    val g = newGenerator(syncEmptyCheckResult())
    pushSyncGuardScope(g)
    ownSyncGuard(g, "guard", mutexRuntimeUnlock())
    val owned = popSyncGuardScope(g)
    assertMsg(emitSyncGuardDrops(g, owned), "emit sync guard drops")
    assertMsg(g.syncGuardUnlockStub != None, "unlock stub stored")
    assertMsg(syncRuntimeSymbolRegistered(g, mutexRuntimeUnlock()), "srt_mutex_unlock registered")
    assertMsg(emitSyncGuardDrops(g, []), "empty guard list ok")
}


test fn testGenerateChannelTryRecvStub() {
    val g = newGenerator(channelEmptyCheckResult())
    match generateChannelRecvStub(g, true) {
        None => assertMsg(false, "channel tryRecv stub")
        Some(_) => {
            assertMsg(g.channelRecvTryMode, "tryRecv mode flag")
            assertMsg(g.channelRecvPhiResult != None, "phi result stored")
        }
    }
    assertMsg(channelRuntimeSymbolRegistered(g, channelRuntimeTryRecv()), "srt_chan_try_recv registered")
}

test fn testGenerateChannelRecvStub() {
    val g = newGenerator(channelEmptyCheckResult())
    match generateChannelRecvStub(g, false) {
        None => assertMsg(false, "channel recv stub")
        Some(_) => {
            assertMsg(g.channelRecvPhiResult != None, "phi result stored")
            assertMsg(g.channelRecvOutAlloca != None, "out alloca stored")
            assertMsg(g.channelRecvSomeResult != None, "some branch result")
            assertMsg(g.channelRecvNoneResult != None, "none branch result")
        }
    }
    assertMsg(channelRuntimeSymbolRegistered(g, channelRuntimeRecv()), "srt_chan_recv registered")
    assertMsg(blockNameRegistered(g, chanSomeBlockName()), "chan_some block")
    assertMsg(blockNameRegistered(g, chanNoneBlockName()), "chan_none block")
    assertMsg(blockNameRegistered(g, chanMergeBlockName()), "chan_merge block")
}


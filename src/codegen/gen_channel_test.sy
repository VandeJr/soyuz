test fn testGenerateChannelIsClosedStub() {
    val g = newGenerator(channelEmptyCheckResult())
    match generateChannelIsClosedStub(g) {
        None => assertMsg(false, "channel isClosed stub")
        Some(_) => assertMsg(g.channelIsClosedStub != None, "stub stored on generator")
    }
    assertMsg(channelRuntimeSymbolRegistered(g, channelRuntimeIsClosed()), "srt_chan_is_closed registered")
}


    val channelClass = channelEmptyClass("Channel")
    val channelInt = Type.Specialized([Type.Class(channelClass)], [IntType])
    val chId = Node.Identifier(1, span, IdentifierData { name: "ch" })
    val recvMember = Node.MemberExpr(2, span, MemberExprData { object: [chId], property: "recv" })
    var cr = channelEmptyCheckResult()
    cr.nodeTypes.append(Some(channelInt))
    cr.nodeTypes.append(Some(channelInt))
    val g = newGenerator(cr)
    assertMsg(isChannelRecvCall(recvMember, g), "ch.recv on Channel[Int]")
    val sendMember = Node.MemberExpr(3, span, MemberExprData { object: [chId], property: "send" })
    assertMsg(!isChannelRecvCall(sendMember, g), "ch.send not recv")
}


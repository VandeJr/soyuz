test fn testSelectRecvArmCount() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    var arms: List[SelectArm] = []
    arms.append(SelectArm { span: span, binding: "msg", chanExpr: None, isDefault: false, body: [Node.IntLiteral(1, span, IntLiteralData { value: "0" })] })
    arms.append(SelectArm { span: span, binding: "", chanExpr: None, isDefault: true, body: [Node.IntLiteral(2, span, IntLiteralData { value: "1" })] })
    assertMsg(selectRecvArmCount(arms) == 1, "one recv arm")
    assertMsg(selectHasDefaultArm(arms), "has default arm")
}

test fn testExtractChannelFromRecvCall() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 20 }
    val chId = Node.Identifier(1, span, IdentifierData { name: "ch" })
    val recvMember = Node.MemberExpr(2, span, MemberExprData { object: [chId], property: "recv" })
    var args: List[Node] = []
    val recvCall = Node.CallExpr(3, span, CallExprData { callee: [recvMember], args: args })
    match extractChannelFromRecvCall(recvCall) {
        None => assertMsg(false, "recv call extracts channel")
        Some(obj) => assertMsg(match obj { Identifier(_, _, idData) => idData.name == "ch", _ => false }, "channel identifier")
    }
}

test fn testGenerateSelectStubBlocking() {
    val g = newGenerator(channelEmptyCheckResult())
    match generateSelectStub(g, 2, false) {
        None => assertMsg(false, "select stub blocking")
        Some(_) => {
            assertMsg(g.selectStub != None, "select stub stored")
            assertMsg(g.selectRecvArmCount == 2, "recv arm count stored")
            assertMsg(!g.selectHasDefault, "no default flag")
        }
    }
    assertMsg(channelRuntimeSymbolRegistered(g, channelRuntimeSelect()), "srt_select registered")
    assertMsg(selectBlockNamesRegistered(g, 2, false), "select arm blocks registered")
    assertMsg(blockNameRegistered(g, selectArmBlockName(0)), "sel_arm0 block")
    assertMsg(blockNameRegistered(g, selectArmBlockName(1)), "sel_arm1 block")
    assertMsg(blockNameRegistered(g, selectMergeBlockName()), "sel_merge block")
}

test fn testGenerateSelectStubWithDefault() {
    val g = newGenerator(channelEmptyCheckResult())
    match generateSelectStub(g, 1, true) {
        None => assertMsg(false, "select stub with default")
        Some(_) => assertMsg(g.selectHasDefault, "default flag stored")
    }
    assertMsg(channelRuntimeSymbolRegistered(g, channelRuntimeSelectTry()), "srt_select_try registered")
    assertMsg(selectBlockNamesRegistered(g, 1, true), "select default blocks registered")
    assertMsg(blockNameRegistered(g, selectDefaultBlockName()), "sel_default block")
}

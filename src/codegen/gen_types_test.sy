import (
    { Node, FuncDeclData, TypeExpr, GenericParam, RecordDeclData, RecordField, EnumDeclData, EnumVariant, EnumField } from @ast/ast
    { Span } from @lexer/tokens
    { CheckResult, FuncType, IntType, FloatType, BoolType, StringType, CharType, UnitType } from @checker/types
    { newGenerator } from @codegen/generator
    { mapTypeToLLVM, mapSoyuzTypeToLLVM, ensureSoyuzStringLlvmTypes, buildMangledGenericName, getOrCreateSpecializedRecord, getOrCreateSpecializedEnum, mapSoyuzTypeExprWithSub } from @codegen/gen_types
    { LlvmType, llvmI64, llvmF64, llvmI1, llvmI32, llvmVoid, llvmI8Ptr, llvmTypesEqual, llvmPointerType, llvmStructType, llvmArrayType, llvmI8, isHeapLlvmType } from @codegen/llvm_types
    { assertMsg } from @soyuz/testing
)

fn zeroSpan() -> Span = Span { line: 1, column: 1, startOffset: 0, endOffset: 0 }

fn emptyCheckResult() -> CheckResult = CheckResult {
    errors: [],
    warnings: [],
    nodeTypes: [],
    specializations: Map[Int, FuncType]{},
    funcVariants: Map[String, List[FuncDeclData]]{},
    testFuncs: [],
    captures: Map[Int, List[String]]{},
    synthCallArgs: Map[Int, List[Node]]{},
    curriedCalls: Map[Int, Node]{},
    typeExtensions: Map[String, Map[String, List[FuncType]]]{}
}

test fn testMapBasicCheckerTypes() {
    val g = newGenerator(emptyCheckResult())
    assertMsg(llvmTypesEqual(mapTypeToLLVM(g, IntType), llvmI64()), "Int -> i64")
    assertMsg(llvmTypesEqual(mapTypeToLLVM(g, FloatType), llvmF64()), "Float -> f64")
    assertMsg(llvmTypesEqual(mapTypeToLLVM(g, BoolType), llvmI1()), "Bool -> i1")
    assertMsg(llvmTypesEqual(mapTypeToLLVM(g, CharType), llvmI32()), "Char -> i32")
    assertMsg(llvmTypesEqual(mapTypeToLLVM(g, UnitType), llvmVoid()), "Unit -> void")
}

test fn testMapStringType() {
    val g = newGenerator(emptyCheckResult())
    ensureSoyuzStringLlvmTypes(g)
    val strPtr = mapTypeToLLVM(g, StringType)
    val expected = llvmPointerType(llvmStructType("SoyuzString", [llvmI64()]))
    assertMsg(llvmTypesEqual(strPtr, expected), "String -> SoyuzString*")
}

test fn testMapSoyuzTypeExprBasics() {
    val g = newGenerator(emptyCheckResult())
    assertMsg(llvmTypesEqual(mapSoyuzTypeToLLVM(g, Some(TypeExpr.Named(0, zeroSpan(), "Int"))), llvmI64()), "TypeExpr Int")
    assertMsg(llvmTypesEqual(mapSoyuzTypeToLLVM(g, Some(TypeExpr.Func(0, zeroSpan(), [], None))), llvmI8Ptr()), "TypeExpr Func")
}

test fn testMangledGenericName() {
    var sub: Map[String, LlvmType] = Map[String, LlvmType]{}
    sub.set("T", llvmI64())
    val name = buildMangledGenericName("Box", [GenericParam { name: "T", constraints: [] }], sub)
    assertMsg(name == "Box__i64", "mangled generic record name")
}

test fn testSpecializedRecord() {
    val g = newGenerator(emptyCheckResult())
    val decl = RecordDeclData {
        isPub: true,
        name: "Box",
        generics: [GenericParam { name: "T", constraints: [] }],
        fields: [RecordField { span: zeroSpan(), name: "value", typeExpr: TypeExpr.Named(0, zeroSpan(), "T") }]
    }
    var sub: Map[String, LlvmType] = Map[String, LlvmType]{}
    sub.set("T", llvmI64())
    val si = getOrCreateSpecializedRecord(g, decl, sub)
    val expected = llvmStructType("Box__i64", [llvmI64()])
    assertMsg(llvmTypesEqual(si.typ, expected), "specialized record struct type")
    var hasCached = false
    for k in g.structs.keys() {
        if k == "Box__i64" { hasCached = true }
    }
    assertMsg(hasCached, "specialized record cached")
}

test fn testIsHeapLlvmType() {
    val heap = llvmPointerType(llvmStructType("Point", [llvmI64(), llvmI64()]))
    val plain = llvmPointerType(llvmI64())
    assertMsg(isHeapLlvmType(heap), "ptr to struct is heap")
    assertMsg(!isHeapLlvmType(plain), "ptr to int is not heap")
    assertMsg(!isHeapLlvmType(llvmI64()), "i64 is not heap")
}

test fn testMapSoyuzTypeExprWithSub() {
    val g = newGenerator(emptyCheckResult())
    var sub: Map[String, LlvmType] = Map[String, LlvmType]{}
    sub.set("T", llvmF64())
    val te = TypeExpr.Named(0, zeroSpan(), "T")
    assertMsg(llvmTypesEqual(mapSoyuzTypeExprWithSub(g, te, sub), llvmF64()), "type param substitution")
}

    match generateExprNode(g, call) {
        None => assertMsg(false, "expected Circulo(5.0) enum constructor codegen")
        Some(r) => {
            assertMsg(llvmTypesEqual(r.llvmType, mapTypeToLLVM(g, formaType)), "Circulo(5.0) returns Forma")
            match g.constructorTagLoad {
                None => assertMsg(false, "enum constructor stores tag stub")
                Some(v) => assertMsg(v.handle > 0, "tag load handle")
            }
            match g.constructorPayloadPtr {

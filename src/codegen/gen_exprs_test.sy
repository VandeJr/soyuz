    types.set(4, StringType)
    types.set(5, StringType)
    types.set(6, StringType)
    types.set(7, IntType)
    val g = newGenerator(checkerWithNodeTypes(types))
    match generateExprNode(g, node) {
        None => assertMsg(false, "expected match when guard codegen")
        Some(_) => {
            assertMsg(blockNameRegistered(g, "match_arm_0_pattern_ok"), "match_arm_0_pattern_ok block")
            assertMsg(blockNameRegistered(g, "match_arm_0_body"), "guard pass targets body block")
            assertMsg(blockNameRegistered(g, "match_arm_0_next"), "guard fail targets next block")
            match g.matchGuardCondValue {
                None => assertMsg(false, "match guard condition value stub")
                Some(v) => assertMsg(v.handle > 0, "guard cond br uses generated condition stub")
            }
        }
    }
}

test fn testGenerateMatchExprCreatesBlocks() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 40 }
    val subject = Node.IntLiteral(1, span, IntLiteralData { value: "10" })
    val guardCond = Node.IntLiteral(7, span, IntLiteralData { value: "1" })
    val negBody = Node.StringLiteral(4, span, StringLiteralData { value: "neg" })
    val posBody = Node.StringLiteral(5, span, StringLiteralData { value: "pos" })
    val guardedArm = MatchArm {
        span: span,
        pattern: Pattern.Binding(2, span, "n"),
        guard: Some(guardCond),
        body: negBody
    }
    val catchallArm = MatchArm {
        span: span,
        pattern: Pattern.Wildcard(3, span),
        guard: None,
        body: posBody
    }
    val data = MatchExprData { subject: subject, arms: [guardedArm, catchallArm] }
    val node = Node.MatchExpr(6, span, data)
    var types: Map[Int, Type] = Map[Int, Type]{}
    types.set(1, IntType)
    types.set(4, StringType)
    types.set(5, StringType)
    types.set(6, StringType)
    types.set(7, IntType)
    val g = newGenerator(checkerWithNodeTypes(types))
    match generateExprNode(g, node) {
        None => assertMsg(false, "expected match expr with blocks")
        Some(_) => {
            assertMsg(blockNameRegistered(g, "match_merge"), "merge block registered")
            assertMsg(blockNameRegistered(g, "match_arm_0_pattern_ok"), "first arm pattern ok block")
            assertMsg(blockNameRegistered(g, "match_arm_0_body"), "first arm body block")
            assertMsg(blockNameRegistered(g, "match_arm_0_next"), "guarded arm fail block")
            assertMsg(blockNameRegistered(g, "match_arm_1_next"), "second arm next block")
            assertMsg(matchPhiIncomingCount(g) == 3, "arm values plus fallthrough phi incomings")
            match g.matchPhiResult {
                None => assertMsg(false, "match phi result stub")
                Some(phi) => assertMsg(phi.handle > 0, "phi result handle at merge")
            }
        }
    }
}

test fn testGenerateMatchExprRestoresBindingVarsBetweenArms() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 40 }
    val subject = Node.IntLiteral(1, span, IntLiteralData { value: "10" })
    val bindingBody = Node.IntLiteral(4, span, IntLiteralData { value: "1" })
    val catchallBody = Node.IntLiteral(5, span, IntLiteralData { value: "2" })
    val bindingArm = MatchArm {
        span: span,
        pattern: Pattern.Binding(2, span, "n"),
        guard: None,
        body: bindingBody
    }
    val catchallArm = MatchArm {
        span: span,
        pattern: Pattern.Wildcard(3, span),
        guard: None,
        body: catchallBody
    }
    val data = MatchExprData { subject: subject, arms: [bindingArm, catchallArm] }
    val node = Node.MatchExpr(6, span, data)
    var types: Map[Int, Type] = Map[Int, Type]{}
    types.set(1, IntType)
    types.set(4, IntType)
    types.set(5, IntType)
    types.set(6, IntType)
    val g = newGenerator(checkerWithNodeTypes(types))
    match generateExprNode(g, node) {
        None => assertMsg(false, "expected match expr")
        Some(_) => {
            var hasN = false
            for k in g.vars.keys() {
                if k == "n" { hasN = true }
            }
            assertMsg(!hasN, "binding n not leaked after arms")
        }
    }
}

fn channelTestClass(name: String) -> ClassType = ClassType {
    name: name,
    fields: Map[String, Type]{},
    fieldPub: Map[String, Bool]{},
    fieldInit: Map[String, Node]{},
    methods: Map[String, List[FuncType]]{},
    methodPub: Map[String, Bool]{},
    implements: [],
    generics: ["T"]
}


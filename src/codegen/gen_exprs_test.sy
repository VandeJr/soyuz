import (
    { Node, FuncDeclData, IntLiteralData, FloatLiteralData, BinaryExprData, UnaryExprData, CharLiteralData, StringLiteralData, IdentifierData, CallExprData, IndexExprData, VarDeclData, AssignExprData, VarKind, MatchExprData, MatchArm, Pattern, LiteralPatternValue, EnumDeclData, EnumVariant, EnumField, TypeExpr, MemberExprData, RecordLiteralData, RecordLiteralField, RecordField, RecordDeclData, RecordPatternField } from @ast/ast
    { Span } from @lexer/tokens
    { CheckResult, FuncType, Type, IntType, CharType, StringType, UnitType, BoolType, EnumType, ClassType } from @checker/types
    { newGenerator } from @codegen/generator
    { ConstValue, parseIntLiteralText, evalConstExpr, evalIntBinaryOp, isArithmeticBinaryOp, isUnaryOp, typeConstantNames, generateExprNode, isLiteralNode, isIdentifierNode, isCallNode, isIndexNode, isUnaryNode, isVarDeclNode, isAssignNode, isMatchNode, literalPatternValueOk, constFromLiteralPatternValue } from @codegen/gen_exprs
    { generateLiteralPatternValue } from @codegen/gen_patterns
    { generateEnumDecl, enumVariantTag, generateRecordDecl } from @codegen/gen_structs
    { blockNameRegistered, matchPhiIncomingCount } from @codegen/gen_ir
    { mapTypeToLLVM } from @codegen/gen_types
    { llvmI64, llvmI32, llvmTypesEqual } from @codegen/llvm_types
    { channelRuntimeNew, channelRuntimeSend, channelRuntimeRecv, channelRuntimeTryRecv, channelRuntimeClose, channelRuntimeIsClosed, channelRuntimeSymbolRegistered, chanSomeBlockName, chanNoneBlockName } from @codegen/gen_channel
    { mutexRuntimeNew, mutexRuntimeLock, mutexGuardRuntimeGet, mutexGuardRuntimeSet, rwlockRuntimeNew, rwlockRuntimeRead, syncRuntimeSymbolRegistered } from @codegen/gen_sync
    { arcRuntimeNew, arcRuntimeClone, arcRuntimeGet, arcRuntimeRefcount, arcRuntimeSymbolRegistered } from @codegen/gen_arc
    { taskRuntimeEnqueue, taskRuntimeAwait, listRuntimeNew, listRuntimeAppend, gatherRuntimeSymbolRegistered, gatherBlockNamesRegistered } from @codegen/gen_gather
    { assertMsg } from @soyuz/testing
)

test fn testParseIntLiteralText() {
    assertMsg(parseIntLiteralText("42") == Some(42), "parse 42")
    assertMsg(parseIntLiteralText("-7") == Some(-7), "parse -7")
    assertMsg(parseIntLiteralText("0") == Some(0), "parse 0")
    assertMsg(parseIntLiteralText("") == None, "empty")
}

test fn testEvalIntBinaryOp() {
    assertMsg(evalIntBinaryOp("+", 10, 5) == Some(15), "10+5")
    assertMsg(evalIntBinaryOp("*", 10, 5) == Some(50), "10*5")
    assertMsg(evalIntBinaryOp("/", 10, 0) == None, "div by zero")
}

test fn testEvalConstUnaryOp() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 3 }
    val inner = Node.IntLiteral(1, span, IntLiteralData { value: "7" })
    val node = Node.UnaryExpr(2, span, UnaryExprData { operator: "-", operand: inner })
    match evalConstExpr(node) {
        Some(IntVal(v)) => assertMsg(v == -7, "-7")
        _ => assertMsg(false, "expected IntVal -7")
    }
    assertMsg(isUnaryOp("-"), "minus is unary")
}

test fn testEvalConstExprMath() {
    val left = Node.IntLiteral(1, Span { line: 1, column: 1, startOffset: 0, endOffset: 2 }, IntLiteralData { value: "10" })
    val right = Node.IntLiteral(2, Span { line: 1, column: 4, startOffset: 3, endOffset: 4 }, IntLiteralData { value: "5" })
    val node = Node.BinaryExpr(3, Span { line: 1, column: 1, startOffset: 0, endOffset: 4 }, BinaryExprData { operator: "+", left: left, right: right })
    match evalConstExpr(node) {
        Some(IntVal(v)) => assertMsg(v == 15, "(10+5) const fold")
        _ => assertMsg(false, "expected IntVal")
    }
}

test fn testTypeConstantNames() {
    val names = typeConstantNames()
    assertMsg(names.get("IntType") == "Int", "IntType maps to Int")
    assertMsg(isArithmeticBinaryOp("+"), "plus is arithmetic")
}

test fn testLiteralPatternValueOk() {
    assertMsg(literalPatternValueOk(LiteralPatternValue.Int("42")), "int literal ok")
    assertMsg(!literalPatternValueOk(LiteralPatternValue.Int("")), "empty int invalid")
    assertMsg(literalPatternValueOk(LiteralPatternValue.Bool(true)), "bool literal ok")
}

test fn testGenerateLiteralPatternValue() {
    val g = newGenerator(exprTestCheckResult())
    val handlesBefore = g.valueHandleCounter
    match generateLiteralPatternValue(g, LiteralPatternValue.Int("7")) {
        None => assertMsg(false, "expected int pattern value")
        Some(v) => assertMsg(v.handle > handlesBefore, "pattern literal value handle")
    }
    match constFromLiteralPatternValue(LiteralPatternValue.Int("7")) {
        None => assertMsg(false, "expected const from pattern int")
        Some(cv) => match cv {
            IntVal(n) => assertMsg(n == 7, "pattern int const value")
            _ => assertMsg(false, "expected int const")
        }
    }
}

fn exprTestCheckResult() -> CheckResult = CheckResult {
    errors: [],
    warnings: [],
    nodeTypes: [],
    specializations: Map[Int, FuncType]{},
    funcVariants: Map[String, List[FuncDeclData]]{},
    testFuncs: [],
    captures: Map[Int, List[String]]{},
    synthCallArgs: Map[Int, List[Node]]{},
    curriedCalls: Map[Int, Node]{},
    typeExtensions: Map[String, Map[String, List[FuncType]]]{}
}

fn checkerWithNodeType(id: Int, t: Type) -> CheckResult {
    var cr = exprTestCheckResult()
    var i = 0
    loop {
        if i > id { break }
        if i == id {
            cr.nodeTypes.append(Some(t))
        } else {
            cr.nodeTypes.append(None)
        }
        i = i + 1
    }
    return cr
}

fn mapHasIntType(m: Map[Int, Type], key: Int) -> Bool {
    for k in m.keys() { if k == key { return true } }
    return false
}

fn checkerWithNodeTypes(types: Map[Int, Type]) -> CheckResult {
    var maxId = 0
    for id in types.keys() {
        if id > maxId { maxId = id }
    }
    var cr = exprTestCheckResult()
    var i = 0
    loop {
        if i > maxId { break }
        if mapHasIntType(types, i) {
            cr.nodeTypes.append(Some(types.get(i)))
        } else {
            cr.nodeTypes.append(None)
        }
        i = i + 1
    }
    return cr
}

test fn testGenerateExprNodeIntLiteral() {
    val node = Node.IntLiteral(1, Span { line: 1, column: 1, startOffset: 0, endOffset: 2 }, IntLiteralData { value: "42" })
    val g = newGenerator(checkerWithNodeType(1, IntType))
    assertMsg(isLiteralNode(node), "int literal")
    match generateExprNode(g, node) {
        None => assertMsg(false, "expected expr result")
        Some(r) => {
            assertMsg(llvmTypesEqual(r.llvmType, llvmI64()), "int literal -> i64")
            match r.maybeConst {
                HasValue(IntVal(v)) => assertMsg(v == 42, "const value 42")
                _ => assertMsg(false, "expected HasValue IntVal")
            }
        }
    }
}


    val call = Node.CallExpr(4, span, CallExprData { callee: callee, args: args })
    var types: Map[Int, Type] = Map[Int, Type]{}
    types.set(1, Type.Class(arcClass))
    types.set(2, Type.Class(arcClass))
    types.set(3, IntType)
    types.set(4, arcInt)
    val g = newGenerator(checkerWithNodeTypes(types))
    match generateExprNode(g, call) {
        None => assertMsg(false, "expected Arc.new call codegen")
        Some(_) => {
            assertMsg(g.arcNewStub != None, "arc new stub stored")
            assertMsg(arcRuntimeSymbolRegistered(g, arcRuntimeNew()), "srt_arc_new registered")
        }
    }
}


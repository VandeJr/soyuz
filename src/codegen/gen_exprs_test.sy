import (
    { Node, FuncDeclData, IntLiteralData, BinaryExprData, CharLiteralData, StringLiteralData, IdentifierData, CallExprData, IndexExprData } from @ast/ast
    { Span } from @lexer/tokens
    { CheckResult, FuncType, Type, IntType, CharType, StringType } from @checker/types
    { newGenerator } from @codegen/generator
    { ConstValue, parseIntLiteralText, evalConstExpr, evalIntBinaryOp, isArithmeticBinaryOp, typeConstantNames, generateExprNode, isLiteralNode, isIdentifierNode, isCallNode, isIndexNode } from @codegen/gen_exprs
    { mapTypeToLLVM } from @codegen/gen_types
    { llvmI64, llvmI32, llvmTypesEqual } from @codegen/llvm_types
    { assertMsg } from @soyuz/testing
)

test fn testParseIntLiteralText() {
    assertMsg(parseIntLiteralText("42") == Some(42), "parse 42")
    assertMsg(parseIntLiteralText("-7") == Some(-7), "parse -7")
    assertMsg(parseIntLiteralText("0") == Some(0), "parse 0")
    assertMsg(parseIntLiteralText("") == None, "empty")
}

test fn testEvalIntBinaryOp() {
    assertMsg(evalIntBinaryOp("+", 10, 5) == Some(15), "10+5")
    assertMsg(evalIntBinaryOp("*", 10, 5) == Some(50), "10*5")
    assertMsg(evalIntBinaryOp("/", 10, 0) == None, "div by zero")
}

test fn testEvalConstExprMath() {
    val left = Node.IntLiteral(1, Span { line: 1, column: 1, startOffset: 0, endOffset: 2 }, IntLiteralData { value: "10" })
    val right = Node.IntLiteral(2, Span { line: 1, column: 4, startOffset: 3, endOffset: 4 }, IntLiteralData { value: "5" })
    val node = Node.BinaryExpr(3, Span { line: 1, column: 1, startOffset: 0, endOffset: 4 }, BinaryExprData { operator: "+", left: left, right: right })
    match evalConstExpr(node) {
        Some(IntVal(v)) => assertMsg(v == 15, "(10+5) const fold")
        _ => assertMsg(false, "expected IntVal")
    }
}

test fn testTypeConstantNames() {
    val names = typeConstantNames()
    assertMsg(names.get("IntType") == "Int", "IntType maps to Int")
    assertMsg(isArithmeticBinaryOp("+"), "plus is arithmetic")
}

fn exprTestCheckResult() -> CheckResult = CheckResult {
    errors: [],
    warnings: [],
    nodeTypes: [],
    specializations: Map[Int, FuncType]{},
    funcVariants: Map[String, List[FuncDeclData]]{},
    testFuncs: [],
    captures: Map[Int, List[String]]{},
    synthCallArgs: Map[Int, List[Node]]{},
    curriedCalls: Map[Int, Node]{},
    typeExtensions: Map[String, Map[String, List[FuncType]]]{}
}

fn checkerWithNodeType(id: Int, t: Type) -> CheckResult {
    var cr = exprTestCheckResult()
    var i = 0
    loop {
        if i > id { break }
        if i == id {
            cr.nodeTypes.append(Some(t))
        } else {
            cr.nodeTypes.append(None)
        }
        i = i + 1
    }
    return cr
}

fn mapHasIntType(m: Map[Int, Type], key: Int) -> Bool {
    for k in m.keys() { if k == key { return true } }
    return false
}

fn checkerWithNodeTypes(types: Map[Int, Type]) -> CheckResult {
    var maxId = 0
    for id in types.keys() {
        if id > maxId { maxId = id }
    }
    var cr = exprTestCheckResult()
    var i = 0
    loop {
        if i > maxId { break }
        if mapHasIntType(types, i) {
            cr.nodeTypes.append(Some(types.get(i)))
        } else {
            cr.nodeTypes.append(None)
        }
        i = i + 1
    }
    return cr
}

test fn testGenerateExprNodeIntLiteral() {
    val node = Node.IntLiteral(1, Span { line: 1, column: 1, startOffset: 0, endOffset: 2 }, IntLiteralData { value: "42" })
    val g = newGenerator(checkerWithNodeType(1, IntType))
    assertMsg(isLiteralNode(node), "int literal")
    match generateExprNode(g, node) {
        None => assertMsg(false, "expected expr result")
        Some(r) => {
            assertMsg(llvmTypesEqual(r.llvmType, llvmI64()), "int literal -> i64")
            match r.maybeConst {
                HasValue(IntVal(v)) => assertMsg(v == 42, "const value 42")
                _ => assertMsg(false, "expected HasValue IntVal")
            }
        }
    }
}

test fn testGenerateExprNodeCharLiteral() {
    val node = Node.CharLiteral(1, Span { line: 1, column: 1, startOffset: 0, endOffset: 3 }, CharLiteralData { value: 'A' })
    val g = newGenerator(checkerWithNodeType(1, CharType))
    assertMsg(isLiteralNode(node), "char literal")
    match generateExprNode(g, node) {
        None => assertMsg(false, "expected expr result")
        Some(r) => {
            assertMsg(llvmTypesEqual(r.llvmType, llvmI32()), "char literal -> i32")
            match r.maybeConst {
                HasValue(CharVal(c)) => assertMsg(c == 'A', "const char A")
                _ => assertMsg(false, "expected HasValue CharVal")
            }
        }
    }
}

test fn testGenerateExprNodeIdentifier() {
    val node = Node.Identifier(2, Span { line: 1, column: 1, startOffset: 0, endOffset: 1 }, IdentifierData { name: "x" })
    val g = newGenerator(checkerWithNodeType(2, IntType))
    assertMsg(isIdentifierNode(node), "identifier")
    match generateExprNode(g, node) {
        None => assertMsg(false, "expected expr result")
        Some(r) => {
            assertMsg(llvmTypesEqual(r.llvmType, llvmI64()), "identifier x -> i64")
            match r.maybeConst {
                NoConst => {}
                _ => assertMsg(false, "expected NoConst for identifier")
            }
        }
    }
}

test fn testGenerateExprNodeCall() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 10 }
    val arg1 = Node.IntLiteral(3, span, IntLiteralData { value: "1" })
    val arg2 = Node.IntLiteral(4, span, IntLiteralData { value: "2" })
    val callee = Node.Identifier(5, span, IdentifierData { name: "add" })
    val ft = FuncType { params: [IntType, IntType], returnType: IntType, generics: [], defaults: [], isOptional: [] }
    val call = Node.CallExpr(6, span, CallExprData { callee: callee, args: [arg1, arg2] })
    var types: Map[Int, Type] = Map[Int, Type]{}
    types.set(3, IntType)
    types.set(4, IntType)
    types.set(5, Type.Func(ft))
    types.set(6, IntType)
    val g = newGenerator(checkerWithNodeTypes(types))
    assertMsg(isCallNode(call), "call expr")
    match generateExprNode(g, call) {
        None => assertMsg(false, "expected expr result")
        Some(r) => {
            assertMsg(llvmTypesEqual(r.llvmType, llvmI64()), "call -> i64")
            match r.maybeConst {
                NoConst => {}
                _ => assertMsg(false, "expected NoConst for call")
            }
        }
    }
}

test fn testGenerateExprNodeStringLiteral() {
    val node = Node.StringLiteral(1, Span { line: 1, column: 1, startOffset: 0, endOffset: 4 }, StringLiteralData { value: "hi" })
    val g = newGenerator(checkerWithNodeType(1, StringType))
    assertMsg(isLiteralNode(node), "string literal")
    match generateExprNode(g, node) {
        None => assertMsg(false, "expected expr result")
        Some(r) => {
            assertMsg(llvmTypesEqual(r.llvmType, mapTypeToLLVM(g, StringType)), "string literal -> SoyuzString*")
            match r.maybeConst {
                HasValue(StringVal(s)) => assertMsg(s == "hi", "const string hi")
                _ => assertMsg(false, "expected HasValue StringVal")
            }
        }
    }
}

test fn testGenerateExprNodeIndexExpr() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 6 }
    val obj = Node.Identifier(1, span, IdentifierData { name: "xs" })
    val idx = Node.IntLiteral(2, span, IntLiteralData { value: "0" })
    val node = Node.IndexExpr(3, span, IndexExprData { object: obj, index: idx })
    var types: Map[Int, Type] = Map[Int, Type]{}
    types.set(1, IntType)
    types.set(2, IntType)
    types.set(3, IntType)
    val g = newGenerator(checkerWithNodeTypes(types))
    assertMsg(isIndexNode(node), "index expr")
    match generateExprNode(g, node) {
        None => assertMsg(false, "expected expr result")
        Some(r) => {
            assertMsg(llvmTypesEqual(r.llvmType, llvmI64()), "index expr -> i64")
            match r.maybeConst {
                NoConst => {}
                _ => assertMsg(false, "expected NoConst for index")
            }
        }
    }
}

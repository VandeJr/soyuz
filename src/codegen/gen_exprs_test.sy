    litFields.append(RecordLiteralField { span: span, name: "x", value: xVal })
    litFields.append(RecordLiteralField { span: span, name: "y", value: yVal })
    val node = Node.RecordLiteral(5, span, RecordLiteralData { name: "Point", typeArgs: [], fields: litFields })
    var recordFields: Map[String, Type] = Map[String, Type]{}
    recordFields.set("x", IntType)
    recordFields.set("y", IntType)
    val pointType = Type.Record("Point", recordFields, [])

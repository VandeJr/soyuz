test fn testGenerateMatchExprWithGuard() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 40 }
    val subject = Node.IntLiteral(1, span, IntLiteralData { value: "10" })
    val guardCond = Node.IntLiteral(7, span, IntLiteralData { value: "1" })
    val negBody = Node.StringLiteral(4, span, StringLiteralData { value: "neg" })
    val posBody = Node.StringLiteral(5, span, StringLiteralData { value: "pos" })
    val guardedArm = MatchArm {
        span: span,
        pattern: Pattern.Binding(2, span, "n"),
        guard: Some(guardCond),
        body: negBody
    }
    val catchallArm = MatchArm {
        span: span,
        pattern: Pattern.Wildcard(3, span),
        guard: None,
        body: posBody
    }
    val data = MatchExprData { subject: subject, arms: [guardedArm, catchallArm] }
    val node = Node.MatchExpr(6, span, data)
    var types: Map[Int, Type] = Map[Int, Type]{}
    types.set(1, IntType)
    types.set(4, StringType)
    types.set(5, StringType)
    types.set(6, StringType)
    types.set(7, IntType)
    val g = newGenerator(checkerWithNodeTypes(types))
    assertMsg(isMatchNode(node), "match expr")
    match generateExprNode(g, node) {
        None => assertMsg(false, "expected match expr result")
        Some(r) => assertMsg(llvmTypesEqual(r.llvmType, mapTypeToLLVM(g, StringType)), "match returns String")
    }
}

test fn testGenerateMatchExprEnumConstructor() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 40 }
    val subject = Node.Identifier(1, span, IdentifierData { name: "cor" })
    val body = Node.IntLiteral(4, span, IntLiteralData { value: "1" })
    val arm = MatchArm {
        span: span,
        pattern: Pattern.Constructor(2, span, "Verde", []),
        guard: None,
        body: body
    }
    val data = MatchExprData { subject: subject, arms: [arm] }
    val node = Node.MatchExpr(5, span, data)
    val corType = Type.Enum(EnumType {
        name: "Cor",
        variants: Map[String, List[Type]]{},
        variantFieldNames: Map[String, List[String]]{},
        generics: []
    })
    var types: Map[Int, Type] = Map[Int, Type]{}
    types.set(1, corType)
    types.set(4, IntType)
    types.set(5, IntType)
    val g = newGenerator(checkerWithNodeTypes(types))
    val v0 = EnumVariant { span: span, name: "Vermelho", fields: [] }
    val v1 = EnumVariant { span: span, name: "Verde", fields: [] }
    assertMsg(generateEnumDecl(g, EnumDeclData { isPub: true, name: "Cor", generics: [], variants: [v0, v1] }), "register Cor")
    match generateExprNode(g, node) {
        None => assertMsg(false, "expected enum match expr result")
        Some(r) => assertMsg(llvmTypesEqual(r.llvmType, mapTypeToLLVM(g, IntType)), "enum match returns Int")
    }
}

// Port of soyuz-go/internal/codegen/m6_enum_test.go TestM6EnumMatch (codegen block scaffolding).
test fn testM6EnumMatchCodegen() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 80 }
    val subject = Node.Identifier(1, span, IdentifierData { name: "c" })
    val body0 = Node.IntLiteral(10, span, IntLiteralData { value: "1" })
    val body1 = Node.IntLiteral(11, span, IntLiteralData { value: "2" })
    val body2 = Node.IntLiteral(12, span, IntLiteralData { value: "3" })
    val arm0 = MatchArm {
        span: span,
        pattern: Pattern.Constructor(2, span, "Vermelho", []),
        guard: None,
        body: body0
    }
    val arm1 = MatchArm {
        span: span,
        pattern: Pattern.Constructor(3, span, "Verde", []),
        guard: None,
        body: body1
    }
    val arm2 = MatchArm {
        span: span,
        pattern: Pattern.Wildcard(4, span),
        guard: None,
        body: body2
    }
    val data = MatchExprData { subject: subject, arms: [arm0, arm1, arm2] }
    val node = Node.MatchExpr(5, span, data)
    var variants: Map[String, List[Type]] = Map[String, List[Type]]{}
    variants.set("Vermelho", [])
    variants.set("Verde", [])
    variants.set("Azul", [])
    val corType = Type.Enum(EnumType {
        name: "Cor",
        variants: variants,
        variantFieldNames: Map[String, List[String]]{},
        generics: []
    })
    var types: Map[Int, Type] = Map[Int, Type]{}
    types.set(1, corType)
    types.set(5, IntType)
    types.set(10, IntType)
    types.set(11, IntType)
    types.set(12, IntType)
    val g = newGenerator(checkerWithNodeTypes(types))
    val v0 = EnumVariant { span: span, name: "Vermelho", fields: [] }
    val v1 = EnumVariant { span: span, name: "Verde", fields: [] }
    val v2 = EnumVariant { span: span, name: "Azul", fields: [] }
    assertMsg(generateEnumDecl(g, EnumDeclData { isPub: true, name: "Cor", generics: [], variants: [v0, v1, v2] }), "register Cor")
    match generateExprNode(g, node) {
        None => assertMsg(false, "expected m6 enum match codegen")
        Some(r) => {
            assertMsg(llvmTypesEqual(r.llvmType, mapTypeToLLVM(g, IntType)), "classifica returns Int")
            assertMsg(blockNameRegistered(g, "match_merge"), "match merge block")
            assertMsg(blockNameRegistered(g, "match_Vermelho_tag_cmp"), "Vermelho tag cmp block")
            assertMsg(blockNameRegistered(g, "match_Verde_tag_cmp"), "Verde tag cmp block")
            assertMsg(blockNameRegistered(g, "match_arm_0_body"), "first arm body block")
            assertMsg(blockNameRegistered(g, "match_arm_1_body"), "second arm body block")
            assertMsg(blockNameRegistered(g, "match_arm_2_body"), "wildcard arm body block")
            assertMsg(matchPhiIncomingCount(g) == 4, "three arm bodies plus fallthrough phi")
        }
    }
}

// Port of m6_enum_test.go Forma enum — match on variants with payload fields.
test fn testM6EnumWithFieldsMatchCodegen() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 80 }
    val floatType = Type.Basic("Float")
    val subject = Node.Identifier(1, span, IdentifierData { name: "f" })
    val raioBinding = Pattern.Binding(6, span, "r")
    val larguraBinding = Pattern.Binding(7, span, "w")
    val body0 = Node.Identifier(10, span, IdentifierData { name: "r" })
    val body1 = Node.Identifier(11, span, IdentifierData { name: "w" })
    val arm0 = MatchArm {
        span: span,
        pattern: Pattern.Constructor(2, span, "Circulo", [raioBinding]),
        guard: None,
        body: body0
    }
    val arm1 = MatchArm {
        span: span,
        pattern: Pattern.Constructor(3, span, "Retangulo", [larguraBinding]),
        guard: None,
        body: body1
    }
    val data = MatchExprData { subject: subject, arms: [arm0, arm1] }
    val node = Node.MatchExpr(5, span, data)
    var variants: Map[String, List[Type]] = Map[String, List[Type]]{}
    variants.set("Circulo", [floatType])
    variants.set("Retangulo", [floatType])
    val formaType = Type.Enum(EnumType {
        name: "Forma",
        variants: variants,
        variantFieldNames: Map[String, List[String]]{},
        generics: []
    })
    var types: Map[Int, Type] = Map[Int, Type]{}
    types.set(1, formaType)
    types.set(5, floatType)
    types.set(10, floatType)
    types.set(11, floatType)
    val g = newGenerator(checkerWithNodeTypes(types))
    val raioField = EnumField { name: "raio", typeExpr: TypeExpr.Named(0, span, "Float") }
    val larguraField = EnumField { name: "largura", typeExpr: TypeExpr.Named(0, span, "Float") }
    val circulo = EnumVariant { span: span, name: "Circulo", fields: [raioField] }
    val retangulo = EnumVariant { span: span, name: "Retangulo", fields: [larguraField] }
    assertMsg(generateEnumDecl(g, EnumDeclData { isPub: true, name: "Forma", generics: [], variants: [circulo, retangulo] }), "register Forma")
    match generateExprNode(g, node) {
        None => assertMsg(false, "expected m6 enum with fields match codegen")
        Some(r) => {
            assertMsg(llvmTypesEqual(r.llvmType, mapTypeToLLVM(g, floatType)), "match returns Float")
            assertMsg(blockNameRegistered(g, "match_merge"), "match merge block")
            assertMsg(blockNameRegistered(g, "match_Circulo_tag_cmp"), "Circulo tag cmp block")
            assertMsg(blockNameRegistered(g, "match_Retangulo_tag_cmp"), "Retangulo tag cmp block")
            assertMsg(blockNameRegistered(g, "match_arm_0_body"), "Circulo arm body block")
            assertMsg(blockNameRegistered(g, "match_arm_1_body"), "Retangulo arm body block")
            assertMsg(matchPhiIncomingCount(g) == 3, "two arm bodies plus fallthrough phi")
        }
    }
}

// Port of m6_enum_test.go TestM6EnumSimple — bare Vermelho zero-arg enum constructor.
test fn testM6EnumSimpleCodegen() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 40 }
    val vermelho = Node.Identifier(2, span, IdentifierData { name: "Vermelho" })
    var variants: Map[String, List[Type]] = Map[String, List[Type]]{}
    variants.set("Vermelho", [])
    variants.set("Verde", [])
    variants.set("Azul", [])
    val corType = Type.Enum(EnumType {
        name: "Cor",
        variants: variants,
        variantFieldNames: Map[String, List[String]]{},
        generics: []
    })
    val ctorType = Type.Func(FuncType {
        params: [],
        returnType: corType,
        generics: [],
        defaults: [],
        isOptional: []
    })
    var types: Map[Int, Type] = Map[Int, Type]{}
    types.set(2, ctorType)
    val g = newGenerator(checkerWithNodeTypes(types))
    val v0 = EnumVariant { span: span, name: "Vermelho", fields: [] }
    val v1 = EnumVariant { span: span, name: "Verde", fields: [] }
    val v2 = EnumVariant { span: span, name: "Azul", fields: [] }
    assertMsg(generateEnumDecl(g, EnumDeclData { isPub: true, name: "Cor", generics: [], variants: [v0, v1, v2] }), "register Cor")
    match generateExprNode(g, vermelho) {
        None => assertMsg(false, "expected Vermelho enum constructor codegen")
        Some(r) => {
            assertMsg(llvmTypesEqual(r.llvmType, mapTypeToLLVM(g, corType)), "Vermelho returns Cor")
            match g.constructorTagLoad {
                None => assertMsg(false, "enum constructor stores tag stub")
                Some(v) => assertMsg(v.handle > 0, "tag load handle")
            }
            assertMsg(g.constructorPayloadPtr == None, "zero-arg variant has no payload ptr")
        }
    }
}

// Port of m6_enum_test.go TestM6EnumWithFields — Circulo(5.0) bare constructor call.
test fn testM6EnumWithFieldsCtorCodegen() {
    val span = Span { line: 1, column: 1, startOffset: 0, endOffset: 40 }
    val floatType = Type.Basic("Float")
    val callee = Node.Identifier(2, span, IdentifierData { name: "Circulo" })
    val arg = Node.FloatLiteral(3, span, FloatLiteralData { value: "5.0" })
    val call = Node.CallExpr(4, span, CallExprData { callee: callee, args: [arg] })
    var variants: Map[String, List[Type]] = Map[String, List[Type]]{}
    variants.set("Circulo", [floatType])
    variants.set("Retangulo", [floatType])
    val formaType = Type.Enum(EnumType {
        name: "Forma",
        variants: variants,
        variantFieldNames: Map[String, List[String]]{},
        generics: []
    })
    var types: Map[Int, Type] = Map[Int, Type]{}
    types.set(3, floatType)
    types.set(4, formaType)
    val g = newGenerator(checkerWithNodeTypes(types))
    val raioField = EnumField { name: "raio", typeExpr: TypeExpr.Named(0, span, "Float") }
    val larguraField = EnumField { name: "largura", typeExpr: TypeExpr.Named(0, span, "Float") }

fn optionIntType() -> Type {
    var variants: Map[String, List[Type]] = Map[String, List[Type]]{}
    variants.set("Some", [IntType])
    variants.set("None", [])
    val optEnum = EnumType {
        name: "Option",
        variants: variants,
        variantFieldNames: Map[String, List[String]]{},
        generics: ["T"]
    }
    return Type.Specialized(Type.Enum(optEnum), [IntType])
}


import (
    { Span } from @lexer/tokens
    { Node, TypeExpr, Named, Pattern, LiteralPatternValue, FuncDeclData, VarDeclData, RecordDeclData, ClassDeclData, InterfaceDeclData, EnumDeclData, ExtendDeclData, ExternDeclData, ImportDeclData, VarKind } from @ast/ast
    { nodePos, nodeId } from @ast/ast_helpers
    { Checker, Type, FuncType, EnumType, InterfaceType, ClassType, Scope, PendingClassMethod, PendingExtendMethod, IntType, FloatType, BoolType, StringType, CharType, UnitType, Unknown, newScope, typeToString } from @checker/types
    { setNodeType, checkerErrorf } from @checker/checker
    { resolveTypeExpr, instantiateFunc, substitute } from @checker/check_generics
    { checkPattern } from @checker/check_patterns
    { isAssignable, isCompatibleFunc } from @checker/assign
    { appendTypeExtension, mapHasStrFuncList, mapHasStrType } from @checker/map_util
)

pub fn checkClassMethodBody(c: Checker, pm: PendingClassMethod) {
    if pm.fd.body == None { return }
    val parentScope = c.scope
    c.scope = newScope(Some(parentScope))
    c.scope.define("self", pm.selfType, true)
    var paramIdx = 0
    for p in pm.fd.params {
        match p.pattern {
            Binding(_, _, name) if name != "self" => {
                if paramIdx < pm.paramTypes.size() {
                    c.scope.define(name, pm.paramTypes.get(paramIdx), true)
                    paramIdx = paramIdx + 1
                }
            }
            _ => {}
        }
    }
    match pm.fd.whenGuard {
        Some(guard) => {
            val gt = c.checkNode(guard)
            if typeToString(gt) != "Bool" {
                checkerErrorf(c, nodePos(guard), "o guard 'when' deve ser Bool, encontrado $(typeToString(gt))", [])
            }
        }
        None => {}
    }
    val oldRet = c.context.returnType
    c.context.returnType = Some(pm.retType)
    if match pm.fd.body {
        Some(body) => {
            val bodyType = c.checkNode(body)
            if pm.fd.isExprBody {
                if !isAssignable(c, pm.retType, bodyType) {
                    checkerErrorf(c, nodePos(body), "incompatible return type in method $(pm.fd.name): expected $(typeToString(pm.retType)), got $(typeToString(bodyType))", [])
                }
            }
            true
        }
        None => false
    } {
        {}
    }
    c.context.returnType = oldRet
    c.scope = parentScope
}

pub fn registerFuncVariants(c: Checker, name: String, variants: List[FuncDeclData]) {
    if variants.size() == 0 { return }
    val first = variants.get(0)
    val parentScope = c.scope
    val funcScope = newScope(Some(parentScope))
    var genericNames: List[String] = []
    for g in first.generics {
        genericNames.append(g.name)
        funcScope.define(g.name, Type.TypeParam(g.name), true)
    }
    var paramTypes: List[Type] = []
    var defaults: List[Option[Node]] = []
    var isOptional: List[Bool] = []
    val oldScope = c.scope
    c.scope = funcScope
    for p in first.params {
        var pt = resolveTypeExpr(c, match p.typeExpr { Some(te) => te, None => Named(0, p.span, "Unknown") })
        if typeToString(pt) == "Unknown" { pt = inferTypeFromPattern(c, p.pattern) }
        paramTypes.append(pt)
        var optional = false
        if match p.typeExpr {
            Some(Optional(_, _, _)) => true
            _ => false
        } {
            optional = true
        }
        isOptional.append(optional)
        defaults.append(None)
        match p.defaultExpr {
            Some(d) => {
                val defaultType = c.checkNode(d)
                if !isAssignable(c, pt, defaultType) {
                    checkerErrorf(c, nodePos(d), "valor padrão incompatível: esperado $(typeToString(pt)), encontrado $(typeToString(defaultType))", [])
                }
            }
            None => {}
        }
    }
    var retType: Type = UnitType
    if match first.returnType {
        Some(rt) => { retType = resolveTypeExpr(c, rt); true }
        None => false
    } {
        {}
    }
    if first.returnType == None && first.isExprBody {
        match first.body {
            Some(body) => {
                val bodyScope = newScope(Some(funcScope))
                for i in range(0, first.params.size()) {
                    match first.params.get(i).pattern {
                        Binding(_, _, n) if i < paramTypes.size() => { bodyScope.define(n, paramTypes.get(i), true) }
                        _ => {}
                    }
                }
                c.scope = bodyScope
                retType = c.checkNode(body)
                c.inferredBodies.set(0, true)
            }
            None => {}
        }
    }
    c.scope = oldScope
    val ft = FuncType { params: paramTypes, returnType: retType, generics: genericNames, defaults: defaults, isOptional: isOptional }
    parentScope.define(name, Type.Func(ft), true)
}

pub fn inferTypeFromPattern(c: Checker, pat: Pattern) -> Type = match pat {
    Literal(_, _, value) => inferLiteralPatternType(value)
    Constructor(_, _, name, _) => match name {
        "Some" => {
            val base = resolveTypeExpr(c, Named(0, Span { line: 0, column: 0, startOffset: 0, endOffset: 0 }, "Option"))
            Type.Specialized(base, [Unknown])
        }
        "None" => {
            val base = resolveTypeExpr(c, Named(0, Span { line: 0, column: 0, startOffset: 0, endOffset: 0 }, "Option"))
            Type.Specialized(base, [Unknown])
        }
        "Ok" => {
            val base = resolveTypeExpr(c, Named(0, Span { line: 0, column: 0, startOffset: 0, endOffset: 0 }, "Result"))
            Type.Specialized(base, [Unknown])
        }
        "Err" => {
            val base = resolveTypeExpr(c, Named(0, Span { line: 0, column: 0, startOffset: 0, endOffset: 0 }, "Result"))
            Type.Specialized(base, [Unknown])
        }
        _ => match c.scope.resolve(name) {
            Some(sym) => match sym.typ {
                Func(ft) => ft.returnType
                _ => sym.typ
            }
            None => Unknown
        }
    }
    Record(_, _, name, _) => match c.scope.resolve(name) { Some(sym) => sym.typ, None => Unknown }
    _ => Unknown
}

fn inferLiteralPatternType(v: LiteralPatternValue) -> Type = match v {
    Int(_) => IntType
    Float(_) => FloatType
    String(_) => StringType
    Char(_) => CharType
    Bool(_) => BoolType
}

pub fn checkFuncVariantsBody(c: Checker, name: String, variants: List[FuncDeclData]) {
    match c.scope.resolve(name) {
        Some(sym) => match sym.typ {
            Func(ft) => {
                var hasCatchall = false
                for v in variants {
                    if v.whenGuard == None {
                        var isParamCatchall = true
                        for p in v.params {
                            if !isCatchallPattern(p.pattern) { isParamCatchall = false }
                        }
                        if isParamCatchall { hasCatchall = true }
                    }
                }
                if !hasCatchall {
                    checkerErrorf(c, Span { line: 0, column: 0, startOffset: 0, endOffset: 0 }, "função '$(name)' requer uma variante catchall sem 'when' e com parâmetros genéricos", [])
                }
                for v in variants { checkFuncDeclBody(c, v, ft) }
            }
            _ => {}
        }
        None => {}
    }
}

fn isCatchallPattern(p: Pattern) -> Bool = match p {
    Binding(_, _, _) => true
    Wildcard(_, _) => true
    _ => false
}

fn checkFuncDeclBody(c: Checker, n: FuncDeclData, expectedFt: FuncType) {
    val parentScope = c.scope
    c.scope = newScope(Some(parentScope))
    for gName in expectedFt.generics {
        c.scope.define(gName, Type.TypeParam(gName), true)
    }
    for i in range(0, n.params.size()) {
        if i < expectedFt.params.size() {
            checkPattern(c, n.params.get(i).pattern, expectedFt.params.get(i))
        }
    }
    match n.whenGuard {
        Some(guard) => {
            val gt = c.checkNode(guard)
            if typeToString(gt) != "Bool" {
                checkerErrorf(c, nodePos(guard), "o guard 'when' deve ser Bool, encontrado $(typeToString(gt))", [])
            }
        }
        None => {}
    }
    val oldRet = c.context.returnType
    c.context.returnType = Some(expectedFt.returnType)
    match c.inferredBodies.get(0) {
        Some(true) => {
            c.context.returnType = oldRet
            c.scope = parentScope
            return
        }
        _ => {}
    }
    match n.body {
        Some(body) => {
            val bodyType = c.checkNode(body)
            if n.isExprBody {
                if n.returnType == None {
                    expectedFt.returnType = bodyType
                } else {
                    if !isAssignable(c, expectedFt.returnType, bodyType) {
                        checkerErrorf(c, nodePos(body), "incompatible return type: expected $(typeToString(expectedFt.returnType)), got $(typeToString(bodyType))", [])
                    }
                }
            }
        }
        None => {}
    }
    c.context.returnType = oldRet
    c.scope = parentScope
}

pub fn checkFuncDecl(c: Checker, n: FuncDeclData, declNodeId: Int) -> Type {
    registerFuncVariants(c, n.name, [n])
    match c.scope.resolve(n.name) {
        Some(sym) => match sym.typ {
            Func(ft) => { checkFuncDeclBody(c, n, ft); sym.typ }
            _ => Unknown
        }
        None => Unknown
    }
}

pub fn checkRecordDecl(c: Checker, n: RecordDeclData) -> Type {
    val parentScope = c.scope
    c.scope = newScope(Some(parentScope))
    var genericNames: List[String] = []
    for g in n.generics {
        genericNames.append(g.name)
        c.scope.define(g.name, Type.TypeParam(g.name), true)
    }
    var fields: Map[String, Type] = Map[String, Type]{}
    for f in n.fields { fields.set(f.name, resolveTypeExpr(c, f.typeExpr)) }
    val rt = Type.Record(n.name, fields, genericNames)
    parentScope.define(n.name, rt, true)
    c.scope = parentScope
    return rt
}

pub fn checkEnumDecl(c: Checker, n: EnumDeclData) -> Type {
    val parentScope = c.scope
    c.scope = newScope(Some(parentScope))
    var genericNames: List[String] = []
    for g in n.generics {
        genericNames.append(g.name)
        c.scope.define(g.name, Type.TypeParam(g.name), true)
    }
    var variants: Map[String, List[Type]] = Map[String, List[Type]]{}
    var variantFieldNames: Map[String, List[String]] = Map[String, List[String]]{}
    val et = EnumType { name: n.name, variants: variants, variantFieldNames: variantFieldNames, generics: genericNames }
    parentScope.define(n.name, Type.Enum(et), true)
    var constructorReturn: Type = Type.Enum(et)
    if genericNames.size() > 0 {
        var tparams: List[Type] = []
        for gname in genericNames { tparams.append(Type.TypeParam(gname)) }
        constructorReturn = Type.Specialized(Type.Enum(et), tparams)
    }
    for v in n.variants {
        var fieldTypes: List[Type] = []
        var fieldNames: List[String] = []
        for f in v.fields {
            fieldTypes.append(resolveTypeExpr(c, f.typeExpr))
            fieldNames.append(f.name)
        }
        variants.set(v.name, fieldTypes)
        variantFieldNames.set(v.name, fieldNames)
        val vt = FuncType { params: fieldTypes, returnType: constructorReturn, generics: genericNames, defaults: [], isOptional: [] }
        parentScope.define(v.name, Type.Func(vt), true)
    }
    c.scope = parentScope
    return Type.Enum(et)
}

pub fn checkInterfaceDecl(c: Checker, n: InterfaceDeclData) -> Type {
    var methods: Map[String, FuncType] = Map[String, FuncType]{}
    for m in n.methods {
        var params: List[Type] = []
        for p in m.params {
            match p.pattern {
                Binding(_, _, name) if name == "self" => {}
                _ => { params.append(resolveTypeExpr(c, match p.typeExpr { Some(te) => te, None => Named(0, p.span, "Unknown") })) }
            }
        }
        val ret = match m.returnType { Some(rt) => resolveTypeExpr(c, rt), None => UnitType }
        methods.set(m.name, FuncType { params: params, returnType: ret, generics: [], defaults: [], isOptional: [] })
    }
    val it = InterfaceType { name: n.name, methods: methods }
    c.scope.define(n.name, Type.Interface(it), true)
    return Type.Interface(it)
}

pub fn checkClassDecl(c: Checker, n: ClassDeclData, declNodeId: Int) -> Type {
    val parentScope = c.scope
    c.scope = newScope(Some(parentScope))
    var genericNames: List[String] = []
    for g in n.generics {
        genericNames.append(g.name)
        c.scope.define(g.name, Type.TypeParam(g.name), true)
    }
    var fields: Map[String, Type] = Map[String, Type]{}
    var fieldPub: Map[String, Bool] = Map[String, Bool]{}
    var fieldInit: Map[String, Node] = Map[String, Node]{}
    var methods: Map[String, List[FuncType]] = Map[String, List[FuncType]]{}
    var methodPub: Map[String, Bool] = Map[String, Bool]{}
    var implements: List[InterfaceType] = []
    for itExpr in n.interfaces {
        val itType = resolveTypeExpr(c, itExpr)
        match itType {
            Interface(it) => implements.append(it)
            _ => checkerErrorf(c, Span { line: 0, column: 0, startOffset: 0, endOffset: 0 }, "$(typeToString(itType)) is not an interface", [])
        }
    }
    val ct = ClassType { name: n.name, fields: fields, fieldPub: fieldPub, fieldInit: fieldInit, methods: methods, methodPub: methodPub, implements: implements, generics: genericNames }
    parentScope.define(n.name, Type.Class(ct), true)
    for member in n.body {
        match member {
            VarDecl(_, _, vd) => {
                val ft = match vd.typeExpr { Some(te) => resolveTypeExpr(c, te), None => Unknown }
                fields.set(vd.name, ft)
                fieldPub.set(vd.name, vd.isPub)
                match vd.init {
                    Some(init) => {
                        fieldInit.set(vd.name, init)
                        val defaultType = c.checkNode(init)
                        if !isAssignable(c, ft, defaultType) {
                            checkerErrorf(c, nodePos(init), "valor padrão incompatível para campo $(vd.name): esperado $(typeToString(ft)), encontrado $(typeToString(defaultType))", [])
                        }
                    }
                    None => {}
                }
            }
            _ => {}
        }
    }
    c.currentClass = Some(ct)
    for member in n.body {
        match member {
            FuncDecl(_, _, fd) => {
                var paramTypes: List[Type] = []
                for p in fd.params {
                    match p.pattern {
                        Binding(_, _, name) if name == "self" => {}
                        _ => { paramTypes.append(resolveTypeExpr(c, match p.typeExpr { Some(te) => te, None => Named(0, p.span, "Unknown") })) }
                    }
                }
                val ret = match fd.returnType { Some(rt) => resolveTypeExpr(c, rt), None => UnitType }
                val ft = FuncType { params: paramTypes, returnType: ret, generics: [], defaults: [], isOptional: [] }
                if mapHasStrFuncList(methods, fd.name) {
                    var existing = methods.get(fd.name)
                    existing.append(ft)
                    methods.set(fd.name, existing)
                } else {
                    methods.set(fd.name, [ft])
                }
                methodPub.set(fd.name, fd.isPub)
                var selfType: Type = Type.Class(ct)
                if ct.name == "StringExtensions" { selfType = StringType }
                c.pendingClassMethods.append(PendingClassMethod { fd: fd, fdNodeId: nodeId(member), ct: ct, selfType: selfType, paramTypes: paramTypes, retType: ret, file: c.currentFile })
            }
            _ => {}
        }
    }
    for it in implements {
        for name in it.methods.keys() {
            val expectedFt = it.methods.get(name)
            if !mapHasStrFuncList(methods, name) || methods.get(name).size() == 0 {
                checkerErrorf(c, Span { line: 0, column: 0, startOffset: 0, endOffset: 0 }, "class $(n.name) does not implement method $(name) required by interface $(it.name)", [])
            } else {
                var found = false
                for actualFt in methods.get(name) {
                    if isCompatibleFunc(expectedFt, actualFt) {
                        found = true
                    }
                }
                if !found {
                    checkerErrorf(c, Span { line: 0, column: 0, startOffset: 0, endOffset: 0 }, "method signature $(name) in $(n.name) incompatible with interface $(it.name)", [])
                }
            }
        }
    }
    c.currentClass = None
    c.scope = parentScope
    return Type.Class(ct)
}

pub fn checkVarDecl(c: Checker, decl: VarDeclData) -> Type {
    var initType: Type = Unknown
    if match decl.init {
        Some(init) => { initType = c.checkNode(init); true }
        None => false
    } {
        {}
    }
    if match decl.typeExpr {
        Some(te) => {
            val expected = resolveTypeExpr(c, te)
            if typeToString(initType) != "Unknown" {
                if match decl.init {
                    Some(init) => {
                        if !isAssignable(c, expected, initType) {
                            checkerErrorf(c, nodePos(init), "incompatible type: expected $(typeToString(expected)), got $(typeToString(initType))", [])
                        }
                        true
                    }
                    None => false
                } {
                    {}
                }
            }
            initType = expected
            true
        }
        None => false
    } {
        {}
    }
    if match decl.pattern {
        Some(pat) => { checkPattern(c, pat, initType); true }
        None => false
    } {
        return initType
    }
    if decl.name != "_" {
        c.scope.define(decl.name, initType, decl.kind != VarKind.Var)
    }
    return initType
}

pub fn checkExternDecl(c: Checker, n: ExternDeclData) -> Type {
    var paramTypes: List[Type] = []
    for p in n.params { paramTypes.append(resolveTypeExpr(c, match p.typeExpr { Some(te) => te, None => Named(0, p.span, "Unknown") })) }
    val retType = match n.returnType { Some(rt) => resolveTypeExpr(c, rt), None => UnitType }
    val ft = FuncType { params: paramTypes, returnType: retType, generics: [], defaults: [], isOptional: [] }
    c.scope.define(n.name, Type.Func(ft), true)
    return Type.Func(ft)
}

pub fn checkExtendDecl(c: Checker, n: ExtendDeclData, extendNodeId: Int) -> Type {
    var selfType: Type = Unknown
    if mapHasStrType(c.extendSelfTypes, n.typeName) {
        selfType = c.extendSelfTypes.get(n.typeName)
    } else {
        match c.scope.resolve(n.typeName) {
            Some(sym) => { selfType = sym.typ }
            None => { selfType = Unknown }
        }
    }
    if typeToString(selfType) == "Unknown" {
        checkerErrorf(c, Span { line: 0, column: 0, startOffset: 0, endOffset: 0 }, "extend: tipo '$(n.typeName)' não encontrado", [])
        return Unknown
    }
    c.extendSelfTypes.set(n.typeName, selfType)
    for methodNode in n.methods {
        match methodNode {
            FuncDecl(_, _, fd) => {
                var paramTypes: List[Type] = []
                for p in fd.params {
                    match p.pattern {
                        Binding(_, _, name) if name == "self" => {}
                        _ => { paramTypes.append(match p.typeExpr { Some(te) => resolveTypeExpr(c, te), None => Unknown }) }
                    }
                }
                val ret = match fd.returnType { Some(rt) => resolveTypeExpr(c, rt), None => UnitType }
                val ft = FuncType { params: paramTypes, returnType: ret, generics: [], defaults: [], isOptional: [] }
                appendTypeExtension(c.typeExtensions, n.typeName, fd.name, ft)
                c.pendingExtendMethods.append(PendingExtendMethod { fd: fd, fdNodeId: extendNodeId, typeName: n.typeName, selfType: selfType, paramTypes: paramTypes, retType: ret, file: c.currentFile })
            }
            _ => {}
        }
    }
    return UnitType
}

pub fn checkExtendMethodBody(c: Checker, pm: PendingExtendMethod) {
    if pm.fd.body == None { return }
    val parentScope = c.scope
    c.scope = newScope(Some(parentScope))
    c.scope.define("self", pm.selfType, true)
    var paramIdx = 0
    for p in pm.fd.params {
        match p.pattern {
            Binding(_, _, name) if name != "self" => {
                if paramIdx < pm.paramTypes.size() {
                    c.scope.define(name, pm.paramTypes.get(paramIdx), true)
                    paramIdx = paramIdx + 1
                }
            }
            _ => {}
        }
    }
    val prev = c.context.returnType
    c.context.returnType = Some(pm.retType)
    if match pm.fd.body {
        Some(body) => { c.checkNode(body); true }
        None => false
    } {
        {}
    }
    c.context.returnType = prev
    c.scope = parentScope
}

fn registerModuleFunc(c: Checker, ns: ClassType, node: Node) {
    match node {
        FuncDecl(_, _, fd) => {
            if fd.isPub {
                match c.scope.resolve(fd.name) {
                    Some(sym) => match sym.typ {
                        Func(ft) => {
                            ns.methods.set(fd.name, [ft])
                            ns.methodPub.set(fd.name, true)
                        }
                        _ => {}
                    }
                    None => {}
                }
            }
        }
        ExternDecl(_, _, ed) => {
            if ed.isPub {
                match c.scope.resolve(ed.name) {
                    Some(sym) => match sym.typ {
                        Func(ft) => {
                            ns.methods.set(ed.name, [ft])
                            ns.methodPub.set(ed.name, true)
                        }
                        _ => {}
                    }
                    None => {}
                }
            }
        }
        _ => {}
    }
}

pub fn registerModuleNamespace(c: Checker, body: List[Node], imp: ImportDeclData) {
    if imp.path == "" { return }
    if imp.resolvedFiles.size() == 0 { return }
    val modName = imp.namespace
    var ns = ClassType { name: modName, fields: Map[String, Type]{}, fieldPub: Map[String, Bool]{}, fieldInit: Map[String, Node]{}, methods: Map[String, List[FuncType]]{}, methodPub: Map[String, Bool]{}, implements: [], generics: [] }
    for node in body {
        registerModuleFunc(c, ns, node)
    }
    if ns.methods.size() > 0 { c.scope.define(modName, Type.Class(ns), true) }
}

pub fn collectFileImports(c: Checker, body: List[Node]) {
    for node in body {
        match node {
            ImportDecl(_, _, _) => {}
            _ => {}
        }
    }
}

import (
    { emptyPathIndex, joinPathFile, PathIndex } from @module/paths
    { newResolverWithStdlib } from @module/resolver
    { collectProgram, collectProgramSucceeded, checkCollectedProgram } from @module/graph
    { assertMsg } from @soyuz/testing
)

fn installPreludeStubForPatternMatchingFeature(index: PathIndex, stdlibDir: String) {
    index.fileContents.set(joinPathFile(stdlibDir, "prelude.sy"), "pub interface Equals { }\nextend Int { pub fn equals(self, other: Int) -> Bool = self == other }\npub interface Error { pub fn message() -> String pub fn code() -> Int }\n")
}

pub fn defaultFeaturePatternMatchingPath() -> String = "feature-tests/pattern_matching.sy"

// Port of feature-tests/pattern_matching.sy — match subset without $(...) in embed string.
test fn testFeaturePatternMatchingTypeCheck() {
    val stdlibDir = "/tmp/stdlib"
    val entry = "/tmp/feature/pattern_matching.sy"
    var index = emptyPathIndex()
    installPreludeStubForPatternMatchingFeature(index, stdlibDir)
    index.fileContents.set(entry, "enum Operacao { Somar(a: Int, b: Int) Negativo(v: Int) }\nfn fib(n: Int) when n == 0 = 0\nfn fib(n: Int) when n == 1 = 1\nfn fib(n: Int) = fib(n - 1) + fib(n - 2)\nfn fizzBuzz(n: Int) -> String { return match (n % 3, n % 5) { (0, 0) => \"FizzBuzz\" (0, _) => \"Fizz\" (_, 0) => \"Buzz\" _ => \"n\" } }\nfn main() {\n\tval codigo = 404\n\tval descricao = match codigo { 200 => \"OK\" 404 => \"Não encontrado\" 500 => \"Erro interno\" _ => \"Desconhecido\" }\n\tprint(descricao)\n\tval status = true\n\tprint(match status { true => \"ativo\" false => \"inativo\" })\n\tval n = -5\n\tval sinal = match n { x if x < 0 => \"negativo\" x if x == 0 => \"zero\" x => \"positivo\" }\n\tprint(sinal)\n\tval neg = Operacao.Negativo(v: 7)\n\tmatch neg { Negativo(v) => print(v) Somar(a, b) => print(0) }\n\tval opt: Option[Int] = Some(42)\n\tmatch opt { Some(v) => print(v) None => print(0) }\n\tval ok: Result[Int] = Ok(10)\n\tmatch ok { Ok(v) => print(v) Err(e) => print(e.message()) }\n\tfor i in 1..=6 { print(fizzBuzz(i)) }\n\tprint(fib(8))\n}\n")
    val r = newResolverWithStdlib(entry, stdlibDir)
    val collected = collectProgram(entry, r, index)
    assertMsg(collectProgramSucceeded(collected), "collect pattern_matching feature ok")
    assertMsg(collected.files.size() >= 2, "prelude plus pattern_matching")
    val result = checkCollectedProgram(collected)
    assertMsg(result.errors.size() == 0, "feature pattern_matching type-checks")
}

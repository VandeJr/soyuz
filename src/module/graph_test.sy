import (
    { emptyPathIndex, pathBaseName } from @module/paths
    { newResolver, newResolverWithStdlib } from @module/resolver
    { collect, collectSucceeded } from @module/graph
    { assertMsg } from @soyuz/testing
)

// Port of module_test.go TestSingleFile — entry only, no imports.
test fn testCollectSingleFile() {
    val dir = "/tmp/proj"
    val entry = "/tmp/proj/main.sy"
    var index = emptyPathIndex()
    index.fileContents.set(entry, "fn hello() = \"oi\"")
    val r = newResolver(dir)
    val result = collect(entry, r, index)
    assertMsg(collectSucceeded(result), "collect ok")
    assertMsg(result.files.size() == 1, "one file")
    assertMsg(result.files.get(0) == entry, "entry file only")
}

// Port of module_test.go TestSingleFileImport — math.sy before main.sy.
test fn testCollectSingleFileImport() {
    val dir = "/tmp/proj"
    val entry = "/tmp/proj/main.sy"
    var index = emptyPathIndex()
    index.fileContents.set("/tmp/proj/math.sy", "pub fn dobrar(x: Int) = x * 2")
    index.fileContents.set(entry, "import math.{ dobrar }\nfn main() = dobrar(5)")
    val r = newResolver(dir)
    val result = collect(entry, r, index)
    assertMsg(collectSucceeded(result), "collect ok")
    assertMsg(result.files.size() == 2, "two files")
    assertMsg(pathBaseName(result.files.get(0)) == "math.sy", "math first")
    assertMsg(pathBaseName(result.files.get(1)) == "main.sy", "main last")
}

// Port of module_test.go TestCycleDetection — cyclic imports return error.
test fn testCollectCycleDetection() {
    val dir = "/tmp/proj"
    val entry = "/tmp/proj/a.sy"
    var index = emptyPathIndex()
    index.fileContents.set("/tmp/proj/a.sy", "import b.{ foo }")
    index.fileContents.set("/tmp/proj/b.sy", "import a.{ bar }")
    val r = newResolver(dir)
    val result = collect(entry, r, index)
    assertMsg(!collectSucceeded(result), "cycle should fail")
}

// Port of module_test.go TestDirectoryImport — package directory with multiple .sy files.
test fn testCollectDirectoryImport() {
    val dir = "/tmp/proj"
    val entry = "/tmp/proj/main.sy"
    var index = emptyPathIndex()
    index.fileContents.set("/tmp/proj/math/ops.sy", "pub fn dobrar(x: Int) = x * 2")
    index.fileContents.set("/tmp/proj/math/trig.sy", "pub fn cos(x: Float) = x")
    index.fileContents.set(entry, "import math.{ dobrar }\nfn main() = dobrar(3)")
    val r = newResolver(dir)
    val result = collect(entry, r, index)
    assertMsg(collectSucceeded(result), "collect ok")
    assertMsg(result.files.size() == 3, "two math files plus main")
    assertMsg(pathBaseName(result.files.get(result.files.size() - 1)) == "main.sy", "main last")
}

// Port of module_test.go TestTransitiveDependencies — base → mid → main order.
test fn testCollectTransitiveDependencies() {
    val dir = "/tmp/proj"
    val entry = "/tmp/proj/main.sy"
    var index = emptyPathIndex()
    index.fileContents.set("/tmp/proj/base.sy", "pub fn id(x: Int) = x")
    index.fileContents.set("/tmp/proj/mid.sy", "import base.{ id }\npub fn double(x: Int) = id(x) * 2")
    index.fileContents.set(entry, "import mid.{ double }\nfn main() = double(4)")
    val r = newResolver(dir)
    val result = collect(entry, r, index)
    assertMsg(collectSucceeded(result), "collect ok")
    assertMsg(result.files.size() == 3, "three files")
    assertMsg(pathBaseName(result.files.get(0)) == "base.sy", "base first")
    assertMsg(pathBaseName(result.files.get(2)) == "main.sy", "main last")
}

// Port of module_test.go TestStdlibImport — @soyuz/mock resolves from StdlibDir.
test fn testCollectStdlibImport() {
    val dir = "/tmp/app"
    val entry = "/tmp/app/main.sy"
    val stdlibDir = "/tmp/stdlib"
    var index = emptyPathIndex()
    index.fileContents.set("/tmp/stdlib/mock.sy", "pub fn assert_eq(a: Int, b: Int, name: String) {}")
    index.fileContents.set(entry, "import ( { assert_eq } from \"@soyuz/mock\" )\nfn main() { assert_eq(1, 1, \"ok\") }")
    val r = newResolverWithStdlib(entry, stdlibDir)
    val result = collect(entry, r, index)
    assertMsg(collectSucceeded(result), "collect ok")
    assertMsg(result.files.size() == 2, "mock.sy and main.sy")
}

// Port of module_test.go TestStdlibImportSemStdlibDir — fails without stdlib configured.
test fn testCollectStdlibImportNoStdlibDir() {
    val entry = "/tmp/app/main.sy"
    var index = emptyPathIndex()
    index.fileContents.set(entry, "import ( { assert_eq } from \"@soyuz/mock\" )")
    val r = newResolver("/tmp/app")
    val result = collect(entry, r, index)
    assertMsg(!collectSucceeded(result), "stdlib import without stdlib dir fails")
}

// Port of module_test.go TestUnresolvedImport — missing module returns error.
test fn testCollectUnresolvedImport() {
    val entry = "/tmp/app/main.sy"
    var index = emptyPathIndex()
    index.fileContents.set(entry, "import inexistente.{ foo }\nfn main() = foo()")
    val r = newResolver("/tmp/app")
    val result = collect(entry, r, index)
    assertMsg(!collectSucceeded(result), "unresolved import should fail")
}

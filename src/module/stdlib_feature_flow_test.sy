import (
    { emptyPathIndex, joinPathFile, PathIndex } from @module/paths
    { newResolverWithStdlib } from @module/resolver
    { collectProgram, collectProgramSucceeded, checkCollectedProgram } from @module/graph
    { assertMsg } from @soyuz/testing
)

fn installPreludeStubForFlowFeature(index: PathIndex, stdlibDir: String) {
    index.fileContents.set(joinPathFile(stdlibDir, "prelude.sy"), "pub interface Equals { }\nextend Int { pub fn equals(self, other: Int) -> Bool = self == other }\n")
}

pub fn defaultFeatureFlowPath() -> String = "feature-tests/flow.sy"

// Port of feature-tests/flow.sy — control-flow subset without $(...) in embed string.
test fn testFeatureFlowTypeCheck() {
    val stdlibDir = "/tmp/stdlib"
    val entry = "/tmp/feature/flow.sy"
    var index = emptyPathIndex()
    installPreludeStubForFlowFeature(index, stdlibDir)
    index.fileContents.set(entry, "fn fizzBuzz(n: Int) -> String {\n\treturn match (n % 3, n % 5) {\n\t\t(0, 0) => \"FizzBuzz\"\n\t\t(0, _) => \"Fizz\"\n\t\t(_, 0) => \"Buzz\"\n\t\t_ => \"n\"\n\t}\n}\nfn somarLista(nums: List[Int]) -> Int {\n\tvar total = 0\n\tfor n in nums { total = total + n }\n\treturn total\n}\nfn primeiroPositivo(nums: List[Int]) -> Option[Int] {\n\tfor n in nums { if n > 0 { return Some(n) } }\n\treturn None\n}\nfn main() {\n\tval x = 5\n\tif x > 0 { print(\"positivo\") }\n\tvar soma = 0\n\tfor i in 0..5 { soma = soma + i }\n\tvar t = 0\n\tval resultado = loop { t = t + 1 if t == 5 { break t * 10 } }\n\tprint(fizzBuzz(3))\n\tprint(somarLista([1, 2, 3]))\n\tmatch primeiroPositivo([-1, 3]) { Some(v) => print(v) None => print(0) }\n}\n")
    val r = newResolverWithStdlib(entry, stdlibDir)
    val collected = collectProgram(entry, r, index)
    assertMsg(collectProgramSucceeded(collected), "collect flow feature ok")
    assertMsg(collected.files.size() >= 2, "prelude plus flow")
    val result = checkCollectedProgram(collected)
    assertMsg(result.errors.size() == 0, "feature flow type-checks")
}

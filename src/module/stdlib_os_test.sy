import (
    { emptyPathIndex, joinPathFile, PathIndex } from @module/paths
    { newResolverWithStdlib } from @module/resolver
    { collectProgram, collectProgramSucceeded, checkCollectedProgram } from @module/graph
    { assertMsg } from @soyuz/testing
)

fn installStdlibErrorStubForOs(index: PathIndex, stdlibDir: String) {
    index.fileContents.set(joinPathFile(stdlibDir, "error.sy"), "pub interface Error { pub fn message() -> String pub fn code() -> Int }\npub class NoneError : Error { pub val msg: String pub fn message(self) -> String = self.msg pub fn code(self) -> Int = 1 }\npub fn noneError(msg: String) -> Error = NoneError { msg: msg }\n")
}

// Mirrors std/os.sy — keep in sync when porting @soyuz/os.
fn installStdlibOsStub(index: PathIndex, stdlibDir: String) {
    installStdlibErrorStubForOs(index, stdlibDir)
    index.fileContents.set(joinPathFile(stdlibDir, "os.sy"), "import ( { Error } from \"@soyuz/error\" )\nextern fn soyuz_os_getenv(name: String) -> String\nextern fn soyuz_os_has_env(name: String) -> Bool\nextern fn soyuz_os_args() -> List[String]\nextern fn soyuz_os_exec(cmd: String) -> String\nextern fn soyuz_os_has_error() -> Bool\nextern fn soyuz_os_last_error() -> String\npub class OSError : Error { pub val msg: String pub val errCode: Int = 1 pub fn message(self) -> String = self.msg pub fn code(self) -> Int = self.errCode }\npub fn getenv(name: String) -> Result[String] = Ok(soyuz_os_getenv(name))\npub fn hasEnv(name: String) -> Bool = soyuz_os_has_env(name)\npub fn args() -> List[String] = soyuz_os_args()\npub fn exec(cmd: String) -> Result[String] = Ok(soyuz_os_exec(cmd))\n")
}

pub fn defaultStdlibOsPath() -> String = "std/os.sy"

// Port of stdlib usage: @soyuz/os resolves (with @soyuz/error dep) and type-checks.
test fn testStdlibOsModuleTypeCheck() {
    val stdlibDir = "/tmp/stdlib"
    val entry = "/tmp/app/main.sy"
    var index = emptyPathIndex()
    installStdlibOsStub(index, stdlibDir)
    index.fileContents.set(entry, "import ( { args, hasEnv } from \"@soyuz/os\" )\nfn main() {\n\tprint(args().size())\n\tprint(hasEnv(\"PATH\"))\n}\n")
    val r = newResolverWithStdlib(entry, stdlibDir)
    val collected = collectProgram(entry, r, index)
    assertMsg(collectProgramSucceeded(collected), "collect os module ok")
    assertMsg(collected.files.size() == 3, "error.sy os.sy plus main")
    val result = checkCollectedProgram(collected)
    assertMsg(result.errors.size() == 0, "stdlib os module type-checks")
}

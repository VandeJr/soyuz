import (
    { ProjectMeta, ProjectConfig, defaultProjectMeta, emptyProjectConfig, parseTomlIntoConfig, resolveAliasPath, applyLibraryEntryDefault, loadProjectConfigFromContent, loadProjectConfigFromEntry } from @module/project
    { emptyPathIndex, joinPathFile } from @module/paths
    { assertMsg } from @soyuz/testing
)

// Port of project_test.go TestLoadFromTOML — parse [project] and [packages] from content.
test fn testLoadFromToml() {
    val content = "[project]\nname = \"meu-app\"\nversion = \"1.2.3\"\ntype = \"binary\"\nentry = \"src/main.sy\"\n\n[packages]\nlexer = \"lib/lexer\"\napp = \"src\"\n"
    var cfg = emptyProjectConfig()
    cfg.meta = ProjectMeta {
        name: "default",
        version: "0.1.0",
        type: "binary",
        entry: "main.sy"
    }
    val parsed = parseTomlIntoConfig(content, cfg)
    assertMsg(parsed.meta.name == "meu-app", "name")
    assertMsg(parsed.meta.version == "1.2.3", "version")
    assertMsg(parsed.meta.entry == "src/main.sy", "entry")
    assertMsg(parsed.packages.get("lexer") == "lib/lexer", "lexer package")
    assertMsg(parsed.packages.get("app") == "src", "app package")
}

// Port of project_test.go TestResolveAliasPath — @alias/rest → filesystem segments.
test fn testResolveAliasPath() {
    var packages: Map[String, String] = Map[String, String]{}
    packages.set("lexer", "lib/lexer")
    val cfg = ProjectConfig {
        root: "",
        meta: defaultProjectMeta(),
        packages: packages
    }
    var rest: List[String] = []
    rest.append("tokens")
    match resolveAliasPath(cfg, "lexer", rest) {
        None => assertMsg(false, "expected lexer alias resolve")
        Some(segs) => {
            assertMsg(segs.size() == 3, "three segments")
            assertMsg(segs.get(0) == "lib", "seg0 lib")
            assertMsg(segs.get(1) == "lexer", "seg1 lexer")
            assertMsg(segs.get(2) == "tokens", "seg2 tokens")
        }
    }
    match resolveAliasPath(cfg, "missing", rest) {
        None => assertMsg(true, "undefined alias returns none")
        Some(_) => assertMsg(false, "undefined alias should fail")
    }
}

// Mirrors LoadProjectConfig: discover root from entry file and load soyuz.toml via PathIndex.
test fn testLoadProjectConfigFromEntry() {
    val root = "/tmp/myapp"
    val entry = "/tmp/myapp/src/main.sy"
    val toml = "[project]\nname = \"myapp\"\nversion = \"2.0.0\"\ntype = \"library\"\n\n[packages]\nutil = \"lib/util\"\n"
    var index = emptyPathIndex()
    index.markerFiles.append(joinPathFile(root, "soyuz.toml"))
    index.fileContents.set(joinPathFile(root, "soyuz.toml"), toml)
    val cfg = loadProjectConfigFromEntry(entry, index)
    assertMsg(cfg.root == root, "root from entry walk")
    assertMsg(cfg.meta.name == "myapp", "name from toml")
    assertMsg(cfg.meta.version == "2.0.0", "version from toml")
    assertMsg(cfg.meta.entry == "lib.sy", "library default entry")
    assertMsg(cfg.packages.get("util") == "lib/util", "packages from toml")
}

test fn testLoadProjectConfigFromEntryNoToml() {
    val root = "/tmp/standalone"
    val entry = "/tmp/standalone/main.sy"
    var index = emptyPathIndex()
    index.markerFiles.append(joinPathFile(root, ".soyuz-root"))
    val cfg = loadProjectConfigFromEntry(entry, index)
    assertMsg(cfg.root == root, "root with marker only")
    assertMsg(cfg.meta.name == "standalone", "default name from root basename")
    assertMsg(cfg.meta.entry == "main.sy", "binary default entry")
}

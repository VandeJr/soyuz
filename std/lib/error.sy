// @soyuz/error — compatibility shim; canonical definitions live in @soyuz/prelude.

pub interface Error {
    fn message() -> String
    fn code() -> Int
}

pub class NoneError : Error {
    pub val msg: String

    pub fn message(self) -> String = self.msg

    pub fn code(self) -> Int = 1
}

pub fn noneError(msg: String) -> Error = NoneError { msg: msg }

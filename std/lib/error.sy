// Soyuz Standard Library — Error
//
// Define a interface base para tratamento de erros no sistema.
// O tipo Result[T] utiliza esta interface para sua variante Err.

pub interface Error {
  fn message() -> String
  fn code() -> Int
}

pub class NoneError : Error {
    pub val msg: String

    pub fn message(self) -> String = self.msg

    pub fn code(self) -> Int = 1
}

pub fn noneError(msg: String) -> Error = NoneError { msg: msg }

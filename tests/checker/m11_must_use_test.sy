// M11 — must_use tests (stub — port from soyuz-go/internal/checker/)
import (
    { tokenize } from @lexer/lexer
    { Parser } from @parser/parser
    { newChecker, check } from @checker/checker
    { TypeError, CheckResult } from @checker/types
)

fn checkM11(src: String) -> List[TypeError] {
    val tokens = tokenize(src)
    val prog = Parser.new(tokens).parse()
    return check(newChecker(), prog).errors
}

test fn testM11Baseline() {
    // TODO: port milestone 11 tests from soyuz-go
    val errs = checkM11("fn main() { val x: Int = 1 }")
    assert(errs.size() == 0, "M11 baseline stub")
}

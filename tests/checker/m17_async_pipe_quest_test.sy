// M17 — async_pipe_quest tests (stub — port from soyuz-go/internal/checker/)
import (
    { tokenize } from @lexer/lexer
    { Parser } from @parser/parser
    { newChecker, check } from @checker/checker
    { TypeError, CheckResult } from @checker/types
)

fn checkM17(src: String) -> List[TypeError] {
    val tokens = tokenize(src)
    val prog = Parser.new(tokens).parse()
    return check(newChecker(), prog).errors
}

test fn testM17Baseline() {
    // TODO: port milestone 17 tests from soyuz-go
    val errs = checkM17("fn main() { val x: Int = 1 }")
    assert(errs.size() == 0, "M17 baseline stub")
}

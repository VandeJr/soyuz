// M16 — async_pipe tests (stub — port from soyuz-go/internal/checker/)
import (
    { tokenize } from @lexer/lexer
    { Parser } from @parser/parser
    { newChecker, check } from @checker/checker
    { TypeError, CheckResult } from @checker/types
)

fn checkM16(src: String) -> List[TypeError] {
    val tokens = tokenize(src)
    val prog = Parser.new(tokens).parse()
    return check(newChecker(), prog).errors
}

test fn testM16Baseline() {
    // TODO: port milestone 16 tests from soyuz-go
    val errs = checkM16("fn main() { val x: Int = 1 }")
    assert(errs.size() == 0, "M16 baseline stub")
}

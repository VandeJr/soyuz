// M15 — task with pipe chain tests (port of soyuz-go/internal/checker/m15_task_pipe_test.go)
import @parser/load
import @checker/load
import (
    { tokenize } from @lexer/lexer
    { Parser } from @parser/parser
    { newChecker } from @checker/checker
    { check } from @checker/dispatch
    { TypeError } from @checker/types
    { assertMsg } from @soyuz/testing
)

fn checkM15(src: String) -> List[TypeError] {
    val tokens = tokenize(src)
    val prog = Parser.new(tokens).parse()
    return check(newChecker(), prog).errors
}

test fn testM15TaskPipeBasic() {
    val src = "
fn double(n: Int) -> Int = n * 2

fn main() {
    val n = 21
    val t = task (n |> double)
    t.detach()
}
"
    val errs = checkM15(src)
    assertMsg(errs.size() == 0, "task (n |> double) não deve gerar erros")
}

test fn testM15TaskPipeChain() {
    val src = "
fn double(n: Int) -> Int = n * 2
fn toString(n: Int) -> String = \"x\"

fn main() {
    val n = 5
    val t = task (n |> double |> toString)
    t.detach()
}
"
    val errs = checkM15(src)
    assertMsg(errs.size() == 0, "task (n |> double |> toString) não deve gerar erros")
}

test fn testM15TaskPipeAwait() {
    val src = "
fn double(n: Int) -> Int = n * 2

fn main() -> Int {
    val n = 21
    val t = task (n |> double)
    return t.await()
}
"
    val errs = checkM15(src)
    assertMsg(errs.size() == 0, "t.await() em task pipe não deve gerar erros")
}

test fn testM15TaskPipeLiteralInput() {
    val src = "
fn double(n: Int) -> Int = n * 2

fn main() {
    val t = task (42 |> double)
    t.detach()
}
"
    val errs = checkM15(src)
    assertMsg(errs.size() == 0, "task (42 |> double) não deve gerar erros")
}

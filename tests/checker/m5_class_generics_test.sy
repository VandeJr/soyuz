// M5 — class_generics tests (stub — port from soyuz-go/internal/checker/)
import (
    { tokenize } from @lexer/lexer
    { Parser } from @parser/parser
    { newChecker, check } from @checker/checker
    { TypeError, CheckResult } from @checker/types
)

fn checkM5(src: String) -> List[TypeError] {
    val tokens = tokenize(src)
    val prog = Parser.new(tokens).parse()
    return check(newChecker(), prog).errors
}

test fn testM5Baseline() {
    // TODO: port milestone 5 tests from soyuz-go
    val errs = checkM5("fn main() { val x: Int = 1 }")
    assert(errs.size() == 0, "M5 baseline stub")
}

// M23 — numbering gap (no soyuz-go m23 source); milestone slot closed
import @parser/load
import @checker/load
import (
    { tokenize } from @lexer/lexer
    { Parser } from @parser/parser
    { newChecker } from @checker/checker
    { check } from @checker/dispatch
    { TypeError } from @checker/types
    { assertMsg } from @soyuz/testing
)

fn checkM23(src: String) -> List[TypeError] {
    val tokens = tokenize(src)
    val prog = Parser.new(tokens).parse()
    return check(newChecker(), prog).errors
}

test fn testM23TaskSendOnChannel() {
    val src = "
fn notify(ch: Channel[String]) {
    val t = task fn() => ch.send(\"ok\")
    t.await()
}
"
    val errs = checkM23(src)
    assertMsg(errs.size() == 0, "task enviando em Channel[T] não deve gerar erros")
}

test fn testM23TaskSendWrongTypeFails() {
    val src = "
fn notify(ch: Channel[Int]) {
    val t = task fn() => ch.send(\"wrong\")
    t.await()
}
"
    val errs = checkM23(src)
    assertMsg(errs.size() > 0, "task enviando tipo errado em Channel[Int] deve gerar erro")
}

test fn testM23TaskAwaitAfterChannelSend() {
    val src = "
fn relay(ch: Channel[Int]) -> Int {
    val t = task fn() => ch.send(42)
    t.await()
    ch.recv().unwrap()
}
"
    val errs = checkM23(src)
    assertMsg(errs.size() == 0, "task + channel send/recv não deve gerar erros")
}

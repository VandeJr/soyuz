// M12 — m12 tests (stub — port from soyuz-go/internal/checker/)
import (
    { tokenize } from @lexer/lexer
    { Parser } from @parser/parser
    { newChecker, check } from @checker/checker
    { TypeError, CheckResult } from @checker/types
)

fn checkM12(src: String) -> List[TypeError] {
    val tokens = tokenize(src)
    val prog = Parser.new(tokens).parse()
    return check(newChecker(), prog).errors
}

test fn testM12Baseline() {
    // TODO: port milestone 12 tests from soyuz-go
    val errs = checkM12("fn main() { val x: Int = 1 }")
    assert(errs.size() == 0, "M12 baseline stub")
}

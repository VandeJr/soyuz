// M20 — select tests (port of soyuz-go/internal/checker/m20_select_test.go)
import @parser/load
import @checker/load
import (
    { tokenize } from @lexer/lexer
    { Parser } from @parser/parser
    { newChecker } from @checker/checker
    { check } from @checker/dispatch
    { TypeError } from @checker/types
    { assertMsg } from @soyuz/testing
)

fn checkM20(src: String) -> List[TypeError] {
    val tokens = tokenize(src)
    val prog = Parser.new(tokens).parse()
    return check(newChecker(), prog).errors
}

test fn testM20SelectRecvArmTypeChecks() {
    val src = "
fn doSelect(ch: Channel[Int]) {
    select {
        msg = ch.recv() => print(msg)
    }
}
"
    val errs = checkM20(src)
    assertMsg(errs.size() == 0, "select recv arm não deve gerar erros")
}

test fn testM20SelectDefaultArmAllowed() {
    val src = "
fn doSelect(ch: Channel[Int]) {
    select {
        msg = ch.recv() => print(msg)
        default => print(\"nada\")
    }
}
"
    val errs = checkM20(src)
    assertMsg(errs.size() == 0, "select com default não deve gerar erros")
}

test fn testM20SelectMultipleRecvArms() {
    val src = "
fn doSelect(chA: Channel[Int], chB: Channel[Int]) {
    select {
        a = chA.recv() => print(a)
        b = chB.recv() => print(b)
    }
}
"
    val errs = checkM20(src)
    assertMsg(errs.size() == 0, "select com múltiplos arms não deve gerar erros")
}

test fn testM20SelectArmWithoutBinding() {
    val src = "
fn doSelect(ch: Channel[Int]) {
    select {
        ch.recv() => print(\"recebido\")
    }
}
"
    val errs = checkM20(src)
    assertMsg(errs.size() == 0, "select arm sem binding não deve gerar erros")
}

test fn testM20SelectOnlyDefault() {
    val src = "
fn doDefault() {
    select {
        default => print(\"sem canais\")
    }
}
"
    val errs = checkM20(src)
    assertMsg(errs.size() == 0, "select só com default não deve gerar erros")
}

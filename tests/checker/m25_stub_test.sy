// M25 — numbering gap (no soyuz-go m25 source); milestone slot closed
import @parser/load
import @checker/load
import (
    { tokenize } from @lexer/lexer
    { Parser } from @parser/parser
    { newChecker } from @checker/checker
    { check } from @checker/dispatch
    { TypeError } from @checker/types
    { assertMsg } from @soyuz/testing
)

fn checkM25(src: String) -> List[TypeError] {
    val tokens = tokenize(src)
    val prog = Parser.new(tokens).parse()
    return check(newChecker(), prog).errors
}

test fn testM25NumberingGapClosed() {
    val src = "
fn work(x: Int) -> Int { x * 2 }

fn run(n: Int) -> Int {
    val t = task work(n)
    val t2 = t.always(fn() => print(\"done\"))
    t2.await()
}
"
    val errs = checkM25(src)
    assertMsg(errs.size() == 0, "M25 slot fechado — paridade com M24 Task.always")
}

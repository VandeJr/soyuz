// M21 — m21 tests (stub — port from soyuz-go/internal/checker/)
import (
    { tokenize } from @lexer/lexer
    { Parser } from @parser/parser
    { newChecker, check } from @checker/checker
    { TypeError, CheckResult } from @checker/types
)

fn checkM21(src: String) -> List[TypeError] {
    val tokens = tokenize(src)
    val prog = Parser.new(tokens).parse()
    return check(newChecker(), prog).errors
}

test fn testM21Baseline() {
    // TODO: port milestone 21 tests from soyuz-go
    val errs = checkM21("fn main() { val x: Int = 1 }")
    assert(errs.size() == 0, "M21 baseline stub")
}

fn soma(a: Int, b: Int) -> Int = a + b
fn dobrar(x: Int) -> Int = x * 2

fn main() {
    val t = task soma(10, 20)
    print("task resultado: $(t.await())")

    val t2 = task soma(1, 2)
    t2.detach()
    print("detach ok")

    val t3 = task soma(1, 1)
    val t4 = task soma(2, 2)
    val (r1, r2) = Task.all(t3, t4)
    print("Task.all: $(r1) $(r2)")

    val dobrados = Task.gather([1, 2, 3, 4, 5], dobrar)
    print("gather ok")

    val ch = Channel.new(1)
    ch.send(99)
    match ch.recv() {
        Some(n) => print("channel recv: $(n)")
        None    => print("fechado")
    }

    val t5 = task soma(3, 4)
    val t6 = task soma(5, 6)
    print("multi: $(t5.await()) $(t6.await())")
}
